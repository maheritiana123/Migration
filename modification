if (err.IndexOf("Doublon", StringComparison.OrdinalIgnoreCase) >= 0)
{
    duplicates++;

    // ===== LOG DU DOUBLON =====
    if (rowForReject != null)
    {
        var duplicateColumns = GetDuplicateLogColumns(tableName);

        var values = new List<string>();

        foreach (string column in duplicateColumns)
        {
            object value;

            if (rowForReject.TryGetValue(column, out value))
            {
                values.Add(
                    column + "=" +
                    (value == null ? "NULL" : value.ToString()));
            }
        }

        // si aucune colonne PK/UNIQUE exploitable
        if (values.Count == 0
            && rowIndex >= 1
            && rowIndex <= oldIdPerRow.Count)
        {
            values.Add("OldId=" + oldIdPerRow[rowIndex - 1]);
        }

        WriteLog(
            "[DOUBLON] Table=" + tableName +
            " | " +
            string.Join(" | ", values));
    }

    // ===== CODE EXISTANT =====
    if (hasIdentity
        && !string.IsNullOrEmpty(newId)
        && rowIndex >= 1
        && rowIndex <= oldIdPerRow.Count)
    {
        var oldId = oldIdPerRow[rowIndex - 1];

        if (!string.IsNullOrEmpty(oldId))
        {
            if (!_idMappings.ContainsKey(tableName))
                _idMappings[tableName] =
                    new Dictionary<object, object>();

            _idMappings[tableName][oldId] = newId;
        }
    }
}
