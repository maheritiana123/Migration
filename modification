/* ============================================
   RÉINITIALISER UNE BASE SQL SERVER
   - Garde toute la structure
   - Garde PK / FK / UNIQUE / INDEX
   - Garde procédures stockées / vues / fonctions
   - Supprime uniquement les données
   - Reset les IDENTITY
============================================ */

SET NOCOUNT ON;

PRINT 'Désactivation des contraintes FK...';

EXEC sp_MSforeachtable 
'ALTER TABLE ? NOCHECK CONSTRAINT ALL';


PRINT 'Suppression des données...';

EXEC sp_MSforeachtable 
'DELETE FROM ?';


PRINT 'Réinitialisation des IDENTITY...';

EXEC sp_MSforeachtable '
IF OBJECTPROPERTY(OBJECT_ID(''?''), ''TableHasIdentity'') = 1
BEGIN
    DBCC CHECKIDENT (''?'', RESEED, 0);
END
';


PRINT 'Réactivation des contraintes FK...';

EXEC sp_MSforeachtable 
'ALTER TABLE ? WITH CHECK CHECK CONSTRAINT ALL';


PRINT 'Base réinitialisée avec succès.';