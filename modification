public class RequiredIfNotAttribute : ValidationAttribute
{
    private readonly string _propertyName;
    private readonly object _forbiddenValue;

    public RequiredIfNotAttribute(string propertyName, object forbiddenValue)
    {
        _propertyName = propertyName;
        _forbiddenValue = forbiddenValue;
    }

    protected override ValidationResult IsValid(object value, ValidationContext context)
    {
        var property = context.ObjectType.GetProperty(_propertyName);
        var propertyValue = property.GetValue(context.ObjectInstance);

        if (!Equals(propertyValue, _forbiddenValue) && string.IsNullOrEmpty(value as string))
        {
            return new ValidationResult($"{context.MemberName} est requis.");
        }

        return ValidationResult.Success;
    }
}