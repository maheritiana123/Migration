SELECT SUM(x.[count]) AS TotalExactApplication
FROM (
    SELECT
        ec.evc_id,
        ec.evc_log_id,
        (
            SELECT COUNT(*)
            FROM eventlog el
            WHERE el.evt_class_id = ec.evc_id
        ) AS [count]
    FROM eventclasses ec
    WHERE ec.evc_log_id IN (
        SELECT log_id
        FROM logs
    )
) x;