SELECT SUM(x.nb) AS TotalAffiche
FROM (
    SELECT ec.evc_id,
           COUNT(el.evt_id) AS nb
    FROM eventclasses ec
    LEFT JOIN eventlog el ON el.evt_class_id = ec.evc_id
    WHERE ec.evc_log_id IS NULL
    GROUP BY ec.evc_id

    UNION ALL

    SELECT ec.evc_id,
           COUNT(el.evt_id) AS nb
    FROM logs l
    JOIN eventclasses ec ON ec.evc_log_id = l.log_id
    LEFT JOIN eventlog el ON el.evt_class_id = ec.evc_id
    GROUP BY ec.evc_id
) x;