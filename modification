DECLARE @sql NVARCHAR(MAX) = '';

SELECT @sql += '
ALTER TABLE [' + SCHEMA_NAME(schema_id) + '].[' + name + '] NOCHECK CONSTRAINT ALL;'
FROM sys.tables;

SELECT @sql += '
DELETE FROM [' + SCHEMA_NAME(schema_id) + '].[' + name + '];'
FROM sys.tables;

SELECT @sql += '
ALTER TABLE [' + SCHEMA_NAME(schema_id) + '].[' + name + '] WITH CHECK CHECK CONSTRAINT ALL;'
FROM sys.tables;

EXEC sp_executesql @sql;