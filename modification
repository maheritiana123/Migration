private string EscapeCsvValue(string value)
{
    if (value == null)
        return "";

    // échappe les quotes
    value = value.Replace("\"", "\"\"");

    // IMPORTANT :
    // supprime les retours ligne
    value = value.Replace("\r", "\\r")
                 .Replace("\n", "\\n");

    // encapsule toujours
    return $"\"{value}\"";
}