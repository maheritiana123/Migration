using (var reader = new StreamReader(csvPath, Encoding.UTF8))
{
    // header
    string headerLine = reader.ReadLine();

    if (string.IsNullOrWhiteSpace(headerLine))
    {
        Console.WriteLine($"CSV vide : {tableName}");
        return;
    }

    var columnNames = ParseCsvSemicolon(headerLine)
        .Select(c => c.Trim())
        .ToList();

    var fkInfos = GetForeignKeyInfo(tableName);
    var identityColumn = GetIdentityColumn(tableName);
    bool hasIdentity = !string.IsNullOrEmpty(identityColumn);

    var columnTypes = columnNames.ToDictionary(
        c => c,
        c => GetColumnType(tableName, c),
        StringComparer.OrdinalIgnoreCase);

    var prepared = new List<Dictionary<string, object>>();
    var oldIdPerRow = new List<string>();

    int structuresSkipped = 0;

    string line;

    while ((line = reader.ReadLine()) != null)
    {
        var vals = ParseCsvSemicolon(line);

        if (vals.Count != columnNames.Count)
        {
            structuresSkipped++;
            continue;
        }

        var row = new Dictionary<string, object>(
            StringComparer.OrdinalIgnoreCase);

        for (int c = 0; c < columnNames.Count; c++)
            row[columnNames[c]] = vals[c];

        prepared.Add(row);

        if (hasIdentity)
            oldIdPerRow.Add(row[identityColumn]?.ToString());

        // flush batch
        if (prepared.Count >= batchSize)
        {
            InsertPreparedBatch(
                tableName,
                prepared,
                oldIdPerRow,
                columnNames,
                columnTypes,
                fkInfos,
                hasIdentity,
                identityColumn);

            prepared.Clear();
            oldIdPerRow.Clear();
        }
    }

    // dernier batch
    if (prepared.Count > 0)
    {
        InsertPreparedBatch(
            tableName,
            prepared,
            oldIdPerRow,
            columnNames,
            columnTypes,
            fkInfos,
            hasIdentity,
            identityColumn);
    }

    Console.WriteLine(
        $"Table {tableName} import terminée. " +
        $"{structuresSkipped} lignes sautées.");
}