2. Méthode qui récupère les colonnes utiles
private List<string> GetDuplicateLogColumns(string tableName)
{
    List<string> cachedColumns;

    if (_duplicateLogColumnsCache.TryGetValue(tableName, out cachedColumns))
        return cachedColumns;

    var columns = new List<string>();

    DynamicSql sql = new DynamicSql
    {
        Dsn = "PXE1_PXE"
    };

    string request = @"
        SELECT
            kcu.COLUMN_NAME,
            kcu.ORDINAL_POSITION
        FROM INFORMATION_SCHEMA.TABLE_CONSTRAINTS tc
        INNER JOIN INFORMATION_SCHEMA.KEY_COLUMN_USAGE kcu
            ON kcu.CONSTRAINT_NAME = tc.CONSTRAINT_NAME
           AND kcu.CONSTRAINT_SCHEMA = tc.CONSTRAINT_SCHEMA
           AND kcu.TABLE_NAME = tc.TABLE_NAME
           AND kcu.TABLE_SCHEMA = tc.TABLE_SCHEMA
        WHERE tc.TABLE_NAME = $table$
          AND tc.CONSTRAINT_TYPE IN ('PRIMARY KEY', 'UNIQUE')
          AND COLUMNPROPERTY(
                OBJECT_ID(kcu.TABLE_SCHEMA + '.' + kcu.TABLE_NAME),
                kcu.COLUMN_NAME,
                'IsIdentity'
              ) = 0
        ORDER BY
            kcu.ORDINAL_POSITION";

    sql.AddDirectRequest(
        request,
        MidwSqlXmlMode.MIDW_SQL_XMLMODE_RAW);

    sql.SetSecureParam("table", tableName, true, 0);
    sql.SetSite(Environment.GetEnvironmentVariable("PFTLSITE"));
    sql.Execute(30000);

    int rowCount = sql.ReturnedRows(1, 1);

    for (int i = 1; i <= rowCount; i++)
    {
        string columnName =
            sql.GetValueUsingColName(i, "COLUMN_NAME", 1, 1);

        if (string.IsNullOrWhiteSpace(columnName))
            continue;

        bool alreadyAdded = columns.Any(
            c => string.Equals(
                c,
                columnName,
                StringComparison.OrdinalIgnoreCase));

        if (!alreadyAdded)
            columns.Add(columnName);
    }

    _duplicateLogColumnsCache[tableName] = columns;

    return columns;
}

3. Méthode qui construit et écrit le log

private void LogDuplicateRow(
    string tableName,
    int rowIndex,
    Dictionary<string, object> duplicateRow,
    string oldId)
{
    var logParts = new List<string>();
    var usefulColumns = GetDuplicateLogColumns(tableName);

    foreach (string columnName in usefulColumns)
    {
        object value;

        if (!duplicateRow.TryGetValue(columnName, out value))
            continue;

        string displayValue =
            value == null || string.IsNullOrWhiteSpace(value.ToString())
                ? "NULL"
                : value.ToString();

        logParts.Add(columnName + "=" + displayValue);
    }

    // Cas où la seule PK est l'IDENTITY et qu'il n'existe aucune UNIQUE utile.
    if (logParts.Count == 0)
    {
        logParts.Add(
            "OldId=" +
            (string.IsNullOrWhiteSpace(oldId) ? "inconnu" : oldId));
    }

    string message =
        "[DOUBLON]" +
        " Table=" + tableName +
        " | BatchRow=" + rowIndex +
        " | " + string.Join(" | ", logParts);

    // Utilise ici la méthode qui écrit déjà dans ton fichier de log actuel.
    WriteLog(message);
}
