CREATE PROCEDURE [dbo].[usp_insert_associated_device]
	@assoc_remote_workstation_id AS INT ,
	@assoc_local_workstation_id AS INT ,
	@assoc_remote_name AS NVARCHAR(MAX),
	@assoc_remote_pxesite as NVARCHAR(MAX),
	@insert_event AS BIT
AS
BEGIN

	SET NOCOUNT ON

	DECLARE @assoc_id as INT;
	
	SELECT @assoc_id = assoc_id 
	FROM [dbo].[associated_devices] 
	WHERE assoc_local_workstation_id=@assoc_local_workstation_id
	AND assoc_remote_workstation_id = @assoc_remote_workstation_id
	AND assoc_remote_pxesite = @assoc_remote_pxesite;
	
	IF @assoc_id IS NULL 
	BEGIN
		
		--on insert un evenement avant insertion
		IF (@insert_event = 1) 
		BEGIN
			DECLARE @message as NVARCHAR(MAX);
			select @message = 'Association with workstation ' + @assoc_remote_name + ' added';
			
			DECLARE @user as NVARCHAR(MAX);
			select @user = 'PXE_'+@assoc_remote_pxesite;

			EXEC [dbo].[usp_insert_event2]
				@evc_name = N'INSERT_WORKSTATION_ASSOCIATION',
				@evt_data = NULL,
				@evt_message = @message,
				@evt_source = N'WEB',
				@evt_timegenerated = NULL,
				@evt_user = @user ,
				@wks_id = @assoc_local_workstation_id,
			@evt_justificatif = null;
		END
	
		INSERT INTO [dbo].[associated_devices] (assoc_local_workstation_id, assoc_remote_workstation_id,assoc_remote_pxesite,assoc_remote_name)
		VALUES (@assoc_local_workstation_id, @assoc_remote_workstation_id, @assoc_remote_pxesite,@assoc_remote_name);
		
		SELECT @assoc_id  = @@identity;
		
	END 
	ELSE
	BEGIN
		UPDATE [dbo].[associated_devices]
		SET assoc_remote_workstation_id = @assoc_remote_workstation_id,
		assoc_local_workstation_id = @assoc_local_workstation_id,
		assoc_remote_name = @assoc_remote_name,
		assoc_remote_pxesite = @assoc_remote_pxesite
		WHERE assoc_id = @assoc_id;
	END
	
	SELECT @assoc_id as [assoc_id];
END
GO
