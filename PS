CREATE FUNCTION [dbo].[fct_check_servers]()
RETURNS TABLE
AS
RETURN
(
		SELECT [e].*
		FROM [dbo].[fct_enum_servers]() [e]
		WHERE [references] > 0
		and not (
			srvid is NOT NULL
			and
			((len(ltrim(rtrim([dbo].[fct_extract_domain]([e].[srvname]))))>(0)))
			and
			((len(ltrim(rtrim([dbo].[fct_extract_hostname]([e].[srvname]))))>(0)))
		)
		UNION
		SELECT * FROM [dbo].[fct_enum_servers]()
		WHERE [dbo].[fct_extract_hostname]([srvname]) in (
			SELECT [dbo].[fct_extract_hostname]([e].[srvname])
			FROM [dbo].[fct_enum_servers]() [e]
			WHERE [references] > 0
			GROUP BY [dbo].[fct_extract_hostname]([e].[srvname])
			HAVING COUNT(*)>1
			)
		AND [references] > 0
)
