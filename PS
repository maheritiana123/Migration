CREATE PROCEDURE [dbo].[usp_select_identities]
	 @Types VARCHAR(3) = NULL	-- 2 valeurs possibles séparées par une virgule
	,@Description NVARCHAR(MAX) = NULL
	,@Value NVARCHAR(256) = NULL
	,@BankCode INT = NULL
	,@BranchCode INT = NULL
	,@Resources VARCHAR(MAX) = NULL
	,@ExpirationDateStart DATETIME = NULL
	,@ExpirationDateEnd DATETIME = NULL
AS
BEGIN

	DECLARE @typesTable TABLE ([id] SMALLINT);
	INSERT INTO @typesTable ([id]) SELECT value FROM string_split(@Types, ',')
	DECLARE @resourcesTable TABLE ([Name] VARCHAR(64));
	INSERT INTO @resourcesTable ([Name]) SELECT value FROM string_split(@Resources, ',')
	DECLARE @resourcesCount INT = (SELECT COUNT([Name]) FROM @resourcesTable)

	SELECT
		 a.[id]
		,[Type]
		,[Value]
		,[ExpirationDate]
		,[Description]
		,(SELECT [Name] FROM [dbo].[Resources] b WHERE a.[Id] = b.[IdentityId] FOR JSON AUTO) AS [Resources]
		,(SELECT * FROM [dbo].[Perimeters] c WHERE a.[Id] = c.[IdentityId] FOR JSON AUTO) AS [Perimeters]
	FROM dbo.[Identities] a
	WHERE [Id] IN (
		SELECT a.[Id]
		FROM [dbo].[Identities] a
		INNER JOIN [dbo].[Resources] d ON a.[Id] = d.[IdentityId]
		LEFT JOIN [dbo].[Perimeters] e ON a.[Id] = e.[IdentityId]
		WHERE
			(@Description IS NULL OR
				@Description = JSON_VALUE([Description], '$.AccountName') OR	-- Nom du compte de service
				@Description = JSON_VALUE([Description], '$.Subject'))			-- Objet du certificat
		AND (@Value IS NULL OR @Value = [Value])
		AND (@Types IS NULL OR [Type] IN (SELECT [Id] FROM @typesTable))
		AND (@ExpirationDateStart IS NULL OR @ExpirationDateStart <= [ExpirationDate])
		AND (@ExpirationDateEnd IS NULL OR @ExpirationDateEnd >= [ExpirationDate])
		AND (@Resources IS NULL OR d.[Name] IN (SELECT [Name] FROM @resourcesTable))
		AND (@BankCode IS NULL OR @BranchCode IS NULL AND [BankCodeEnd] IS NULL AND @BankCode = [BankCodeStart] OR
				@BranchCode IS NULL AND @BankCode BETWEEN [BankCodeStart] AND [BankCodeEnd] OR
				[BankCodeEnd] IS NULL AND [BankCodeStart] = @BankCode AND [BranchCodeStart] = @BranchCode OR
				([BankCodeStart] = @BankCode AND @BranchCode BETWEEN [BranchCodeStart] AND [BranchCodeEnd] OR
					@BankCode BETWEEN [BankCodeStart] AND [BankCodeEnd]))
		GROUP BY a.[Id]
		HAVING 
			CASE WHEN @Resources IS NOT NULL THEN
				SUM(CASE WHEN d.[Name] IS NULL THEN 0 ELSE 1 END)
				ELSE 1
			END
			= 
			CASE WHEN @Resources IS NOT NULL THEN @resourcesCount ELSE 1 END)
	
END
