CREATE VIEW [dbo].[workstations_view]
AS

	SELECT
		[names].[name_name],
		[workstations].[wks_accounting_bank],
		[workstations].[wks_accounting_branch],
		[workstations].[wks_accounting_number],
		[workstations].[wks_accounting_office],
		[workstations].[wks_accounting_federation],
		[workstations].[wks_accounting_pva],
		CASE WHEN [workstations].[wks_federation] IS NOT NULL AND LEN([workstations].[wks_federation])>0 THEN [workstations].[wks_federation] ELSE CASE WHEN [adspaths_view].[adp_id] IS NOT NULL THEN adspaths_view.[adp_federation] ELSE [s3].srv_wkit_fede END END AS [wks_federation],
		CASE WHEN [workstations].[wks_bank] IS NOT NULL AND LEN([workstations].[wks_bank])>0 THEN [workstations].[wks_bank] ELSE CASE WHEN [adspaths_view].[adp_id] IS NOT NULL THEN adspaths_view.[adp_bank] ELSE [s3].srv_wkit_codebanque END END AS [wks_bank],
		CASE WHEN adspaths_view.[adp_smssitecode] IS NOT NULL THEN adspaths_view.[adp_smssitecode] ELSE [s3].srv_wkit_srvsmsparentsitecode END AS [smssitecode],
		CASE WHEN adspaths_view.[adp_mtosenv] IS NOT NULL THEN adspaths_view.[adp_mtosenv] ELSE [s3].srv_wkit_mtosenv END AS [mtosenv],
		CASE WHEN [workstations].[wks_branch] IS NOT NULL AND LEN([workstations].[wks_branch])>0 THEN [workstations].[wks_branch] ELSE [s3].srv_wkit_codecaisse END AS [wks_branch] ,
		CASE WHEN [workstations].[wks_office] IS NOT NULL AND LEN([workstations].[wks_office])>0 THEN [workstations].[wks_office] ELSE [s3].srv_wkit_codebureau END AS [wks_office] ,
		[workstations].[wks_section],
		[workstations].[wks_pva],
		[workstations].[wks_adspath_imssite_id],
		CASE WHEN adspaths_view.[adf_name] IS NOT NULL THEN adspaths_view.[adf_name] ELSE [s3].srv_wkit_fede + '-AGENCES' END AS [adf_name],
		CASE WHEN adspaths_view.ads_name IS NOT NULL THEN adspaths_view.ads_name ELSE [s3].srv_wkit_codecaisse END AS [ads_name],
		CASE WHEN adspaths_view.[add_name] IS NOT NULL THEN adspaths_view.[add_name] ELSE [s3].srv_domain END AS [add_name],
		CASE WHEN ims_adp.[ims_name] IS NOT NULL THEN ims_adp.[ims_name] ELSE [s3].srv_wkit_siteims END AS [ims_name],
		[workstations].[wks_auto_default_printer],
		[workstations].[wks_bios_status],
		[workstations].[wks_bootconfiguration_bios],
		[workstations].[wks_bootconfiguration_os],
		[workstations].[wks_step_data],
		CONVERT(VARCHAR, [workstations].[wks_step_lastupdate], 120) AS [wks_step_lastupdate],
		[workstations].[wks_guid],
		CONVERT(VARCHAR, [workstations].[wks_heartbeat], 120) AS [wks_heartbeat],
		[workstations].[wks_hypervision],
		[workstations].[wks_id],
		[workstations].[wks_kit_distribution],
		[workstations].[wks_kit_equipment],
		[workstations].[wks_kit_model],
		[workstations].[wks_kit_operating_system],
		[workstations].[wks_macaddress],
		[workstations].[wks_mat_barcode],
		[workstations].[wks_pcom_mode],
		[workstations].[wks_pcom_ses1_imssite_id],
		[workstations].[wks_pcom_ses2_imssite_id],
		[workstations].[wks_pcom_ses3_imssite_id],
		[workstations].[wks_rblk_mode],
		[workstations].[wks_rblk_ses1_imssite_id],
		[workstations].[wks_rblk_ses2_imssite_id],
		[workstations].[wks_remote],
		[workstations].[wks_setup_status],
		[workstations].[wks_compromised],
		[workstations].[wks_sndpscanner],
		[workstations].[wks_pxe_server_id],
		[workstations].[wks_applicant_name],
		[workstations].[wks_uuid],
		[s1].srv_fullname as [wks_pxe_server_srv_fullname],
		[s3].srv_id as [wks_ref_server_id],
		CASE WHEN [s3].srv_wkit_srvnameold IS NOT NULL THEN [s3].srv_wkit_srvnameold ELSE [s3].srv_fullname END as [wks_ref_server_srv_fullname],
		[s2].srv_id as [wks_kit_server_id],
		[s2].[srv_fullname] as [wks_kit_server_srv_fullname],
		[workstations].[wks_kit_server_id] as [wks_kit_server_id_private],
		[adspaths_view].[adp_slice],
		CASE WHEN [adspaths_view].adp_antivirus_server_id IS NOT NULL THEN [adspaths_view].srv_fullname_av ELSE [s3].srv_wkit_srvav END AS [wks_av_server_srv_fullname],
		[ims_pcom1].[ims_name] as [wks_pcom_ses1_imssite_name],
		[ims_pcom2].[ims_name] as [wks_pcom_ses2_imssite_name],
		[ims_pcom3].[ims_name] as [wks_pcom_ses3_imssite_name],
		[ims_rblk1].[ims_name] as [wks_rblk_ses1_imssite_name],
		[ims_rblk2].[ims_name] as [wks_rblk_ses2_imssite_name],
		CASE WHEN [workstations].[wks_adspath_imssite_id] is NULL THEN [s1].[srv_wkit_codebanque]+[s1].[srv_wkit_codecaisse] ELSE [adspaths_view].[adp_scope] END as [perimeter],
		CONVERT(VARCHAR, [workstations].[wks_lastupdate], 120) as [wks_lastupdate],
		[workstations].[wks_tobereplaced_workstation_id],
		[tobereplaced_names].name_name as [wks_tobereplaced_workstation_name]
	
	FROM [dbo].[workstations] WITH (NOLOCK)
	LEFT JOIN [dbo].[names] ON [names].[name_workstation_id] = [workstations].[wks_id]
	LEFT JOIN ([dbo].[workstations] [tobereplaced] INNER JOIN [dbo].[names] [tobereplaced_names] WITH (NOLOCK) ON [tobereplaced_names].name_workstation_id = [tobereplaced].wks_id) ON [tobereplaced].[wks_id] = [workstations].[wks_tobereplaced_workstation_id]
	LEFT JOIN [dbo].[servers] [s1] ON [s1].[srv_id] = [workstations].[wks_pxe_server_id]
	LEFT JOIN [dbo].[imssites] [ims_pcom1] ON [ims_pcom1].[ims_id] = [workstations].[wks_pcom_ses1_imssite_id]
	LEFT JOIN [dbo].[imssites] [ims_pcom2] ON [ims_pcom2].[ims_id] = [workstations].[wks_pcom_ses2_imssite_id]
	LEFT JOIN [dbo].[imssites] [ims_pcom3] ON [ims_pcom3].[ims_id] = [workstations].[wks_pcom_ses3_imssite_id]
	LEFT JOIN [dbo].[imssites] [ims_rblk1] ON [ims_rblk1].[ims_id] = [workstations].[wks_rblk_ses1_imssite_id]
	LEFT JOIN [dbo].[imssites] [ims_rblk2] ON [ims_rblk2].[ims_id] = [workstations].[wks_rblk_ses2_imssite_id]
	LEFT JOIN [dbo].[adspaths_imssites] ON [adspaths_imssites].[adpims_id] = [workstations].[wks_adspath_imssite_id]
	LEFT JOIN [dbo].[imssites] [ims_adp] ON [ims_adp].[ims_id] = [adspaths_imssites].[adpims_imssite_id]
	LEFT JOIN [dbo].[adspaths_view] ON [adspaths_view].[adp_id] = [adspaths_imssites].[adpims_adspath_id]
	LEFT JOIN [dbo].[servers] [s2] ON [s2].[srv_id] = 
		CASE WHEN [workstations].[wks_kit_server_id] is NULL 
		THEN 
			CASE WHEN [workstations].[wks_adspath_imssite_id] is NULL 
			THEN [workstations].[wks_pxe_server_id] 
			ELSE [adspaths_view].[adp_kit_server_id] END
		ELSE [workstations].[wks_kit_server_id] END
	LEFT JOIN [dbo].[servers] [s3] ON [s3].[srv_id] = CASE WHEN [workstations].wks_adspath_imssite_id IS NULL THEN [workstations].[wks_pxe_server_id] ELSE [adspaths_view].adp_reference_server_id END
GO
