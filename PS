CREATE PROCEDURE [dbo].[usp_update_workstation_adspath_imssite]
	@adf_name AS VARCHAR(MAX),
	@ads_name AS VARCHAR(MAX),
	@add_name AS VARCHAR(MAX),
	@ims_name AS VARCHAR(MAX),
	@wks_id AS INT,
	@evt_message [NVARCHAR](MAX),
	@evt_user [NVARCHAR](MAX)
	
AS
BEGIN

	DECLARE @adpims_id AS INT;
	SELECT TOP 1 @adpims_id = adpims_id FROM [dbo].[adspaths_imssites] WITH (NOLOCK) WHERE adpims_adspath_id = (SELECT adp_id FROM [dbo].[adspaths_view] WITH (NOLOCK) WHERE adf_name = @adf_name and ads_name = @ads_name and add_name = @add_name) and adpims_imssite_id = (SELECT ims_id FROM [dbo].[imssites] WITH (NOLOCK) WHERE ims_name = @ims_name);

	IF (@adpims_id IS NOT NULL)
	BEGIN
		UPDATE [dbo].[workstations]
		SET wks_adspath_imssite_id = @adpims_id
		WHERE wks_id = @wks_id

		SELECT @@ROWCOUNT AS result

		EXEC [dbo].[usp_insert_event2]
		@wks_id = @wks_id,
		@evc_name = 'MODIFICATION_GLOBALE',
		@evt_message = @evt_message,
		@evt_source = 'WEB',
		@evt_user = @evt_user,
		@evt_justificatif = null;
	END

END
