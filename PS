CREATE PROCEDURE [dbo].[usp_update_workstation2]
	@name_name AS VARCHAR(16),
	@wks_accounting_bank AS VARCHAR(5),
	@wks_bank AS VARCHAR(5),
	@wks_accounting_branch AS VARCHAR(5),
	@wks_branch AS VARCHAR(5),
	@wks_accounting_number AS VARCHAR(2),
	@wks_accounting_office AS VARCHAR(2),
	@wks_office AS VARCHAR(2),
	@wks_accounting_federation AS VARCHAR(2),
	@wks_federation AS VARCHAR(2),
	@wks_section AS VARCHAR(7),
	@wks_accounting_pva AS VARCHAR(3),
	@wks_pva AS VARCHAR(3),
	@wks_adspath_imssite_id AS INT,
	@wks_auto_default_printer AS BIT,
	@wks_bios_status AS SMALLINT,
	@wks_bootconfiguration_bios AS VARCHAR(128),
	@wks_bootconfiguration_os AS VARCHAR(128),
	@wks_hypervision AS BIT,
	@wks_kit_distribution AS VARCHAR(8),
	@wks_kit_equipment AS VARCHAR(24),
	@wks_kit_model AS VARCHAR(24),
	@wks_kit_operating_system AS VARCHAR(16),
	@wks_kit_server_id AS INT,
	@wks_macaddress AS VARCHAR(12),
	@wks_uuid AS VARCHAR(50),
	@wks_mat_barcode AS VARCHAR(13),
	@wks_pcom_mode AS SMALLINT,
	@wks_pcom_ses1_imssite_name AS VARCHAR(MAX),
	@wks_pcom_ses2_imssite_name AS VARCHAR(MAX),
	@wks_pcom_ses3_imssite_name AS VARCHAR(MAX),
	@wks_rblk_mode AS SMALLINT,
	@wks_rblk_ses1_imssite_name AS VARCHAR(MAX),
	@wks_rblk_ses2_imssite_name AS VARCHAR(MAX),
	@wks_remote AS BIT,
	@wks_setup_status AS SMALLINT,
	@wks_compromised AS BIT,
	@wks_sndpscanner AS BIT,
	@wks_tobereplaced_workstation_name AS NVARCHAR(16),
	@wks_id AS INT,
	@evt_user [NVARCHAR](MAX),
	@evt_justificatif [NVARCHAR](128)
	
	
AS
BEGIN
	
	DECLARE @calculate_wks_bank AS VARCHAR(5);
	DECLARE @calculate_wks_branch AS VARCHAR(5);
	DECLARE @calculate_wks_office AS VARCHAR(2);
	DECLARE @calculate_wks_federation AS VARCHAR(2);
	DECLARE @calculate_wks_section AS VARCHAR(7);
	DECLARE @calculate_wks_pva AS VARCHAR(3);
	DECLARE @old_compromised AS BIT;

	DECLARE @evt_message AS NVARCHAR(MAX)
	SET @evt_message = N'The workstation has been modified.'
	SET @old_compromised = (SELECT wks_compromised FROM [dbo].[workstations_view] WITH (NOLOCK) WHERE wks_id = @wks_id)
	DECLARE @evc_name AS NVARCHAR(MAX)

	IF (@wks_setup_status = 1 or @wks_setup_status = 10)
		BEGIN
			SET @evc_name = 'REKIT'
		END
		ELSE
		BEGIN
			SET @evc_name = 'MODIFICATION'
		END
    /*Si on passe dans l'état compromis ou si on sort de l'état compromis on ne met pas de log ici, déjà une log dans le code CS pour mettre numéro SARA*/
	IF (@wks_compromised = 1)
	BEGIN
		IF (@old_compromised = 1)
		BEGIN
			EXEC [dbo].[usp_insert_event2] 
			@wks_id = @wks_id,
			@evc_name = @evc_name, 
			@evt_message = @evt_message, 
			@evt_source = 'WEB', 
			@evt_user = @evt_user,
			@evt_justificatif = @evt_justificatif;
		END		
	END
	IF (@wks_compromised = 0)
	BEGIN
		IF(@old_compromised = 0)
		BEGIN
		EXEC [dbo].[usp_insert_event2] 
			@wks_id = @wks_id,
			@evc_name = @evc_name, 
			@evt_message = @evt_message, 
			@evt_source = 'WEB', 
			@evt_user = @evt_user,
			@evt_justificatif = @evt_justificatif;
		END	
	END	
	
	IF (@name_name IS NOT NULL and (SELECT ISNULL(name_name , '') FROM [dbo].[workstations_view] WITH (NOLOCK) WHERE wks_id = @wks_id) != @name_name)
	BEGIN
		DELETE FROM [dbo].[names]
		WHERE name_workstation_id = @wks_id;
			
		INSERT INTO [dbo].[names]
		(name_name,name_workstation_id)
		VALUES
		(@name_name,@wks_id);
	END

	--on met à vide les variables organisationnels si ce sont déjà les variables par défaut.
	SELECT 
	@calculate_wks_federation = CASE WHEN [adspaths_view].[adp_id] IS NOT NULL THEN adspaths_view.[adp_federation] ELSE [s3].srv_wkit_fede END ,
	@calculate_wks_bank = CASE WHEN [adspaths_view].[adp_id] IS NOT NULL THEN adspaths_view.[adp_bank] ELSE [s3].srv_wkit_codebanque END ,
	@calculate_wks_branch = [s3].srv_wkit_codecaisse  ,
	@calculate_wks_office = [s3].srv_wkit_codebureau ,
	@calculate_wks_pva = NULL,
	@calculate_wks_section = NULL
	FROM [dbo].[workstations] WITH (NOLOCK)
	LEFT JOIN [dbo].[adspaths_imssites] ON [adspaths_imssites].[adpims_id] = [workstations].[wks_adspath_imssite_id]
	LEFT JOIN [dbo].[adspaths_view] ON [adspaths_view].[adp_id] = [adspaths_imssites].[adpims_adspath_id]
	LEFT JOIN [dbo].[servers] [s3] ON [s3].[srv_id] = CASE WHEN [workstations].wks_adspath_imssite_id IS NULL THEN [workstations].[wks_pxe_server_id] ELSE [adspaths_view].adp_reference_server_id END
	WHERE wks_id = @wks_id;

	--si la valeur à mettre est égale à la valeur calculée, on vide.
	IF (@wks_bank = @calculate_wks_bank )
	BEGIN
		select @wks_bank = null;
	END
	
	IF (@wks_branch = @calculate_wks_branch )
	BEGIN
		select @wks_branch = null;
	END
	
	IF (@wks_federation = @calculate_wks_federation )
	BEGIN
		select @wks_federation = null;
	END
	
	IF (@wks_section = @calculate_wks_section )
	BEGIN
		select @wks_section = null;
	END
	
	IF (@wks_office = @calculate_wks_office )
	BEGIN
		select @wks_office = null;
	END
	
	IF (@wks_pva = @calculate_wks_pva )
	BEGIN
		select @wks_pva = null;
	END
	
	UPDATE [dbo].[workstations]
	SET
	wks_accounting_bank = @wks_accounting_bank,
	wks_bank = @wks_bank,
	wks_accounting_branch = @wks_accounting_branch,
	wks_branch = @wks_branch,
	wks_accounting_number = @wks_accounting_number,
	wks_accounting_office = @wks_accounting_office,
	wks_office = @wks_office,
	wks_accounting_pva = @wks_accounting_pva,
	wks_pva = @wks_pva,
	wks_accounting_federation = @wks_accounting_federation,
	wks_federation = @wks_federation,
	wks_section = @wks_section,
	wks_adspath_imssite_id = @wks_adspath_imssite_id,
	wks_auto_default_printer = @wks_auto_default_printer,
	wks_bios_status = @wks_bios_status,
	wks_bootconfiguration_bios = @wks_bootconfiguration_bios,
	wks_bootconfiguration_os = @wks_bootconfiguration_os,
	wks_hypervision = @wks_hypervision,
	wks_kit_distribution = @wks_kit_distribution,
	wks_kit_equipment = @wks_kit_equipment,
	wks_kit_model = @wks_kit_model,
	wks_kit_operating_system = @wks_kit_operating_system,
	wks_kit_server_id = @wks_kit_server_id,
	wks_macaddress = @wks_macaddress,
	wks_uuid = @wks_uuid,
	wks_mat_barcode = @wks_mat_barcode,
	wks_pcom_mode = @wks_pcom_mode,
	wks_pcom_ses1_imssite_id = (SELECT ims_id from [dbo].[imssites] WITH (NOLOCK) where ims_name = @wks_pcom_ses1_imssite_name),
	wks_pcom_ses2_imssite_id = (SELECT ims_id from [dbo].[imssites] WITH (NOLOCK) where ims_name = @wks_pcom_ses2_imssite_name),
	wks_pcom_ses3_imssite_id = (SELECT ims_id from [dbo].[imssites] WITH (NOLOCK) where ims_name = @wks_pcom_ses3_imssite_name),
	wks_rblk_mode = @wks_rblk_mode,
	wks_rblk_ses1_imssite_id = (SELECT ims_id from [dbo].[imssites] WITH (NOLOCK) where ims_name = @wks_rblk_ses1_imssite_name),
	wks_rblk_ses2_imssite_id = (SELECT ims_id from [dbo].[imssites] WITH (NOLOCK) where ims_name = @wks_rblk_ses2_imssite_name),
	wks_remote = @wks_remote,
	wks_setup_status = @wks_setup_status,
	wks_compromised = @wks_compromised,
	wks_sndpscanner = @wks_sndpscanner,
	wks_step_data = CASE WHEN @wks_setup_status = 1 THEN NULL ELSE wks_step_data END,
	wks_step_lastupdate = CASE WHEN @wks_setup_status = 1 THEN GETDATE() ELSE wks_step_lastupdate END,
	wks_tobereplaced_workstation_id = (SELECT wks_id FROM [dbo].[workstations] WITH (NOLOCK) INNER JOIN [dbo].[names] WITH (NOLOCK) ON [name_workstation_id] = [wks_id] AND [name_name] = @wks_tobereplaced_workstation_name)
	WHERE
	wks_id = @wks_id
END


GO
