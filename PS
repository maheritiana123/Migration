CREATE   PROCEDURE [dbo].[usp_select_eventlogs]
	@guid AS VARCHAR(42) = NULL,
	@name AS NVARCHAR(16) = NULL,
	@mac AS NVARCHAR(12) = NULL,
	@uuid AS VARCHAR(42) = NULL,
	@mat_barcode AS NVARCHAR(13) = NULL,
	@persoid AS VARCHAR(MAX) = NULL,
	@evc_names AS NVARCHAR(MAX) = NULL,
	@datetime_debut AS VARCHAR(19) = NULL,
	@datetime_fin AS VARCHAR(19) = NULL,
	@page AS INT = 1,
	@nb_par_page AS INT = 20,
	@col_order AS VARCHAR(128),
	@justificatif AS VARCHAR(MAX) = NULL,
	@order AS VARCHAR(4)
	
AS
BEGIN
	SET NOCOUNT ON;

	DECLARE @pre NVARCHAR(MAX) = N'DECLARE @evc TABLE (evc_n NVARCHAR(32));' + NCHAR(10)
	+ N'INSERT INTO @evc' + NCHAR(10)
	+ N'SELECT value FROM STRING_SPLIT(@evc_names, '','');';

	DECLARE @WHERE AS NVARCHAR(MAX) = N'
	WHERE evc_name IN (SELECT evc_n FROM @evc)';
	IF (@guid IS NOT NULL)
	BEGIN
		SET @WHERE += N'
		AND evt_guid = @guid';
	END
	IF (@name IS NOT NULL)
	BEGIN
		SET @WHERE += N'
		AND (evt_workstation_name LIKE @name + ''%'' OR evt_guid IN (SELECT wks_guid FROM [dbo].[workstations_view] WHERE name_name LIKE @name + ''%''))';
	END
	IF (@mac IS NOT NULL)
	BEGIN
		SET @WHERE += N'
		AND (evt_workstation_macaddress LIKE @mac + ''%'' OR evt_guid IN (SELECT wks_guid FROM [dbo].[workstations] WHERE wks_macaddress LIKE @mac + ''%''))';
	END
	IF (@uuid IS NOT NULL)
	BEGIN
		SET @WHERE += N'
		AND (evt_workstation_uuid LIKE @uuid + ''%'' OR evt_guid IN (SELECT wks_guid FROM [dbo].[workstations] WHERE wks_uuid LIKE @uuid + ''%''))';
	END
	IF (@mat_barcode IS NOT NULL)
	BEGIN
		SET @WHERE += N'
		AND (evt_workstation_mat_barcode LIKE @mat_barcode + ''%'' OR evt_guid IN (SELECT wks_guid FROM [dbo].[workstations] WHERE wks_mat_barcode LIKE @mat_barcode + ''%''))';
	END
	IF (@persoid IS NOT NULL)
	BEGIN
		SET @WHERE += N'
		AND evt_user LIKE @persoid + ''%''';
	END
	IF (@justificatif IS NOT NULL)
	BEGIN
		SET @WHERE += N'
		AND evt_workstation_justificatif LIKE @justificatif + ''%''';
	END
	IF (@datetime_debut IS NOT NULL)
	BEGIN
		SET @WHERE += N'
		AND evt_timegenerated >= CONVERT(DATETIME, @datetime_debut, 120)';
	END
	IF (@datetime_fin IS NOT NULL)
	BEGIN
		SET @WHERE += N'
		AND evt_timegenerated <= CONVERT(DATETIME, @datetime_fin, 120)';
	END
	
	DECLARE @orderBy NVARCHAR(32);
	SELECT @orderBy = 
	CASE @col_order
		WHEN 'evt_timegenerated' THEN
			N'[evt_timegenerated]'
		WHEN 'evt_user' THEN
			N'[evt_user]'
		ELSE
			N'[evc_name]'
	END

	DECLARE @select NVARCHAR(MAX) = N'SELECT
	[t].[evt_id],
	[t].[evt_guid],
	[t].[evc_name],
	[t].[evt_data],
	[t].[evt_message],
	[t].[evt_reported],
	[t].[evt_source],
	[t].[evt_user],
	[t].[evt_workstation_name],
	[t].[evt_workstation_macaddress],
	[t].[evt_workstation_uuid],
	[t].[evt_workstation_status],
	[t].[evt_timegenerated],
	[t].[evt_timewritten],
	[t].[wks_id],
	[t].[new_mac],
	[t].[new_uuid],
	[t].[new_name],
	[t].[new_status],
	[t].[evt_workstation_mat_barcode],
	[t].[new_mat_barcode],
	[t].[evt_workstation_justificatif]' + NCHAR(10)
	+ N'FROM (
	SELECT
		[evt_id],
		[evt_guid],
		[evc_name],
		[evt_data],
		[evt_message],
		[evt_reported],
		[evt_source],
		[evt_user],
		[evt_workstation_name],
		[evt_workstation_macaddress],
		[evt_workstation_uuid],
		[evt_workstation_status],
		[evt_timegenerated],
		[evt_timewritten],
		[wks_id],
		[new_mac],
		[new_uuid],
		[new_name],
		[new_status],
		[evt_workstation_mat_barcode],
		[new_mat_barcode],
		[evt_workstation_justificatif],
		ROW_NUMBER() OVER(ORDER BY ' + @orderBy + N' ' + CASE @order WHEN N'Asc' THEN N'ASC' ELSE N'DESC' END + N') AS [row]
	FROM [dbo].[eventlog_view] WITH (NOLOCK)'
	+ @WHERE + NCHAR(10)
	+ N') AS [t]' + NCHAR(10)
	+ N'WHERE [t].[row] BETWEEN ' + CAST((@page - 1) * @nb_par_page + 1 AS NVARCHAR(MAX)) + N' AND ' + CAST(@page * @nb_par_page AS NVARCHAR(MAX)) + NCHAR(10)
	+ N'ORDER BY [t].[row] ASC';

	DECLARE @req NVARCHAR(MAX) = @pre + NCHAR(10) + NCHAR(10) + @select
	--print @req

	exec sp_executesql @req, N'
		@guid AS VARCHAR(42),
		@name AS NVARCHAR(16),
		@mac AS NVARCHAR(12),
		@uuid AS VARCHAR(42),
		@mat_barcode AS NVARCHAR(13),
		@persoid AS VARCHAR(MAX),
		@evc_names AS NVARCHAR(MAX),
		@datetime_debut AS VARCHAR(19),
		@datetime_fin AS VARCHAR(19),
		@justificatif AS VARCHAR(MAX)',
		@guid,
		@name,
		@mac,
		@uuid,
		@mat_barcode,
		@persoid,
		@evc_names,
		@datetime_debut,
		@datetime_fin,
		@justificatif

	DECLARE @WHERE2 AS NVARCHAR(MAX);
	
	SET @WHERE2 = N''
	IF (@guid IS NOT NULL)
	BEGIN
	SET @WHERE2 += N'
	AND evt_guid = @guid';
	END
	IF (@name IS NOT NULL)
	BEGIN
	SET @WHERE2 += N'
	AND (evt_workstation_name LIKE @name + ''%'' OR evt_guid IN (SELECT wks_guid FROM [dbo].[workstations_view] WHERE name_name LIKE @name + ''%''))';
	END
	IF (@mac IS NOT NULL)
	BEGIN
	SET @WHERE2 += N'
	AND (evt_workstation_macaddress LIKE @mac + ''%'' OR evt_guid IN (SELECT wks_guid FROM [dbo].[workstations] WHERE wks_macaddress LIKE @mac + ''%''))';
	END
	IF (@uuid IS NOT NULL)
	BEGIN
	SET @WHERE2 += N'
	AND (evt_workstation_uuid LIKE @uuid + ''%'' OR evt_guid IN (SELECT wks_guid FROM [dbo].[workstations] WHERE wks_uuid LIKE @uuid + ''%''))';
	END
	IF (@mat_barcode IS NOT NULL)
	BEGIN
	SET @WHERE2 += N'
	AND (evt_workstation_mat_barcode LIKE @mat_barcode + ''%'' OR evt_guid IN (SELECT wks_guid FROM [dbo].[workstations] WHERE wks_mat_barcode LIKE @mat_barcode + ''%''))';
	END
	IF (@persoid IS NOT NULL)
	BEGIN
	SET @WHERE2 += N'
	AND evt_user LIKE @persoid + ''%''';
	END
	IF (@datetime_debut IS NOT NULL)
	BEGIN
	SET @WHERE2 += N'
	AND evt_timegenerated >= CONVERT(DATETIME, @datetime_debut, 120)';
	END
	IF (@datetime_fin IS NOT NULL)
	BEGIN
	SET @WHERE2 += N'
	AND evt_timegenerated <= CONVERT(DATETIME, @datetime_fin, 120)';
	END

	DECLARE @requete2 AS NVARCHAR(MAX) = 
	N'SELECT 
	log_id,
	log_name,
	log_resource,
	evc_id,
	evc_name,
	evc_duration,
	evc_take_snapshot,
	COUNT(*) AS [count]' + NCHAR(10)
	+ N'FROM [dbo].[eventclasses] WITH (NOLOCK)' + NCHAR(10)
	+ N'INNER JOIN [dbo].[eventlog] WITH (NOLOCK) ON evc_id = evt_class_id' + NCHAR(10)
	+ N'LEFT JOIN dbo.logs WITH (NOLOCK) ON evc_log_id = log_id' + NCHAR(10)
	+ CASE WHEN LEN(@WHERE2) = 0 THEN '' ELSE N'WHERE 1=1' + @WHERE2 + NCHAR(10) END
	+ N'GROUP BY
	log_id,
	log_name,
	log_resource,
	evc_id,
	evc_name,
	evc_duration,
	evc_take_snapshot' + NCHAR(10)
	+ N'UNION' + NCHAR(10)
	+ N'SELECT
	log_id,
	log_name,
	log_resource,
	NULL,
	NULL,
	NULL,
	NULL,
	0' + NCHAR(10)
	+ N'FROM dbo.logs WITH (NOLOCK)' + NCHAR(10)
	+ N'WHERE log_id NOT IN (SELECT DISTINCT evc_log_id FROM dbo.eventclasses WITH (NOLOCK) WHERE evc_log_id IS NOT NULL)'

	--print @requete2
	EXEC sp_executesql @requete2, N'
		@guid VARCHAR(42),
		@name NVARCHAR(16),
		@mac NVARCHAR(12),
		@uuid VARCHAR(42),
		@mat_barcode NVARCHAR(13),
		@persoid VARCHAR(MAX),
		@datetime_debut VARCHAR(19),
		@datetime_fin VARCHAR(19)',
		@guid,
		@name,
		@mac,
		@uuid,
		@mat_barcode,
		@persoid,
		@datetime_debut,
		@datetime_fin	
END
GO
