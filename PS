CREATE PROCEDURE [dbo].[usp_delete_server]
	@srv_id [INT]
AS
BEGIN

	SET NOCOUNT ON
	
	-- Aucun poste n'utilise ce serveur en tant que serveur de kit
	-- donc on peut enlever ce serveur des serveurs de kit fixés dans les adspaths
	UPDATE [dbo].[adspaths]
	SET [adp_kit_server_id_private] = NULL
	WHERE [adp_kit_server_id_private] = @srv_id

	-- Suppression des chemins AD utilisant le serveur.
	-- Il faut s'assurer avant qu'aucun poste n'utilise un de ces chemins AD.
	DELETE FROM [dbo].[adspaths]
	WHERE [adp_antivirus_server_id] = @srv_id
	   OR [adp_reference_server_id] = @srv_id

	-- Modification de l'imprimante par défaut des postes de travail dans le cas où le défaut
	-- courant serait une imprimante attachée au serveur qu'on est en train de supprimer.
	UPDATE [dbo].[workstations]
	SET [wks_auto_default_printer] = 1
	WHERE [wks_id] IN (SELECT DISTINCT [net_workstation_id]
	                   FROM [dbo].[networkprinters] WITH (NOLOCK)
	                   INNER JOIN [dbo].[printers] WITH (NOLOCK) ON [networkprinters].[net_printer_id] = [printers].[prn_id]
	                   WHERE [networkprinters].[net_default] = 1
	                     AND [printers].[prn_server_id] = @srv_id)

	-- Suppression de toutes les associations entre des postes de travail et
	-- les imprimantes attachées au serveur qu'on est en train de supprimer.
	DELETE FROM [dbo].[networkprinters]
	WHERE [net_id] IN (SELECT DISTINCT [net_workstation_id]
	                   FROM [dbo].[networkprinters] WITH (NOLOCK)
	                   INNER JOIN [dbo].[printers] WITH (NOLOCK) ON [networkprinters].[net_printer_id] = [printers].[prn_id]
	                   WHERE [printers].[prn_server_id] = @srv_id)

	-- Suppression de toutes les associations dans lesquelles le serveur
	-- qu'on est en train de supprimer joue le rôle d'un serveur d'impression.
	DELETE FROM [dbo].[printservers]
	WHERE [prs_print_server_id] = @srv_id

	-- Suppression du serveur.
	DELETE FROM [dbo].[servers]
	WHERE [srv_id] = @srv_id

END
GO
