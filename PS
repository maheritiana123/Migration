CREATE VIEW [dbo].[POSTEVARVIEW]
		AS
		select poAdresseMac, poid, imsname as wpsiteims,addetail.wpsrvpxename, addetail.wpsrvav, addetail.wpsrvsms, addetail.wpsrvhis,addetail.wpcodebanque,
		addetail.wpcodefede, addetail.wpcodefedename, addetail.wpsmssitecode
		from poste 
		inner join 
		(
			select imsname, Adspath_Ims_Id, Adspath_Id from adspath_imssite
			inner join imssite on ImsSite_Id = imsid
		) as imslink on Adspath_Ims_Id = PoAdsImsId
		inner join
		(
		select ad.Adspath_Id,a.srvname as wpsrvpxename, b.srvname as wpsrvav, d.srvname as wpsrvsms, e.srvname as wpsrvhis,
		f.Bank_Name as wpcodebanque, g.Federation_Name as wpcodefede, h.Prefix_Name as wpcodefedename, i.Sms_Site_Name as wpsmssitecode
		from adspath as ad
		inner join srv a on a.srvid = ad.Srv_Pxe_Id
		inner join srv b on b.srvid = ad.Srv_Av_Id
		inner join srv d on d.srvid = ad.Srv_Sms_Id
		inner join srv e on e.srvid = ad.Srv_Sna_Id
		inner join bank f on f.Bank_Id = ad.Code_Bank_Id
		inner join federation g on g.Federation_Id = ad.Code_Fede_Id
		inner join prefix h on h.Prefix_Id = ad.Prefix_Id
		left outer  join SMSSITECODE i on i.Sms_Site_Id = ad.Code_Sms_Id) as addetail
		on addetail.Adspath_Id = imslink.Adspath_Id
