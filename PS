CREATE FUNCTION [dbo].[fct_enum_printers]()
RETURNS TABLE
AS
RETURN
(
	SELECT [srvid], [srvname], [printername], SUM(WPImpDef) AS [WPImpDef],
		SUM([WPPPrinterName]) AS [WPPPrinterName], SUM([WPRPrinterName]) AS [WPRPrinterName],
		SUM([WPRPrinterName2]) AS [WPRPrinterName2], SUM([WPRPrinterName3]) AS [WPRPrinterName3]
	FROM [dbo].[fct_enum_networkprinters]()
	GROUP BY [srvid], [srvname], [printername]
)
