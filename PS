GO

CREATE VIEW [dbo].[eventlog_view]
AS

SELECT
	evt_id,
	evt_guid,
	evc_name,
	evt_data,
	evt_message,
	evt_reported,
	evt_snapshot,
	evt_source,
	evt_timegenerated,
	evt_timewritten,
	evt_user,
	wks_id,
	evt_workstation_macaddress,
	evt_workstation_uuid,
	evt_workstation_name,
	evt_workstation_status,
	evt_workstation_justificatif,
	ISNULL(evt.mac,wks.mac) new_mac,
	ISNULL(evt.uuid,wks.uuid) new_uuid,
	CASE WHEN evt.mac IS NULL THEN wks.name ELSE evt.name END new_name,
	CASE WHEN evt.mac IS NULL THEN wks.[status] ELSE evt.status END new_status,
	evt_workstation_mat_barcode,
	CASE WHEN evt.mat_barcode IS NULL THEN wks.mat_barcode ELSE evt.mat_barcode END new_mat_barcode
FROM [dbo].[eventlog] WITH (NOLOCK)
INNER JOIN [dbo].[eventclasses] on evc_id = evt_class_id
OUTER APPLY
(select TOP 1 evt_workstation_macaddress mac,evt_workstation_uuid uuid, evt_workstation_name name, evt_workstation_mat_barcode mat_barcode, evt_workstation_status [status] FROM [dbo].[eventlog] as evt WITH (NOLOCK)
WHERE evt.evt_guid = eventlog.evt_guid AND evt.evt_timewritten > eventlog.evt_timewritten 
ORDER BY evt_timewritten asc) evt
OUTER APPLY
(SELECT TOP 1 wks_id, wks_macaddress mac,wks_uuid uuid, name_name name, wks_mat_barcode mat_barcode, wks_setup_status [status] FROM [dbo].[workstations] WITH (NOLOCK) 
LEFT JOIN [dbo].names ON name_workstation_id = wks_id 
WHERE eventlog.evt_guid = wks_guid) wks

