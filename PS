	IF @WPCodePVA IS NOT NULL AND LEN(@WPCodePVA) > 0 BEGIN INSERT INTO @variables ([key], [value]) VALUES ('WPCodePva', @WPCodePVA) END
	IF @WPCodeSection IS NOT NULL AND LEN(@WPCodeSection) > 0 BEGIN INSERT INTO @variables ([key], [value]) VALUES ('WPCodeSection', @WPCodeSection) END
