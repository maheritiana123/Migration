CREATE  PROCEDURE [dbo].[SUPPOSTES] @ADRMAC AS NVARCHAR(20), @HSTUSER AS NVARCHAR(8) AS
BEGIN
	DECLARE @HSTID As INT;
	DECLARE @IERREUR AS INT;
	DECLARE @POID AS INT;
	
	SET @IERREUR = 0;
	SET @POID = (SELECT POID FROM POSTE WHERE POADRESSEMAC=@ADRMAC);
	
	-- suppression des evénements relatifs à l'id du poste
	EXEC [dbo].[DEL_EVENT_BYPOID] @POID;
	SET @IERREUR = @IERREUR + @@ERROR;
	SELECT @IERREUR as result;
	
