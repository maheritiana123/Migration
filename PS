	SELECT [addomains].[add_id], [addomains].[add_name]
		, SUM(CASE WHEN [T].[counter] = 'number_of_adspaths' THEN [T].[count] ELSE 0 END) AS [number_of_adspaths]
		, SUM(CASE WHEN [T].[counter] = 'number_of_workstations' THEN [T].[count] ELSE 0 END) AS [number_of_workstations]
