CREATE PROCEDURE [dbo].[FUSION_UPDATE]
	@fede as varchar(2),
	@ofede as varchar(2),
	@bank as varchar(5),
	@obank as varchar(5),
	@agency as varchar(5),
	@oagency as varchar(5),
	@office as varchar(2),
	@ooffice as varchar(2),
	@sagency as varchar(5),
	@soffice as varchar(2)
WITH RECOMPILE
AS
BEGIN
declare @iErreur int
declare @sponamelist as nvarchar(512)
declare	@polist as varchar(512)
SET @iErreur = 0;

-- selection sur code caisse
IF len(@sagency) > 0 AND len(@soffice) =0
BEGIN
	SET @polist = 
	'SELECT DISTINCT PVEPOID FROM POSTEVARENV
	WHERE PVEVALEUR ='''+@sagency+
	'''AND PVEVEId IN (SELECT VEId FROM VarEnv WHERE VarEnv.VENom = ''WPCodeCaisse'')';
	
	execute(
	'SELECT PONOM FROM POSTE a
	INNER JOIN POSTEVARENV b ON a.POID = b.PVEPOID
	WHERE b.PVEVALEUR ='''+@sagency+'''
	AND b.PVEVEId IN (SELECT  VEId FROM VarEnv WHERE VarEnv.VENom = ''WPCodeCaisse'')');
END

-- selection sur code caisse/ code bureau
if len(@soffice) > 0
BEGIN
	SET @polist = 
	'SELECT DISTINCT a.PVEPOID FROM POSTEVARENV a
	INNER JOIN POSTEVARENV b on a.PVEPOID = b.PVEPOID
	WHERE a.PVEVALEUR =''' + @sagency + ''' AND a.PVEVEId IN (SELECT VEId FROM VarEnv WHERE VarEnv.VENom = ''WPCodeCaisse'')
	AND b.PVEVALEUR =''' +@soffice + ''' AND b.PVEVEId IN (SELECT VEId FROM VarEnv WHERE VarEnv.VENom = ''WPCodeBureau'')';
	
	execute( 
	'SELECT PONOM FROM POSTE c
	INNER JOIN POSTEVARENV a ON c.POID = a.PVEPOID
	INNER JOIN POSTEVARENV b on a.PVEPOID = b.PVEPOID
	WHERE a.PVEVALEUR =''' + @sagency + ''' AND a.PVEVEId IN (SELECT VEId FROM VarEnv WHERE VarEnv.VENom = ''WPCodeCaisse'')
	AND b.PVEVALEUR =''' +@soffice + ''' AND b.PVEVEId IN (SELECT VEId FROM VarEnv WHERE VarEnv.VENom = ''WPCodeBureau'')');

END

-- selection globale sur l'nesmele des postes nommés présents ayant la donnée commune @codebank
IF len(@sagency) =0 AND len(@soffice) =0
BEGIN
	SET @polist = 'SELECT DISTINCT PVEPOID FROM POSTEVARENV WHERE PVEVALEUR = '''+ @obank +''' AND PVEVEID IN (SELECT VEId FROM VarEnv WHERE VarEnv.VENom = ''WPCodeBanque'')';

	SELECT @sponamelist= 
	'SELECT PONOM FROM POSTE c
	INNER JOIN POSTEVARENV a ON c.POID = a.PVEPOID
	WHERE a.PVEVALEUR =''' + @obank + ''' AND a.PVEVEId IN (SELECT VEId FROM VarEnv WHERE VarEnv.VENom = ''WPCodeBanque'')';

	IF len(@ofede) > 0
	BEGIN
		SET @polist = 
		'SELECT DISTINCT a.PVEPOID FROM POSTEVARENV a
		INNER JOIN POSTEVARENV b on a.PVEPOID = b.PVEPOID
		WHERE a.PVEVALEUR =''' + @obank + ''' AND a.PVEVEId IN (SELECT VEId FROM VarEnv WHERE VarEnv.VENom = ''WPCodeBanque'')
		AND b.PVEVALEUR =''' +@ofede + ''' AND b.PVEVEId IN (SELECT VEId FROM VarEnv WHERE VarEnv.VENom = ''WPCodeFede'')';

		SELECT @sponamelist= 
		'SELECT PONOM FROM POSTE c
		INNER JOIN POSTEVARENV a ON c.POID = a.PVEPOID
		INNER JOIN POSTEVARENV b on a.PVEPOID = b.PVEPOID
		WHERE a.PVEVALEUR =''' + @obank + ''' AND a.PVEVEId IN (SELECT VEId FROM VarEnv WHERE VarEnv.VENom = ''WPCodeBanque'')
		AND b.PVEVALEUR =''' +@ofede + ''' AND b.PVEVEId IN (SELECT VEId FROM VarEnv WHERE VarEnv.VENom = ''WPCodeFede'')';

	END
	execute(@sponamelist);

END

-- update code banque
IF len(@bank) > 0 AND len(@fede) =0
BEGIN
	BEGIN TRANSACTION BANK_UPDATE
	
	EXECUTE('UPDATE PosteVarEnv                 
	SET    PVEValeur = ''' + @bank +'''            
	WHERE  PVEValeur = ''' + @obank + '''
	AND PVEVEId IN (SELECT  VEId FROM VarEnv WHERE VarEnv.VENom = ''WPCodeBanque'' or VarEnv.VENom = ''WPCodeBanqueComptable'') 
	AND PVEPOID IN ('+@polist+')'
	)    
	SET @iErreur = @iErreur + @@ERROR
	IF (@iErreur = 0) COMMIT TRANSACTION BANK_UPDATE
	ELSE ROLLBACK TRANSACTION BANK_UPDATE
END

-- update code fede + code banque
IF len(@bank) > 0 AND len(@fede) > 0
BEGIN
	BEGIN TRANSACTION FEDE_UPDATE
	EXECUTE('UPDATE POSTE
	SET PoAdspath = REPLACE(PoAdspath, '''+@ofede +'-AGENCES'', ''' + @fede + '-AGENCES'')
	WHERE (PoAdspath LIKE ''%'+ @ofede +'-AGENCES%'')
	AND POID IN ('+@polist+')'
	)
	
	EXECUTE('UPDATE PosteVarEnv                 
	SET    PVEValeur = ''' + @fede + '''            
	WHERE  PVEValeur = ''' + @ofede + ''' and (PVEVEId IN (SELECT VEId FROM VarEnv WHERE VarEnv.VENom = ''WPCodeFede''))
	AND PVEPOID IN ('+@polist+')'
	)

	-- on refait la liste selon le code fede updaté dans le cas global
	IF len(@sagency) =0 AND len(@soffice) =0
	BEGIN
		SET @polist = 
		'SELECT DISTINCT a.PVEPOID FROM POSTEVARENV a
		INNER JOIN POSTEVARENV b on a.PVEPOID = b.PVEPOID
		WHERE a.PVEVALEUR =''' + @obank + ''' AND a.PVEVEId IN (SELECT VEId FROM VarEnv WHERE VarEnv.VENom = ''WPCodeBanque'')
		AND b.PVEVALEUR =''' +@fede + ''' AND b.PVEVEId IN (SELECT VEId FROM VarEnv WHERE VarEnv.VENom = ''WPCodeFede'')';
	END

	EXECUTE('UPDATE PosteVarEnv                 
	SET    PVEValeur = ''' + @bank  + '''           
	WHERE  PVEValeur = ''' + @obank + '''
	AND PVEVEId IN (SELECT  VEId FROM VarEnv WHERE VarEnv.VENom = ''WPCodeBanque'' or VarEnv.VENom = ''WPCodeBanqueComptable'') 
	AND PVEPOID IN ('+@polist+')'
	)  
	
	SET @iErreur = @iErreur + @@ERROR
	IF (@iErreur = 0) COMMIT TRANSACTION FEDE_UPDATE
	ELSE ROLLBACK TRANSACTION FEDE_UPDATE


END
-- update code caisse + code bureau
IF len(@agency) > 0 AND len(@office) > 0
BEGIN
	BEGIN TRANSACTION CAISSE_UPDATE

	-- on refait la liste dans ce cas après chgt

	execute( 
	'SELECT PONOM FROM POSTE c
	INNER JOIN POSTEVARENV a ON c.POID = a.PVEPOID
	INNER JOIN POSTEVARENV b on a.PVEPOID = b.PVEPOID
	WHERE a.PVEVALEUR =''' + @oagency + ''' AND a.PVEVEId IN (SELECT VEId FROM VarEnv WHERE VarEnv.VENom = ''WPCodeCaisse'')
	AND b.PVEVALEUR =''' +@ooffice + ''' AND b.PVEVEId IN (SELECT VEId FROM VarEnv WHERE VarEnv.VENom = ''WPCodeBureau'')');

	
	EXECUTE('UPDATE POSTE SET PoAdspath = REPLACE(PoAdspath, ''OU#'+@oagency+';'', ''OU#'+@agency+';'')
	FROM POSTE a 
	INNER JOIN
	(
		SELECT PVEPOID FROM POSTEVARENV WHERE PVEVALEUR =''' + @ooffice + '''
		AND PVEVEId IN (SELECT VEId FROM VarEnv WHERE VarEnv.VENom = ''WPCodeBureau'')
	) AS b
	on a.POID = b.PVEPOID 
	WHERE (PoAdspath LIKE ''%OU#'+@oagency+';%'')'
	)

	EXECUTE('UPDATE PosteVarEnv SET PVEValeur = '''+@agency  +'''
	FROM POSTEVARENV a 
	INNER JOIN
	(
		SELECT PVEPOID FROM POSTEVARENV WHERE PVEVALEUR =''' + @ooffice + '''
		AND PVEVEId IN (SELECT VEId FROM VarEnv WHERE VarEnv.VENom = ''WPCodeBureau'')
	) AS b
	on a.PVEPOID = b.PVEPOID 
	WHERE PVEValeur = '''+@oagency +''' and
	(PVEVEId IN (SELECT  VEId FROM VarEnv WHERE VarEnv.VENom = ''WPCodeCaisse'' or VarEnv.VENom = ''WPCodeCaisseComptable'' ))'
	)

	EXECUTE('UPDATE POSTEVARENV SET pvevaleur = ''' + @office + '''
	FROM POSTEVARENV a 
	INNER JOIN
	(
		SELECT PVEPOID FROM POSTEVARENV WHERE PVEVALEUR =''' +@agency + '''
		AND PVEVEId IN (SELECT VEId FROM VarEnv WHERE VarEnv.VENom = ''WPCodeCaisse'')
	) AS b
	on a.PVEPOID = b.PVEPOID 
	WHERE a.PVEValeur = ''' + @ooffice + '''
	AND PVEVEId IN (SELECT  VEId FROM VarEnv WHERE VarEnv.VENom = ''WPCodeBureau'' or VarEnv.VENom = ''WPCodeBureauComptable'')'
	)

	SET @iErreur = @iErreur + @@ERROR
	IF (@iErreur = 0) COMMIT TRANSACTION CAISSE_UPDATE
	ELSE ROLLBACK TRANSACTION CAISSE_UPDATE
END

-- retour du nombre de poste
IF (@iErreur <> 0)
BEGIN
	select('Erreur lors de l''opération : ' + @iErreur +'. Aucun changement effectué');
END

END
GO
