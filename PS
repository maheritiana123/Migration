CREATE PROCEDURE [dbo].[usp_select_workstations3]
	@list AS VARCHAR(MAX) = NULL,
	@list_views AS XML = NULL,
	@srv AS VARCHAR(MAX) = NULL,
	@page AS INT,
	@nb_par_page AS INT,
	@col_order AS VARCHAR(MAX),
	@order AS VARCHAR(MAX)
	
AS
BEGIN

	SET NOCOUNT ON

	DECLARE @declarations_variables AS VARCHAR(MAX);
	SET @declarations_variables = '
	DECLARE @list_views AS XML;
	SET @list_views = '''+CAST(@list_views AS VARCHAR(MAX))+''';';

	DECLARE @WHERE AS VARCHAR(MAX);
	

	DECLARE @TEMPLATES AS VARCHAR(MAX);
	SET @TEMPLATES = 
	'wks_macaddress like ''@template'''
	+';' + 'wks_uuid like ''@template'''
	+';' + 'name_name like ''@template'''
	+';' + 'wks_tobereplaced_workstation_name like ''@template'''
	+';' + 'wks_mat_barcode like ''@template'''
	+';' + 'wks_kit_model = REPLACE(''@template'',''%'','''')'
	+';' + 'wks_kit_operating_system like ''@template'''
	+';' + 'wks_kit_equipment like ''@template'''
	+';' + 'wks_ref_server_srv_fullname like ''@template'''
	+';' + 'CAST(wks_setup_status AS VARCHAR) = ''@template'''
	
	IF @list IS NOT NULL
	BEGIN
	SET @WHERE = [dbo].[fct_add_conditions](@WHERE,@list,@TEMPLATES);
	END        
	
	IF (@list_views IS NOT NULL AND @list_views.value('count(/views/view)','INT') > 0)
	BEGIN
	DECLARE @list_v AS VARCHAR(MAX);
	SET @list_v = ''
	SELECT @list_v = @list_v + ',''' + t2.toto.value('.','VARCHAR(MAX)') + '''' FROM @list_views.nodes('views/view') as t2(toto)
	SET @WHERE = [dbo].[fct_add_condition](@WHERE,'wks_ref_server_id in (SELECT distinct viewsrv_server_id from views_servers inner join views ON view_id = viewsrv_view_id WHERE view_name in ('+SUBSTRING(@list_v,2,len(@list_v))+') GROUP BY viewsrv_server_id HAVING count(viewsrv_view_id) = '+CAST(@list_views.value('count(views/view)','INT') AS VARCHAR(MAX))+')','AND');
	END
	IF (@srv IS NOT NULL)
	BEGIN
	DECLARE @wks_ref_server_id AS INT
	SELECT @wks_ref_server_id = srv_id FROM [dbo].[servers] WITH (NOLOCK) WHERE srv_hostname = @srv
	SET @WHERE = [dbo].[fct_add_condition](@WHERE,'wks_ref_server_id = ' + CAST(@wks_ref_server_id AS VARCHAR) + '','AND');
	END
	
	IF (@WHERE = 'WHERE()')
	BEGIN
	SET @WHERE = N'';
	END
		
	IF CHARINDEX('WHERE() AND',@WHERE) > 0
	BEGIN
	SET @WHERE = REPLACE(@WHERE,'WHERE() AND','WHERE'); 
	END
	
DECLARE @requete AS VARCHAR(MAX);
SET @requete =  
	'SELECT
	wks_id,
	wks_macaddress,
	wks_uuid,
	name_name,
	wks_setup_status,
	wks_compromised,
	wks_kit_model,
	wks_kit_operating_system,
	wks_kit_equipment,
	wks_ref_server_id,
	wks_ref_server_srv_fullname,
	perimeter,
	CONVERT(VARCHAR,wks_lastupdate, 120) wks_lastupdate
	FROM [dbo].[workstations_view] WITH (NOLOCK)'
	+ ' ' + ISNULL(@WHERE,'') + ' ';

EXEC [dbo].[USP_PAGINATION]
@page = @page,
@nb_par_page = @nb_par_page,
@col_order = @col_order,
@order = @order,
@requete_appelante = @requete;

END
