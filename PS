    @p12 SQL_VARIANT = NULL, @p13 SQL_VARIANT = NULL, @p14 SQL_VARIANT = NULL,
    @p15 SQL_VARIANT = NULL, @p16 SQL_VARIANT = NULL, @p17 SQL_VARIANT = NULL,
    @p18 SQL_VARIANT = NULL, @p19 SQL_VARIANT = NULL
AS
BEGIN
    SET NOCOUNT ON;
    
    DECLARE @sql NVARCHAR(MAX);
    DECLARE @paramDef NVARCHAR(MAX) = N'
        @p0 SQL_VARIANT, @p1 SQL_VARIANT, @p2 SQL_VARIANT,
        @p3 SQL_VARIANT, @p4 SQL_VARIANT, @p5 SQL_VARIANT,
        @p6 SQL_VARIANT, @p7 SQL_VARIANT, @p8 SQL_VARIANT,
        @p9 SQL_VARIANT, @p10 SQL_VARIANT, @p11 SQL_VARIANT,
        @p12 SQL_VARIANT, @p13 SQL_VARIANT, @p14 SQL_VARIANT,
        @p15 SQL_VARIANT, @p16 SQL_VARIANT, @p17 SQL_VARIANT,
        @p18 SQL_VARIANT, @p19 SQL_VARIANT';
    
    -- Construction sécurisée de la requête
    SET @sql = N'INSERT INTO ' + QUOTENAME(@TableName) + ' (' + @Columns + ') 
                 VALUES (' + @Values + ')';
    
    -- Gestion IDENTITY
	IF @HasIdentity = 1
        SET @sql = @sql + N'; SELECT SCOPE_IDENTITY() AS NEW_ID';
    
    -- Exécution avec tous les paramètres
    EXEC sp_executesql @sql, @paramDef,
        @p0, @p1, @p2, @p3, @p4, @p5, @p6, @p7, @p8, @p9,
        @p10, @p11, @p12, @p13, @p14, @p15, @p16, @p17, @p18, @p19;
END
