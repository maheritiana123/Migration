CREATE PROCEDURE [dbo].[usp_update_pcomsession]
	@name AS NVARCHAR(MAX),
	@sessionid AS INT,
	@imssite AS NVARCHAR(MAX)
AS
BEGIN

DECLARE @haserror AS BIT;
SET @haserror = 0;

IF (@sessionid NOT IN (1,2,3))
BEGIN
	SELECT 'sessionid must be 1, 2 or 3 !' as Error;
	SET @haserror = 1;
END

DECLARE @wks_id as INT
SELECT @wks_id = name_workstation_id FROM [dbo].names WITH (NOLOCK)
WHERE name_name = @name

IF (@wks_id IS NULL)
BEGIN
	SELECT 'workstation "' + @name + '" does not exist !' as Error;
	SET @haserror = 1;
END

DECLARE @ims_id as INT
SELECT @ims_id = ims_id FROM [dbo].imssites WITH (NOLOCK)
WHERE ims_name = @imssite;

IF (@ims_id IS NULL AND @imssite IS NOT NULL)
BEGIN
	SELECT 'Ims site "' + @imssite + '" does not exist !' as Error;
	SET @haserror = 1;
END

IF (@haserror = 0)
BEGIN

	DECLARE @evc_name AS NVARCHAR(MAX)
	DECLARE @evt_message as NVARCHAR(MAX)
	SET @evc_name = 'MODIFICATION'
	SET @evt_message = N'The workstation has been modified.'			
		
	EXEC [dbo].[usp_insert_event] 
	@evc_name = @evc_name,
	@evt_data = NULL,
	@evt_message = @evt_message,
	@evt_source = 'WEBS',
	@evt_user = 'WEBS',
	@evt_justificatif = NULL,
	@wks_id = @wks_id
	;

	IF (@sessionid = 1)
	BEGIN
		UPDATE [dbo].workstations
		SET wks_pcom_ses1_imssite_id = @ims_id
		WHERE wks_id = @wks_id;
	END
	IF (@sessionid = 2)
	BEGIN
		UPDATE [dbo].workstations
		SET wks_pcom_ses2_imssite_id = @ims_id
		WHERE wks_id = @wks_id;
	END
	IF (@sessionid = 3)
	BEGIN
		UPDATE [dbo].workstations
		SET wks_pcom_ses3_imssite_id = @ims_id
		WHERE wks_id = @wks_id;
	END
END
END
		  
		  

