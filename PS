CREATE PROCEDURE [dbo].[ADD_EVENT_ENTRY]
	@CATEGORY AS NVARCHAR(50),
	@PONAME AS NVARCHAR(13),
	@USERNAME AS NVARCHAR(8),
	@SOURCE AS NVARCHAR(50),
	@DATA AS NVARCHAR(1024),
	@GDATE AS NVARCHAR(20)
AS
BEGIN
	DECLARE	@IERREUR AS INT
	DECLARE	@ERRLABEL AS NVARCHAR(50)
	DECLARE @POID AS INT
	DECLARE @CATID AS INT

	SET @IERREUR = 0;
	SELECT @ERRLABEL = '';	
	-- SELECT POID
	IF EXISTS(SELECT POID FROM POSTE WHERE PONOM = @PONAME)
	BEGIN
		SELECT @POID = (SELECT POID FROM POSTE WHERE PONOM = @PONAME);
		-- SELECT CATID
		IF EXISTS(SELECT CATEGORYID FROM EVENT_CATEGORIES WHERE CATEGORYNAME = @CATEGORY)
		BEGIN
			SELECT @CATID = (SELECT CATEGORYID FROM EVENT_CATEGORIES WHERE CATEGORYNAME = @CATEGORY);
		END
		-- INSERT CATID IF NOT EXISTS
		ELSE
		BEGIN
			EXEC [dbo].[ADD_EVENT_CATEGORY] @CATEGORY, '', @CATID OUT;
		END

		IF(@CATID = 0)
		BEGIN
			SELECT @ERRLABEL = 'ERROR WHEN GETTING CATEGORY ID';
		END
		ELSE
		BEGIN
			-- INSERT EVENT ACCORDING GDATE
			IF LEN(@GDATE) > 0
			BEGIN
				INSERT INTO EVENTS(EVTSOURCE,EVTTXT,EVTUSR,EVTPOID,EVTCATEGORYID,EVTORIGINALEDATE) VALUES(@SOURCE,@DATA,@USERNAME,@POID,@CATID,convert(datetime,@GDATE,103));
			END
			ELSE
			BEGIN
				INSERT INTO EVENTS(EVTSOURCE,EVTTXT,EVTUSR,EVTPOID,EVTCATEGORYID) VALUES(@SOURCE,@DATA,@USERNAME,@POID,@CATID);
			END
			SET @IERREUR = @IERREUR + @@ERROR;
		END
	END
	-- POID NOT FOUND
	ELSE
	BEGIN
		SELECT @ERRLABEL = 'POST ' + @PONAME+ ' NOT FOUND IN DATABASE';
	END
	-- ERROR INSERT EVENT
	IF(@IERREUR <> 0)
	BEGIN
		SELECT @ERRLABEL = 'ERROR WHEN INSERTING EVENT' + @CATEGORY;
	END

	IF LEN(@ERRLABEL) > 0
	BEGIN
		SELECT @ERRLABEL as resultlabel;
	END
END
GO
