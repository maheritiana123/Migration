	IF @WPImpILS IS NOT NULL AND LEN(@WPImpILS) > 0 BEGIN INSERT INTO @variables ([key], [value]) VALUES ('WPImpILS', @WPImpILS) END
	IF @WPImpLocal IS NOT NULL AND LEN(@WPImpLocal) > 0 BEGIN INSERT INTO @variables ([key], [value]) VALUES ('WPImpLocal', @WPImpLocal) END
	IF @WPImpUsb IS NOT NULL AND LEN(@WPImpUsb) > 0 BEGIN INSERT INTO @variables ([key], [value]) VALUES ('WPImpUsb', @WPImpUsb) END
	IF @WPIPrinterTER IS NOT NULL AND LEN(@WPIPrinterTER) > 0 BEGIN INSERT INTO @variables ([key], [value]) VALUES ('WPIPrinterTER', @WPIPrinterTER) END
	IF @WPIPrinterVerso IS NOT NULL AND LEN(@WPIPrinterVerso) > 0 BEGIN INSERT INTO @variables ([key], [value]) VALUES ('WPIPrinterVerso', @WPIPrinterVerso) END
