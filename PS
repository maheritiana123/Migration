BEGIN
	select pxesrv.srvname as wpsrvpxe, avsrv.srvname as wpsrvav, smssrv.srvname as wpsrvsms, snasrv.srvname as wpsrvhis,
	a.Bank_Name as wpcodebanque, c.Prefix_Name as codefedepostename, d.Federation_Name as wpcodefede,
