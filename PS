          (SELECT * FROM [dbo].[servers] WITH (NOLOCK) WHERE prn_server_id = srv_id FOR XML RAW('printserver'), ELEMENTS , TYPE)
          from [dbo].[networkprinters_view] where net_workstation_id = wks_id FOR XML RAW('networkprinter'), ELEMENTS , TYPE) networkprinters
