CREATE PROCEDURE [dbo].[usp_update_replaceserver]
	@oldsrv_id AS INT,
	@type AS VARCHAR(16),
	@newsrv_id AS INT
AS
BEGIN

	SET NOCOUNT ON

		IF @type = 'ref' 
		BEGIN
			UPDATE [dbo].[workstations]
			SET [wks_kit_server_id] = @oldsrv_id
			WHERE [wks_id] in (SELECT [wks_id] FROM [dbo].[workstations_view] WITH (NOLOCK) WHERE [wks_ref_server_id] = @oldsrv_id)
			AND [wks_kit_server_id] IS NULL
			
			UPDATE [dbo].[adspaths]
			SET [adp_reference_server_id] = @newsrv_id
			WHERE [adp_reference_server_id] = @oldsrv_id

			UPDATE [dbo].[workstations]
			SET [wks_pxe_server_id] = @newsrv_id
			WHERE [wks_pxe_server_id] = @oldsrv_id
		END

		IF @type = 'kit' 
		BEGIN

			UPDATE [dbo].[workstations]
			SET [wks_kit_server_id] = @newsrv_id
			WHERE [wks_kit_server_id] = @oldsrv_id or ([wks_adspath_imssite_id] IS NULL AND wks_pxe_server_id = @oldsrv_id AND wks_kit_server_id IS NULL)

			UPDATE [dbo].[adspaths]
			SET [adp_kit_server_id_private] = @newsrv_id
			WHERE [adp_kit_server_id_private] = @oldsrv_id or ([adp_reference_server_id] = @oldsrv_id and [adp_kit_server_id_private] is NULL)
			
		END

		IF @type = 'print' 
		BEGIN
			UPDATE [dbo].[printservers]
			SET [prs_print_server_id] = @newsrv_id
			WHERE [prs_print_server_id] = @oldsrv_id
				AND NOT EXISTS(SELECT * FROM [dbo].[printservers] as [p2] WITH (NOLOCK) WHERE [p2].[prs_server_id] = [prs_server_id] and [p2].[prs_print_server_id] = @newsrv_id)
			
			DELETE FROM [dbo].[printservers]
			WHERE [prs_print_server_id] = @oldsrv_id

			UPDATE [dbo].[printers]
			SET [prn_server_id] = @newsrv_id
			WHERE [prn_server_id] = @oldsrv_id
			AND prn_name NOT IN (SELECT prn_name FROM [dbo].[printers] WITH (NOLOCK) WHERE prn_server_id = @newsrv_id)
			
			UPDATE [dbo].[networkprinters]
			SET [net_printer_id] = (SELECT prn_id FROM [dbo].[printers] p1 WITH (NOLOCK) WHERE p1.prn_name = p2.prn_name AND p1.prn_server_id = @newsrv_id)
			FROM [dbo].[networkprinters]
			INNER JOIN [dbo].[printers] p2 WITH (NOLOCK) ON net_printer_id = prn_id
			WHERE [prn_server_id] = @oldsrv_id 
			
			DELETE FROM [dbo].[printers]
			WHERE prn_server_id = @oldsrv_id
		END

		IF @type = 'av' 
		BEGIN
			UPDATE [dbo].[adspaths]
			SET [adp_antivirus_server_id] = @newsrv_id
			WHERE [adp_antivirus_server_id] = @oldsrv_id 
		END

  END
		  
