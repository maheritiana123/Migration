		FROM [dbo].[workstations] WITH (NOLOCK)
		JOIN [dbo].[adspaths_imssites] WITH (NOLOCK) ON [adspaths_imssites].[adpims_id] = [workstations].[wks_adspath_imssite_id]
		JOIN [dbo].[adspaths] WITH (NOLOCK) ON [adspaths].[adp_id] = [adspaths_imssites].[adpims_adspath_id]
		GROUP BY [adspaths].[adp_addomain_id] ) AS [T] ON [T].[domain_id] = [addomains].[add_id]
	GROUP BY [addomains].[add_id], [addomains].[add_name]

