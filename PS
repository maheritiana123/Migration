CREATE PROCEDURE [dbo].[usp_delete_logs_GDPR]
@date AS DATETIME
AS
BEGIN	
	
	SELECT evc_name,COUNT(evc_name) as count FROM [dbo].[eventlog] WITH (NOLOCK) 
	INNER JOIN [dbo].[eventclasses] WITH (NOLOCK) ON evc_id = evt_class_id 
	GROUP BY evc_name
	ORDER BY evc_name
		
	DELETE FROM [dbo].[eventlog]
	FROM [dbo].[eventlog]
	INNER JOIN [dbo].[eventclasses] WITH (NOLOCK) ON evc_id = evt_class_id
	WHERE evt_timegenerated < DATEADD(YEAR,-10,@date)
	
	SELECT @@ROWCOUNT AS deleted_eventlogs
	
	SELECT evc_name,COUNT(evc_name) as count FROM [dbo].[eventlog] WITH (NOLOCK) 
	INNER JOIN [dbo].[eventclasses] WITH (NOLOCK) ON evc_id = evt_class_id 
