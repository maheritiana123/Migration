CREATE PROCEDURE [dbo].[SELECT_POSTSUPP]
	@DateD  nvarchar(10),      	-- date de début ou unique
	@DateF nvarchar(10)		-- date de fin
WITH RECOMPILE
AS
BEGIN
	declare @beginDate varchar(30);
	declare @endDate varchar(30);

