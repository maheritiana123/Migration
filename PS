CREATE PROCEDURE [dbo].[usp_select_adspaths]
	@adf_name [VARCHAR](MAX) = NULL,
	@ads_name [VARCHAR](MAX) = NULL,
	@add_name [VARCHAR](MAX) = NULL,
	@ims_name [VARCHAR](MAX) = NULL,
	@srv_ref [VARCHAR](MAX) = NULL,
	@srv_kit [VARCHAR](MAX) = NULL,
	@srv_av [VARCHAR](MAX) = NULL,
	@page INT,
	@nb_par_page INT,
	@col_order [VARCHAR](MAX),
	@order [VARCHAR](MAX)
AS
BEGIN

	SET NOCOUNT ON
	DECLARE @WHERE AS VARCHAR(MAX);
	IF (@adf_name IS NOT NULL)
	BEGIN
	SET @WHERE = [dbo].[fct_add_condition](@WHERE,'[adfederations].[adf_name] = ''' + @adf_name + '''','AND');
	END
	IF (@ads_name IS NOT NULL)
	BEGIN
	SET @WHERE = [dbo].[fct_add_condition](@WHERE,'[adsites].[ads_name] = ''' + @ads_name + '''','AND');
	END
	IF (@add_name IS NOT NULL)
	BEGIN
	SET @WHERE = [dbo].[fct_add_condition](@WHERE,'[addomains].[add_name] = ''' + @add_name + '''','AND');
	END
	IF (@ims_name IS NOT NULL)
	BEGIN
		IF (@ims_name = '--')
		BEGIN
			SET @WHERE = [dbo].[fct_add_condition](@WHERE,'NOT EXISTS (SELECT TOP 1 [adspaths_imssites].[adpims_id]
	                                          FROM [dbo].[adspaths_imssites] WITH (NOLOCK)
	                                          WHERE [adspaths_imssites].[adpims_adspath_id] = [adspaths].[adp_id])','AND');
		END
		ELSE
		BEGIN
			SET @WHERE = [dbo].[fct_add_condition](@WHERE,'''' + @ims_name + ''' IN (SELECT [imssites].[ims_name]
	                         FROM [dbo].[imssites] WITH (NOLOCK)
	                         INNER JOIN [dbo].[adspaths_imssites] WITH (NOLOCK) ON [adspaths_imssites].[adpims_imssite_id] = [imssites].[ims_id]
	                                                                           AND [adspaths_imssites].[adpims_adspath_id] = [adspaths].[adp_id])','AND');
		END
	END
	IF (@srv_ref IS NOT NULL)
	BEGIN
	SET @WHERE = [dbo].[fct_add_condition](@WHERE,'[servers_reference].[srv_fullname] LIKE ''%' + @srv_ref + '%''','AND');
	END
	IF (@srv_kit IS NOT NULL)
	BEGIN
	SET @WHERE = [dbo].[fct_add_condition](@WHERE,'[servers_kit].[srv_fullname] LIKE ''%' + @srv_kit + '%''','AND');
	END
	IF (@srv_av IS NOT NULL)
	BEGIN
	SET @WHERE = [dbo].[fct_add_condition](@WHERE,'[servers_antivirus].[srv_fullname] LIKE ''%' + @srv_av + '%''','AND');
	END

DECLARE @requete AS VARCHAR(MAX);

SET @requete = 
	'SELECT [adspaths].[adp_id],
	       [adspaths].[adp_bank],
	       [adspaths].[adp_federation],
	       [adspaths].[adp_scope],
	       [adspaths].[adp_slice],
	       [adspaths].[adp_mtosenv],
	       [adspaths].[adp_kit_server_id_private],
			[addomains].[add_name],
			[adfederations].[adf_name],
			[adsites].[ads_name],
	       (
	       	SELECT [imssites].[ims_id], [imssites].[ims_name]
	       	FROM [dbo].[imssites] WITH (NOLOCK)
	       	WHERE [imssites].[ims_id] IN (SELECT [adspaths_imssites].[adpims_imssite_id]
	       	                              FROM [dbo].[adspaths_imssites] WITH (NOLOCK)
	       	                              WHERE [adspaths_imssites].[adpims_adspath_id] = [adspaths].[adp_id])
			ORDER BY ims_name
	       	FOR XML RAW(''imssite''),ROOT(''imssites''), ELEMENTS XSINIL , TYPE
	       ) AS [imssites],
	       [servers_antivirus].[srv_id] AS [srv_id_av],
	       [servers_antivirus].[srv_hostname] AS [srv_hostname_av],
	       [servers_reference].[srv_id] AS [srv_id_ref],
	       [servers_reference].[srv_hostname] AS [srv_hostname_ref],
	       [servers_kit].[srv_id] AS [srv_id_kit],
	       [servers_kit].[srv_hostname] AS [srv_hostname_kit],
	       (
	       	SELECT COUNT(*)
	       	FROM [dbo].[workstations] WITH (NOLOCK)
	       	INNER JOIN [dbo].[adspaths_imssites] WITH (NOLOCK) ON ([adspaths_imssites].[adpims_id] = [workstations].[wks_adspath_imssite_id]
	       	                                                   AND [adspaths_imssites].[adpims_adspath_id] = [adspaths].[adp_id])
	       ) AS [number_of_workstations]
	FROM [dbo].[adspaths] WITH (NOLOCK)
	INNER JOIN [dbo].[addomains] WITH (NOLOCK) ON [addomains].[add_id] = [adspaths].[adp_addomain_id]
	INNER JOIN [dbo].[adfederations] WITH (NOLOCK) ON [adfederations].[adf_id] = [adspaths].[adp_adfederation_id]
	INNER JOIN [dbo].[adsites] WITH (NOLOCK) ON [adsites].[ads_id] = [adspaths].[adp_adsite_id]
	INNER JOIN [dbo].[servers] AS [servers_antivirus] WITH (NOLOCK) ON [servers_antivirus].[srv_id] = [adspaths].[adp_antivirus_server_id]
	INNER JOIN [dbo].[servers] AS [servers_reference] WITH (NOLOCK) ON [servers_reference].[srv_id] = [adspaths].[adp_reference_server_id]
	INNER JOIN [dbo].[servers] AS [servers_kit] WITH (NOLOCK) ON [servers_kit].[srv_id] = [adspaths].[adp_kit_server_id]'
	+ ' ' + ISNULL(@WHERE,'') + ' ';

EXEC [dbo].[USP_PAGINATION]
@page = @page,
@nb_par_page = @nb_par_page,
@col_order = @col_order,
@order = @order,
@requete_appelante = @requete;

END


