		[s2].[poste.popxeid], [s2].[sassrv.pxeid], [s2].[srv_imp.imp_id], [s2].[srv_imp.srv_id],
		[s2].[WPPPrinterName], [s2].[WPRPrinterName], [s2].[WPRPrinterName2], [s2].[WPRPrinterName3],
		[s2].[adspath.srv_av_id] + [s2].[adspath.srv_pxe_id] + [s2].[poste.pokitid] + [s2].[poste.popxeid] +
		[s2].[sassrv.pxeid] + [s2].[srv_imp.imp_id] + [s2].[srv_imp.srv_id] + [s2].[WPPPrinterName] +
		[s2].[WPRPrinterName] + [s2].[WPRPrinterName2] + [s2].[WPRPrinterName3] AS [references]
	FROM (
		SELECT [srvname], SUM([adspath.srv_av_id]) AS [adspath.srv_av_id], SUM([adspath.srv_pxe_id]) AS [adspath.srv_pxe_id],
			SUM ([poste.pokitid]) AS [poste.pokitid], SUM([poste.popxeid]) AS [poste.popxeid], SUM([sassrv.pxeid]) AS [sassrv.pxeid],
			SUM([srv_imp.imp_id]) AS [srv_imp.imp_id], SUM([srv_imp.srv_id]) AS [srv_imp.srv_id], SUM([WPPPrinterName]) AS [WPPPrinterName],
			SUM([WPRPrinterName]) AS [WPRPrinterName], SUM([WPRPrinterName2]) AS [WPRPrinterName2], SUM([WPRPrinterName3]) AS [WPRPrinterName3]
