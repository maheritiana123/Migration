CREATE PROCEDURE [dbo].[usp_select_self_events]
	@date nvarchar(8) -- date au format ISO 112 "yyyyMMdd", date Ã  partir de laquelle les Ã©vÃ©nements sont sÃ©lectionnÃ©s (date incluse)
AS
BEGIN
	
	DECLARE @date_tmp AS DATETIME
	SET @date_tmp = CONVERT(datetime,@date,112)

	-- RÃ©cupÃ©ration de la date de fin du mois
	DECLARE @date_end AS DATETIME
	SET @date_end = DATEADD(WEEK, 1, CONVERT(datetime,@date_tmp,112));	
	
	SELECT        evtlog.evt_workstation_name AS workstation, evtlog.evc_name, evtlog.evt_user, REPLACE(REPLACE(REPLACE(evtlog.evt_data, char(10), ''), char(13), ''), ';', '.') AS dataWritten, REPLACE(REPLACE(REPLACE(evtlog.evt_message, char(10), ''), char(13), ''), ';', '.') AS msg, CONVERT(varchar,evtlog.evt_timegenerated,120) AS timegenerated, CONVERT(varchar,evtlog.evt_timewritten, 120) AS timewritten, 
