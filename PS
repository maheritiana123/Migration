CREATE PROCEDURE [dbo].[usp_replace_ils]
	@oldbarcode as NVARCHAR(13),
	@newbarcode AS NVARCHAR(13),
	@ip AS NVARCHAR(15),
	@mat_productcode AS NVARCHAR(16),
	@user as NVARCHAR(8),
	@ils_duplex as [bit] 
AS
BEGIN
	SET NOCOUNT ON
	

	--on sélectionne les imprimantes ils déclarés sur ce barcode
	DECLARE @wks_id int 

	DECLARE the_cursor CURSOR FAST_FORWARD
	FOR SELECT ils_workstation_id
		FROM ilsprinters
		WHERE ils_barcode = @oldbarcode;

	OPEN the_cursor
	FETCH NEXT FROM the_cursor INTO @wks_id;

	WHILE @@FETCH_STATUS = 0
	BEGIN
		
		--insertion de l'évenement
		EXEC [dbo].[usp_insert_event] 
		@evc_name = 'MODIFICATION',
		@evt_data = NULL,
		@evt_message = N'The workstation has been modified.',
		@evt_source = 'WEBS',
		@evt_user = @user,
		@evt_justificatif = NULL,
		@wks_id = @wks_id;


		FETCH NEXT FROM the_cursor INTO @wks_id;
	END

	CLOSE the_cursor
	DEALLOCATE the_cursor



	UPDATE ilsprinters
	SET ils_ipaddress = @ip,
	ils_barcode = @newbarcode,
	ils_mat_productcode = @mat_productcode,
	ils_duplex = @ils_duplex
	WHERE ils_barcode = @oldbarcode;


	
	SELECT @@ROWCOUNT as [rowcount]
END
GO
