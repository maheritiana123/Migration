		popxeid,
		--CASE WHEN PoAdsImsId is not null THEN (select srv_pxe_id from adspath where Adspath_Id = (select Adspath_Id from ADSPATH_IMSSITE where Adspath_Ims_Id = PoAdsImsId)) ELSE popxeid END porefid,
		(select pvevaleur from PosteVarEnv where PVEVEId = (select veid from VarEnv where VENom = 'WPCodeFede') and PVEPoId = PoId) WPCodeFede,
		(select pvevaleur from PosteVarEnv where PVEVEId = (select veid from VarEnv where VENom = 'WPCodeBanque') and PVEPoId = PoId) WPCodeBanque,
		(select pvevaleur from PosteVarEnv where PVEVEId = (select veid from VarEnv where VENom = 'WPCodeCaisse') and PVEPoId = PoId) WPCodeCaisse,
		(select pvevaleur from PosteVarEnv where PVEVEId = (select veid from VarEnv where VENom = 'WPCodeBureau') and PVEPoId = PoId) WPCodeBureau,
		(select pvevaleur from PosteVarEnv where PVEVEId = (select veid from VarEnv where VENom = 'WPSiteIms') and PVEPoId = PoId) WPSiteIms,
		(select pvevaleur from PosteVarEnv where PVEVEId = (select veid from VarEnv where VENom = 'WPDomaine') and PVEPoId = PoId) WPDomaine,
		(select pvevaleur from PosteVarEnv where PVEVEId = (select veid from VarEnv where VENom = 'WPPuName') and PVEPoId = PoId) WPPuName,
		(select pvevaleur from PosteVarEnv where PVEVEId = (select veid from VarEnv where VENom = 'WPServTel') and PVEPoId = PoId) WPServTel,
		(select pvevaleur from PosteVarEnv where PVEVEId = (select veid from VarEnv where VENom = 'WPSMSSITECODE') and PVEPoId = PoId) WPSMSSITECODE,
		(select pvevaleur from PosteVarEnv where PVEVEId = (select veid from VarEnv where VENom = 'WPSrvAV') and PVEPoId = PoId) WPSrvAV
		from POSTE
		WHERE PoAdsImsId is null
	) t
	--where PoPxeId = porefid
	group by popxeid,WPCodeFede,WPCodeBanque,WPCodeCaisse,WPCodeBureau,WPSiteIms,WPDomaine,WPPuName,WPServTel,WPSMSSITECODE,WPSrvAV

