          ils_ipaddress,
          ils_mat_productcode
          FROM [dbo].[ilsprinters] WITH (NOLOCK) where ils_workstation_id = wks_id FOR XML RAW('ilsprinter'), ELEMENTS , TYPE)
          , (SELECT
          loc_id,
          CASE WHEN loc_default = 1 THEN 'True' ELSE 'False' END loc_default,
