CREATE FUNCTION [dbo].[fct_error_defaultprinters]()
RETURNS TABLE
AS
RETURN (
	SELECT * 
	FROM fct_enum_posteprinters() pp
	WHERE [pp].[poid] not in
		(
			SELECT [pp2].[poid]
			FROM fct_enum_posteprinters() pp2
			WHERE
				(	
					([pp2].[WPImpDef] = 'USB001' and [pp2].[WPImpUSB] = 'O')
					or
					([pp2].[WPImpDef] = 'LOCAL001' and [pp2].[WPImpLocal] = 'O')
					or
					([pp2].[WPImpDef] = [pp2].[WPPPrinterName] and [pp2].[WPImpPartage] = 'O')
					or
					([pp2].[WPImpDef] = [pp2].[WPRPrinterName] and [pp2].[WPImpReseau] = 'O')
					or
					([pp2].[WPImpDef] = [pp2].[WPRPrinterName2] and [pp2].[WPImpReseau2] = 'O')
					or
					([pp2].[WPImpDef] = [pp2].[WPRPrinterName3] and [pp2].[WPImpReseau3] = 'O')
					or
					([pp2].[WPImpDef] = 'N')
					or
					([pp2].[WPImpDef] = '')
				)
		)
)
