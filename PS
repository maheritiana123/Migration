CREATE PROCEDURE [dbo].[SP_SASLIST](
	@operation	NVARCHAR(3),	-- opération en cours ADD, MOD ou SUP
	@sasid		INT	,	-- id d'une liste existante
	@sasname	NVARCHAR(25),	-- nom d'une liste de serveur
	@rsasname	NVARCHAR(8),	-- nom de la ressource sas de la liste
	@srvlist	NVARCHAR(1000)	-- liste des id de serveurs de la liste
) AS
BEGIN
	DECLARE @NEWSASID as int
	DECLARE @SRVID as int
	DECLARE @RETURNVALUE INT
	
	SELECT @RETURNVALUE= 1
	
	BEGIN TRANSACTION
	
	IF (@operation = 'ADD')
	BEGIN
		-- table de référence de la liste
		INSERT INTO SASRESOURCE (SASLISTNAME, SASRESOURCENAME) VALUES (@sasname, @rsasname)
		SELECT @NEWSASID = @@IDENTITY
		
		-- maj de la table pivot
		INSERT INTO SASSRV
		SELECT @NEWSASID, itemvalue from dbo.PXE_SPLIT(@srvlist,',')
	END
	
	IF (@operation = 'MOD')
	BEGIN
		-- suppression table pivot
		DELETE FROM SASSRV WHERE SASID = @sasid
		-- maj de la table pivot avec les nouvelles entrées
		INSERT INTO SASSRV
		SELECT @sasid, itemvalue from dbo.PXE_SPLIT(@srvlist,',')
		-- maj éventuelle du nom
		UPDATE SASRESOURCE SET SASLISTNAME = @sasname WHERE SASRESID = @sasid
	END
	
	IF (@operation = 'SUP')
	BEGIN
		-- suppression table pivot
		DELETE FROM SASSRV WHERE SASID = @sasid
		-- suppression table ressource
		DELETE FROM SASRESOURCE WHERE SASRESID = @sasid
	END
	
	COMMIT
	
	-- Gestion des erreurs
	if (@@error <> 0)
	begin
		RAISERROR('Origine: SP_SASLIST - Erreur: %d', 18, 1, @@error)
		ROLLBACK TRAN
		SELECT @RETURNVALUE= -1
	end
	-- valeur de retour de la procédure stockée
	select @RETURNVALUE as result
END
GO
