CREATE FUNCTION [dbo].[fct_conversion_printers]()
RETURNS TABLE
AS
RETURN (
	SELECT 
	distinct '\\'+[np1].[srvname]+'\'+[np1].[printername] nom_long ,
	[np1].[srvid] srvid,
	'\\'+[np2].[srvname]+'\'+[np2].[printername] nom_long_new, 
	[np2].[srvid] srvid_new 
	FROM [dbo].[fct_enum_networkprinters]() np1
	INNER JOIN [dbo].[fct_enum_networkprinters]() np2  on 
		[np2].[srvid] is not null and 
		[np1].[srvname] like SUBSTRING([np2].[srvname], 1 , 8)+'%' and 
		[np1].[srvname] <> [np2].[srvname] and 
		[np1].[printername] = [np2].[printername]
	WHERE 
	[np1].[srvid] is null
)
