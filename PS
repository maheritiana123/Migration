CREATE PROCEDURE [dbo].[batch_validate_data_integrity]
AS
BEGIN
    SET NOCOUNT ON
    CREATE TABLE #ConstraintErrors (
        TableName NVARCHAR(128),
        ConstraintName NVARCHAR(128),
        ErrorDescription NVARCHAR(MAX)
    )
    
    INSERT INTO #ConstraintErrors
    EXEC('DBCC CHECKCONSTRAINTS WITH ALL_CONSTRAINTS')
    
    IF EXISTS (SELECT 1 FROM #ConstraintErrors)
    BEGIN
        SELECT * FROM #ConstraintErrors
        RAISERROR('Erreurs d''intégrité détectées', 16, 1)
    END
    
    DROP TABLE #ConstraintErrors
END
