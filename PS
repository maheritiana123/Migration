			  AND [pv1].[pvevaleur]	= 'O' AND LTRIM(RTRIM([pv2].[pvevaleur])) LIKE '\\%\%'
			GROUP BY SUBSTRING(SUBSTRING(LTRIM(RTRIM([pv2].[pvevaleur])), 3, LEN(LTRIM(RTRIM([pv2].[pvevaleur])))), 1, CHARINDEX('\', SUBSTRING(LTRIM(RTRIM([pv2].[pvevaleur])), 3, LEN(LTRIM(RTRIM([pv2].[pvevaleur]))))) - 1)

