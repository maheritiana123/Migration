CREATE FUNCTION [dbo].[fct_add_CONDITION] (@WHERE [VARCHAR](MAX),@CONDITION [VARCHAR](MAX),@OPERATOR [VARCHAR](MAX))
RETURNS VARCHAR(MAX)
AS
BEGIN

	IF @CONDITION IS NOT NULL
	BEGIN
		IF @WHERE IS NOT NULL SET @WHERE = @WHERE + ' ' + @OPERATOR + ' ' ELSE SET @WHERE = 'WHERE '
		SET @WHERE = @WHERE + '(' + @CONDITION + ')'
	END

	RETURN @WHERE

END
