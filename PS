CREATE PROCEDURE [dbo].[ADD_EVENT_CATEGORY]
	@CATEGORYNAME AS NVARCHAR(50),
	@CATEGORYTXT AS NVARCHAR(100),
	@CIDOUT INT OUTPUT
AS
BEGIN
	DECLARE	@IERREUR AS INT
	SET @IERREUR = 0;
	SET @CIDOUT = 0;

	IF EXISTS(SELECT CATEGORYID FROM EVENT_CATEGORIES WHERE CATEGORYNAME = @CATEGORYNAME)
	BEGIN
		SET @IERREUR = 1;
	END
	ELSE
	BEGIN
		IF LEN(@CATEGORYNAME) > 0
		BEGIN
			INSERT INTO EVENT_CATEGORIES(CATEGORYNAME, CATEGORYTXT) VALUES(@CATEGORYNAME, @CATEGORYTXT)
			SET @CIDOUT = (SELECT @@IDENTITY);
			SET @IERREUR = @IERREUR + @@ERROR;
		END
		ELSE
		BEGIN
			SET @IERREUR = 2;
		END
	END
	SET @IERREUR = @IERREUR + @@ERROR;
	IF(@IERREUR <> 0)
	BEGIN
		SET @CIDOUT = 0;
	END
END
GO
