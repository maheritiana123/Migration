CREATE PROCEDURE [dbo].[UPDATE_SRV]
	@NewRef nvarchar(100),     -- nouvelle référence du serveur
	@RETURNVALUE INT OUTPUT		-- retour de la SP
AS
BEGIN
	DECLARE @SRVNEWID as int

	BEGIN TRANSACTION

	-- L'id est renvoyé en sortie lorsque la proc est appelée à l'enregistrement d'un nouveau poste
	
	if exists (SELECT SRVID FROM SRV WHERE SRVNAME = @newRef)
	BEGIN
		SET @SRVNEWID = (SELECT SRVID FROM SRV WHERE SRVNAME = @newRef)
	END	
	ELSE
	BEGIN
		INSERT INTO SRV (SRVNAME) VALUES (@NewRef)
		SELECT @SRVNEWID = @@IDENTITY
	END

	COMMIT
	
	SET @RETURNVALUE= @SRVNEWID;
	
	-- Gestion des erreurs
	if (@@error <> 0)
	begin
		RAISERROR('Origine: SP UPDATE_SRV - Erreur: %d', 18, 1, @@error)
		ROLLBACK TRAN
		SET @RETURNVALUE= -1
	end
END
