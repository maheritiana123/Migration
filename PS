          FROM adspaths_imssites WITH (NOLOCK) where adpims_id = wks_adspath_imssite_id FOR XML RAW('adspathimssite'), ELEMENTS , TYPE)
		,(SELECT * FROM [dbo].[fct_get_technical_variables](@wks_id) ORDER BY [key] FOR XML RAW('variable') , ELEMENTS , ROOT('variables') , TYPE)
