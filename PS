CREATE  PROCEDURE [dbo].[UPDATE_POSTE] 
	@POADRESSEMAC AS NVARCHAR(12),
	@NEWADRESSEMAC AS NVARCHAR(12),
	@PONOM AS NVARCHAR(20),
	@POMODELE AS NVARCHAR(3), 
	@POETAT AS SMALLINT,
	@POPOSTBIOS AS SMALLINT,
	@POSRVKIT AS NVARCHAR(100),
	@POVERSION AS NVARCHAR(3),
	@POMATERIEL AS NVARCHAR(100),
	@POKIT AS NVARCHAR(100),
	@POSRVNAME AS NVARCHAR(100),
	@POBOOTDISK AS NVARCHAR(100),
	@POTER AS NVARCHAR(13),
	@POADSPATH AS INT,
	@POADSPATHTEXT AS NVARCHAR(100),
	@POSITEIMS AS VARCHAR(2),
	@HSTUSER AS NVARCHAR(8),
	@HSTYPE AS NVARCHAR(8),
	@HSTRKNOM AS NVARCHAR(20),
	@HSTRKADRESSEMAC AS NVARCHAR(12),
	@HSTRKTER AS NVARCHAR(10),
	@HSTRKIP AS NVARCHAR(20),
	@HYPERVISE AS BIT,
	@HSTHYPERVISE AS BIT,
	@HEARTBEAT AS DATETIME AS
BEGIN
	DECLARE @HSTID As INT
	DECLARE @PXEID AS INT
	DECLARE @KITID AS INT
	DECLARE @IERREUR AS INT
	DECLARE @POADIMSID AS INT
	DECLARE @ALREADYIN AS INT
	DECLARE @INPOID AS INT
	DECLARE @INSTATE AS SMALLINT
	DECLARE @INPONOM AS VARCHAR(20)
	
	SET @IERREUR = 0;
	SET @INPOID = 0;
	SET @INPONOM = '';
	SET @ALREADYIN = 0;
	SET @INSTATE = -1;
	
	
	SELECT @INPOID = POID, @INPONOM= PONOM, @INSTATE=POETAT FROM POSTE WHERE POADRESSEMAC = @POADRESSEMAC
	
	IF @INPOID = 0
	BEGIN
		UPDATE VERROUPOSTE
   		SET VePoCompteur = VePoCompteur + 1
	END
	
	IF @INPONOM = '' AND EXISTS(SELECT POID from POSTE WHERE PONOM = @PONOM)
	BEGIN
		SET @ALREADYIN = -1;
		SELECT @ALREADYIN as result;
	END
	
	IF @ALREADYIN = 0
	BEGIN
		BEGIN TRANSACTION UPDATE_SRV
		
		-- actualisation des rÚfÚrences serveurs kit et pxe
		
		EXEC [dbo].[UPDATE_SRV] @POSRVKIT, @KITID OUT
		EXEC [dbo].[UPDATE_SRV] @POSRVNAME, @PXEID OUT
		
		SET @IERREUR = @IERREUR + @@ERROR
		IF (@IERREUR = 0) COMMIT TRANSACTION UPDATE_SRV
		ELSE ROLLBACK TRANSACTION UPDATE_SRV
		
		IF @IERREUR = 0
		 BEGIN
		 	BEGIN TRANSACTION UPDATE_POSTE
		 	
		 	-- insertion des anciennes valeurs dans la table historique
		 	
		 	EXEC [dbo].[HSTINSERT] @POADRESSEMAC, @HSTUSER,@HSTYPE,@HSTRKNOM,@HSTRKADRESSEMAC,@HSTRKTER,@HSTRKIP
		 	
		 	IF @IERREUR = 0
			BEGIN
			
				IF @POADSPATH IS NOT NULL
				BEGIN
					-- CAS SIEGE
					SELECT @POADIMSID = (SELECT Adspath_Ims_Id FROM adspath_imssite as ads
					INNER JOIN ADSPATH as ad ON ad.Adspath_Id = ads.Adspath_Id
					INNER JOIN IMSSITE ON IMSID = ImsSite_Id
					WHERE ad.Adspath_Id = @POADSPATH
					AND
					IMSNAME = @POSITEIMS
					)
					
					UPDATE POSTE
					SET POADRESSEMAC = @NEWADRESSEMAC, 
					PONOM = UPPER(@PONOM),
					POMODELE = UPPER(@POMODELE),
					POETAT = @POETAT,
					POPOSTBIOS = @POPOSTBIOS,
					POKITID = @KITID,
					POVERSION = UPPER(@POVERSION),
					POMATERIEL = UPPER(@POMATERIEL),
					POKIT = UPPER(@POKIT),
					POBOOTDISK = UPPER(@POBOOTDISK),
					POTER = UPPER(@POTER),
					POADSIMSID = @POADIMSID,
					POSTATEDATE = (CASE WHEN @INSTATE <> @POETAT THEN getdate() ELSE POSTATEDATE END),
					POHYPERVISE = @HYPERVISE
					WHERE POADRESSEMAC = @POADRESSEMAC
				END
				ELSE
				BEGIN
					-- CAS AGENCE
					UPDATE POSTE
					SET POADRESSEMAC = @NEWADRESSEMAC, 
					PONOM = UPPER(@PONOM),
					POMODELE = UPPER(@POMODELE),
					POETAT = @POETAT,
					POPOSTBIOS = @POPOSTBIOS,
					POKITID = @KITID,
					POVERSION = UPPER(@POVERSION),
					POMATERIEL = UPPER(@POMATERIEL),
					POKIT = UPPER(@POKIT),
					POBOOTDISK = UPPER(@POBOOTDISK),
					POTER = UPPER(@POTER),
					POPXEID = @PXEID,
					POADSPATH = @POADSPATHTEXT,
					POSTATEDATE = (CASE WHEN @INSTATE <> @POETAT THEN getdate() ELSE POSTATEDATE END),
					POHYPERVISE = @HYPERVISE
					WHERE POADRESSEMAC = @POADRESSEMAC
				END	
			END
			
			SET @IERREUR = @IERREUR + @@ERROR
			IF (@IERREUR = 0) COMMIT TRANSACTION UPDATE_POSTE
			ELSE ROLLBACK TRANSACTION UPDATE_POSTE
			SELECT @IERREUR as result
		 END
	 END
END
