          (SELECT
          CASE WHEN wks_pcom_ses1_imssite_id is not NULL THEN (SELECT 'True' selected,1 as number,* from [dbo].[imssites] WITH (NOLOCK) where wks_pcom_ses1_imssite_id = ims_id FOR XML RAW('imssite'), ELEMENTS XSINIL , TYPE) ELSE (SELECT 1 as number,'False' as selected,'' as ims_name FOR XML RAW('imssite'), ELEMENTS XSINIL , TYPE) END
          ,CASE WHEN wks_pcom_ses2_imssite_id is not NULL THEN (SELECT 'True' selected,2 as number,* from [dbo].[imssites] WITH (NOLOCK) where wks_pcom_ses2_imssite_id = ims_id FOR XML RAW('imssite'), ELEMENTS XSINIL , TYPE) ELSE (SELECT 2 as number,'False' as selected,'' as ims_name FOR XML RAW('imssite'), ELEMENTS XSINIL , TYPE) END
