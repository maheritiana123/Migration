				0 AS [adspath.srv_av_id], 0 AS [adspath.srv_pxe_id], 0 AS [poste.pokitid], 0 AS [poste.popxeid], 0 AS [sassrv.pxeid],
				0 AS [srv_imp.imp_id], 0 AS [srv_imp.srv_id], 0 AS [WPPPrinterName], 0 AS [WPRPrinterName], COUNT(*) AS [WPRPrinterName2],
				0 AS [WPRPrinterName3]
			FROM [dbo].[postevarenv] AS [pv1] WITH (NOLOCK)
			LEFT JOIN [dbo].[postevarenv] AS [pv2] WITH (NOLOCK) ON (
