CREATE PROCEDURE [dbo].[ADDACTUVAR] @VARNAME AS NVARCHAR(100), @VARVALUE AS NVARCHAR(200), @POID AS INT , @PONAME AS NVARCHAR(20) AS
BEGIN
	DECLARE @VEID INT	-- identifiant de la variable
	DECLARE @ISPROTECTED BIT
	DECLARE @CURRENTVALUE NVARCHAR(200)
	DECLARE @RETURNVALUE INT
	
	SET @ISPROTECTED = 0;
	
	-- si id poste absent, recherche d'après le nom
	IF @POID = 0
	BEGIN
		SELECT @POID = poid from poste WITH (NOLOCK) where ponom = @PONAME
	END 

	-- la variable existe
	IF EXISTS (SELECT * FROM VARENV WITH (NOLOCK) WHERE VENOM = @VARNAME)
	BEGIN
		SELECT @VEID=VEId, @ISPROTECTED = ADVAR FROM VARENV WITH (NOLOCK) WHERE VENOM = @VARNAME
	END
	-- la variable n'existe pas
	ELSE
	BEGIN
		INSERT INTO VARENV (VENOM) VALUES (@VARNAME)
		IF @@ERROR <> 0 or @@ROWCOUNT = 0
		BEGIN
			SELECT @RETURNVALUE= 2
		END
		ELSE
		BEGIN
			SELECT @VEID=VEId FROM VARENV WITH (NOLOCK) WHERE VENOM =@VARNAME
		END
	END
	
	IF @VEID IS NULL
	BEGIN
		SELECT @RETURNVALUE= 3
	END
	ELSE
	BEGIN
		-- si c'est une variable protégée, on ne fait rien
		IF @ISPROTECTED = 1
		BEGIN
			SELECT @RETURNVALUE= 1
		END
		ELSE
		BEGIN
			-- selection de la variable pour le poste en question
			SELECT @CURRENTVALUE = PVEVALEUR FROM POSTEVARENV WITH (NOLOCK) WHERE PVEPOID = @POID AND PVEVEID = @VEID
		
			-- si l'ancienne valeur existe, suppression
			IF @CURRENTVALUE IS not NULL
			BEGIN
				DELETE POSTEVARENV WHERE PVEPOID = @POID AND PVEVEID= @VEID	
				IF @@ERROR <> 0 or @@ROWCOUNT = 0
				BEGIN
					SELECT @RETURNVALUE= 4
				END
			END
			IF @RETURNVALUE IS NULL
			BEGIN
				-- enregistrement de la nouvelle valeur
				SELECT @RETURNVALUE= 1
				INSERT INTO POSTEVARENV (PVEPoId,PVEVEId,PVEValeur) VALUES (@POID,@VEID,@VARVALUE)
				IF @@ERROR <> 0 or @@ROWCOUNT = 0
				BEGIN
					SELECT @RETURNVALUE= 5
				END
				
				-- gestion config snafarm si variable pftlsnafarm à 2 ou 3 libération des lus robolook du poste
				IF @VARNAME= 'PFTLSNAFARM' AND (@VARVALUE='2' or @VARVALUE='3')
				BEGIN
					DELETE FROM POSTEVARENV WHERE PVEPOID = @POID AND PVEVEID IN (select veid from varenv WITH (NOLOCK) where venom = 'WPLUEidcom' or venom = 'WPLUROBOLOOKA' or venom = 'WPLUROBOLOOKB' or venom = 'WPLUEidcom1' or venom = 'WPLUROBOLOOKA1' or venom = 'WPLUROBOLOOKB1' or venom = 'WPLUEidcom2' or venom = 'WPLUROBOLOOKA2' or venom = 'WPLUROBOLOOKB2')
				END
				
				-- gestion config snafarm si variable pftlsnafarm à 2  libération des lus pcom du poste
				IF @VARNAME= 'PFTLSNAFARMPCOM' AND (@VARVALUE='2')
				BEGIN
					DELETE FROM POSTEVARENV WHERE PVEPOID = @POID AND PVEVEID IN (select veid from varenv WITH (NOLOCK) where venom = 'WPLuPComA1' or venom = 'WPLuPComB1' or venom = 'WPLuPComA2' or venom = 'WPLuPComB2' or venom = 'WPLuPComA3' or venom = 'WPLuPComB3')
				END
			END
		END
	END
	-- valeur de retour de la procédure stockée
	select @RETURNVALUE as result
END

