				[wks_remote],
				[wks_setup_status],
				[wks_sndpscanner])
		SELECT
				[poste].[poid],
				NULLIF(LTRIM(RTRIM([pv1].[pvevaleur])), ''),
				NULLIF(LTRIM(RTRIM([pv2].[pvevaleur])), ''),
				NULLIF(LTRIM(RTRIM([pv3].[pvevaleur])), ''),
				NULLIF(LTRIM(RTRIM([pv4].[pvevaleur])), ''),
				[poste].[poadsimsid],
				CASE [pp].[WPImpDef] WHEN '' THEN 1 ELSE 0 END,
				CASE [poste].[poetat] WHEN 0 THEN 0 WHEN 10 THEN 1 WHEN 11 THEN 1 WHEN 12 THEN 2 WHEN 13 THEN 3 ELSE 9 END,
				NULLIF(LTRIM(RTRIM([poste].[pobootdisk])), ''),
