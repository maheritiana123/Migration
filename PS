  @PxeId as int,
  @PxeName as varchar(100),
  @AvId as int,
  @AvName as varchar(100),
  @SmsId as int,
  @SmsName as varchar(100),
  @SnaId as int,
  @SnaName as varchar(100),
  @CodeFedeId as int,
  @CodeFedeName as varchar(2),
  @CodeBankId as int,
  @CodeBankName as varchar(5),
  @CodeSmsId as int,
  @CodeSmsName as varchar(3)
  
AS
BEGIN
-- SET NOCOUNT ON added to prevent extra result sets from
-- interfering with SELECT statements.
SET NOCOUNT ON;

BEGIN TRANSACTION;

BEGIN TRY

IF NOT @FedeName IS NULL
BEGIN
  SELECT @FedeId = ad_federation_id FROM AD_FEDERATION WHERE ad_federation_name=@FedeName
  IF @FedeId IS NULL
  BEGIN
    INSERT INTO AD_FEDERATION (ad_federation_name) VALUES(@FedeName)
    SET @FedeId=@@IDENTITY
  END
END

IF NOT @SiteName IS NULL
BEGIN
  SELECT @SiteId = ad_site_id FROM AD_SITE_LOCATION WHERE ad_site_name=@SiteName
  IF @SiteId IS NULL
  BEGIN
    INSERT INTO AD_SITE_LOCATION (ad_site_name) VALUES(@SiteName)
    SET @SiteId=@@IDENTITY
  END
END

IF NOT @DomName IS NULL
BEGIN
  SELECT @DomId = ad_domain_id FROM AD_DOMAIN WHERE ad_domain_name_full=@DomName
  IF @DomId IS NULL
  BEGIN
    INSERT INTO AD_DOMAIN (ad_domain_name_full) VALUES(@DomName)
    SET @DomId=@@IDENTITY
  END
END

IF NOT @PrefixName IS NULL
BEGIN
  SELECT @PrefixId = prefix_id FROM PREFIX WHERE prefix_name=@PrefixName
  IF @PrefixId IS NULL
  BEGIN
    INSERT INTO PREFIX (prefix_name) VALUES(@PrefixName)
    SET @PrefixId=@@IDENTITY
  END
END

IF NOT @PerimeterName IS NULL
BEGIN
  SELECT @PerimeterId = Perimeter_id FROM PERIMETER WHERE Perimeter_name=@PerimeterName
  IF @PerimeterId IS NULL
  BEGIN
    INSERT INTO PERIMETER (Perimeter_name) VALUES(@PerimeterName)
    SET @PerimeterId=@@IDENTITY
  END
END

IF NOT @PxeName IS NULL
BEGIN
  SELECT @PxeId = srvid FROM SRV WHERE SrvName=@PxeName
  IF @PxeId IS NULL
  BEGIN
		INSERT INTO SRV(SRVNAME) VALUES(@PxeName);
		SET @PxeId = @@IDENTITY;
  END
END

IF NOT @AvName IS NULL
BEGIN
  SELECT @AvId = srvid FROM SRV WHERE srvname=@AvName
  IF @AvId IS NULL
  BEGIN
		INSERT INTO SRV(SRVNAME) VALUES(@AvName);
		SET @AvId = @@IDENTITY;
  END
END

IF NOT @SmsName IS NULL
BEGIN
  SELECT @SmsId = srvid FROM SRV WHERE srvname=@SmsName
  IF @SmsId IS NULL
  BEGIN
		INSERT INTO SRV(SRVNAME) VALUES(@SmsName);
		SET @SmsId = @@IDENTITY;
  END
END

IF NOT @SnaName IS NULL
BEGIN
  SELECT @SnaId = srvid FROM SRV WHERE srvname=@SnaName
  IF @SnaId IS NULL
  BEGIN
		INSERT INTO SRV(SRVNAME) VALUES(@SnaName);
		SET @SnaId = @@IDENTITY;
  END
END

IF NOT @CodeFedeName IS NULL
BEGIN
  SELECT @CodeFedeId = federation_id FROM FEDERATION WHERE federation_name=@CodeFedeName
  IF @CodeFedeId IS NULL
  BEGIN
    INSERT INTO FEDERATION (federation_name) VALUES(@CodeFedeName)
    SET @CodeFedeId=@@IDENTITY
  END
END

IF NOT @CodeBankName IS NULL
BEGIN
  SELECT @CodeBankId = bank_id FROM BANK WHERE bank_name=@CodeBankName
  IF @CodeBankId IS NULL
  BEGIN
    INSERT INTO BANK (bank_name) VALUES(@CodeBankName)
    SET @CodeBankId=@@IDENTITY
  END
END

IF NOT @CodeSmsName IS NULL
BEGIN
  SELECT @CodeSmsId = sms_site_id FROM SMSSITECODE WHERE sms_site_name=@CodeSmsName
  IF @CodeSmsId IS NULL
  BEGIN
    INSERT INTO SMSSITECODE (sms_site_name) VALUES(@CodeSmsName)
    SET @CodeSmsId=@@IDENTITY
  END
END

IF EXISTS(SELECT * FROM ADSPATH WHERE Adspath_Federation_Id=@FedeId AND Adspath_Site_Id=@SiteId AND Adspath_Domain_Id=@DomId) 
BEGIN
  -- probléme l'adspath
	IF @@TRANCOUNT > 0 ROLLBACK TRANSACTION;
	
	SELECT 0 AS RESULT;
END
ELSE
BEGIN
  INSERT INTO ADSPATH
   ([Adspath_Federation_Id]
   ,[Adspath_Site_Id]
   ,[Adspath_Domain_Id]
   ,[Prefix_Id]
   ,[Perimeter_Id]
   ,[Srv_Pxe_Id]
   ,[Srv_Av_Id]
   ,[Srv_Sms_Id]
   ,[Srv_Sna_Id]
   ,[Code_Fede_Id]
   ,[Code_Bank_Id]
   ,[Code_Sms_Id])
  VALUES
   (
   @FedeId,
   @SiteId,
   @DomId,
   @PrefixId,
   @PerimeterId,
   @PxeId,
   @AvId,
   @SMSId,
   @SNAId,
   @CodeFedeId,
   @CodeBankId,
   @CodeSmsId
   );

	COMMIT TRANSACTION;

	SELECT @@IDENTITY AS RESULT;
END

END TRY
BEGIN CATCH

	IF @@TRANCOUNT > 0 ROLLBACK TRANSACTION;

	SELECT ERROR_NUMBER() AS ErrorNumber,
	ERROR_SEVERITY() AS ErrorSeverity,
	ERROR_STATE() AS ErrorState,
	ERROR_PROCEDURE() AS ErrorProcedure,
	ERROR_LINE() AS ErrorLine,
	ERROR_MESSAGE() AS ErrorMessage;

END CATCH
END
