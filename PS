CREATE PROCEDURE [dbo].[usp_replace_networkprinter]
	@printserver_old AS NVARCHAR(MAX),
	@printserver_new AS NVARCHAR(MAX),
	@prn_name_old AS NVARCHAR(MAX),
	@prn_name_new AS NVARCHAR(MAX),
	@user AS NVARCHAR(MAX)
AS
BEGIN
	SET NOCOUNT ON
	DECLARE @prn_old_id [INT];
	SELECT @prn_old_id = prn_id 
	FROM [dbo].[printers] WITH (NOLOCK) 
	WHERE prn_name = @prn_name_old and prn_server_id = (SELECT srv_id FROM [dbo].[servers] WITH (NOLOCK) WHERE srv_fullname = @printserver_old);
	
	DECLARE @prn_new_id [INT];
	SELECT @prn_new_id = prn_id 
	FROM [dbo].[printers] WITH (NOLOCK) 
	WHERE prn_name = @prn_name_new and prn_server_id = (SELECT srv_id FROM [dbo].[servers] WITH (NOLOCK) WHERE srv_fullname = @printserver_new);

	DECLARE @id as VARCHAR(MAX)
	DECLARE impacted_workstations CURSOR FOR
	SELECT distinct net_workstation_id
	FROM [dbo].[networkprinters] WITH (NOLOCK)
	WHERE net_printer_id = @prn_old_id;

	OPEN impacted_workstations;

	FETCH NEXT FROM impacted_workstations
	INTO @id;

	DECLARE @evt_message as NVARCHAR(MAX)
	SET @evt_message = N'The ''\\' + ISNULL(@printserver_old,'') + '\' + ISNULL(@prn_name_old,'') + ''' network printer has been replaced by ''\\' + ISNULL(@printserver_new,'') + '\' + ISNULL(@prn_name_new,'') + '''.'

	WHILE @@FETCH_STATUS = 0
	BEGIN
	EXEC [dbo].[usp_insert_event2] @evc_name = 'MODIFICATION',@evt_data = NULL, @evt_message = @evt_message, @evt_source = 'WEB', @evt_user = @user, @wks_id = @id, @evt_justificatif = null;
	FETCH NEXT FROM impacted_workstations INTO @id;
	END

	CLOSE impacted_workstations;
	DEALLOCATE impacted_workstations;

	IF @prn_new_id IS NULL
	BEGIN
	INSERT INTO [dbo].[printers]
	(prn_name,prn_server_id)
