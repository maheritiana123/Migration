CREATE PROCEDURE [dbo].[INSERT_ADSPATH]
  @FedeId as int,
  @FedeName as varchar(15),
  @SiteId as int,
  @SiteName as varchar(30),
  @DomId as int,
  @DomName as varchar(128),
  @PrefixId as int,
  @PrefixName as varchar(4),
  @PerimeterId as int,
