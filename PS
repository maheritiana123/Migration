CREATE PROCEDURE [dbo].[usp_select_heartbeat_diseases]
	@timespan AS INT = NULL,
	@top AS INT,
	@wks_id AS BIGINT = NULL
AS
BEGIN

	SET NOCOUNT ON

	DECLARE @lbound AS VARCHAR(MAX)
	DECLARE @request AS VARCHAR(MAX)

	-- Calcul de la borne inférieure pour la recherche par paquet de @top lignes
	SELECT @lbound = CASE WHEN @wks_id IS NULL THEN 'NULL' ELSE CAST(@wks_id AS VARCHAR(MAX)) END

	-- Préparation de la requête
	IF (@timespan IS NULL)
	BEGIN

		SELECT @request =
			  'SELECT TOP ' + CAST(@top AS VARCHAR(MAX)) + ' [name_name], [wks_heartbeat], [wks_id], [wks_mat_barcode] '
			+ 'FROM [dbo].[workstations_view] WITH (NOLOCK) '
			+ 'WHERE [wks_hypervision] = 1 '
			+ 'AND [wks_heartbeat] IS NULL '
			+ 'AND ((' + @lbound + ' IS NULL) OR ([wks_id] > ' + @lbound + ')) '
			+ 'ORDER BY [wks_id] '

	END
	ELSE
	BEGIN

		SELECT @request =
			  'SELECT TOP ' + CAST(@top AS VARCHAR(MAX)) + ' [name_name], [wks_heartbeat], [wks_id], [wks_mat_barcode] '
			+ 'FROM [dbo].[workstations_view] WITH (NOLOCK) '
			+ 'WHERE [wks_hypervision] = 1 '
			+ 'AND ISNULL(DATEDIFF(mi, CONVERT(DATETIME, [wks_heartbeat], 120), GETDATE()), ' + CAST(@timespan AS VARCHAR(MAX)) + ' + 1) > ' + CAST(@timespan AS VARCHAR(MAX)) + ' '
			+ 'AND ((' + @lbound + ' IS NULL) OR ([wks_id] > ' + @lbound + ')) '
			+ 'ORDER BY [wks_id] '

	END

	-- Exécution
	EXEC(@request)

END
