CREATE PROCEDURE [dbo].[MIXED_POVAR](
	@clientMac      NVARCHAR(12),    -- adresse MAC du poste client
	@paramid	int
) AS
BEGIN
	DECLARE @TempTable TABLE(veid int,name varchar(20), value varchar(100));
	declare @siteims varchar(2);
	declare @srvpxe nvarchar(100);
	declare @srvav nvarchar(100);
	declare @srvsms nvarchar(100);
	declare @srvhis nvarchar(100);
	declare @codefede varchar(2);
	declare @codefedename varchar(4);
	declare @smssitecode nvarchar(3);
	declare @codebanque varchar(5);
	
	select @siteims=wpsiteims,
			@srvpxe=wpsrvpxename,
			@srvav=wpsrvav,
			@srvsms=wpsrvsms,
			@srvhis=wpsrvhis,
			@codefede=wpcodefede,
			@codefedename=wpcodefedename,
			@smssitecode=wpsmssitecode,
			@codebanque=wpcodebanque
	from POSTEVARVIEW 
	where poAdresseMac=@clientMac;

	insert into @TempTable(veid, name, value)
	(
		select veid, 'wpsiteims' as 'name', @siteims as 'value' from varenv
		where venom='wpsiteims' and @siteims is not NULL 
		union
		select veid, 'wpsrvpxe' as 'name', @srvpxe as 'value' from varenv
		where venom='wpsrvpxe' and @srvpxe is not NULL 
		union
		select veid, 'wpsrvsms' as 'name', @srvsms as 'value' from varenv
		where venom='wpsrvsms' and @srvsms is not NULL 
		union
		select veid, 'wpsrvav' as 'name', @srvav as 'value' from varenv
		where venom='wpsrvav' and @srvav is not NULL 
		union
		select veid, 'wpsrvhis' as 'name', @srvhis as 'value' from varenv
		where venom='wpsrvhis' and @srvhis is not NULL 
		union
		select veid, 'wpcodefede' as 'name', @codefede as 'value' from varenv
		where venom='wpcodefede' and @codefede is not NULL 
		union
		select veid, 'wppostefede' as 'name', @codefedename as 'value' from varenv
		where venom='wppostefede' and @codefedename is not NULL 
		union
		select veid, 'wpsmssitecode' as 'name', @smssitecode as 'value' from varenv
		where venom='wpsmssitecode' and @smssitecode is not NULL 
		union 
		select veid, 'wpcodebanque' as 'name', @codebanque as 'value' from varenv
		where venom='wpcodebanque' and @codebanque is not NULL 
	);

	IF @paramid IS NOT NULL
	BEGIN
		SELECT @paramid, veid, value FROM @TempTable 
		UNION
		SELECT @paramid, veid, pveValeur as 'value'
		FROM posteVarenv INNER JOIN poste ON pvepoid = poid
		INNER JOIN varenv ON pveVeId = veid
		WHERE poAdresseMac	= @clientMac
		AND ADVAR IS NULL
		AND pveveid NOT IN (SELECT veid FROM @TempTable);
	END
	ELSE
	BEGIN
		SELECT name, value FROM @TempTable 
		UNION
		SELECT venom as 'name', pveValeur as 'value'
		FROM posteVarenv INNER JOIN poste ON pvepoid = poid
		INNER JOIN varenv ON pveVeId = veId
		WHERE poAdresseMac	= @clientMac
		AND ADVAR IS NULL
		AND venom NOT IN (SELECT name FROM @TempTable);
	END
END
