CREATE FUNCTION [dbo].[fct_error_defaultprinters_reseau_large]()
RETURNS TABLE
AS
RETURN (
		SELECT * 
		FROM fct_enum_posteprinters() pp
		WHERE
			(
				[pp].[WPImpDef] like '\\%\%' and not
				(
					(
						SUBSTRING(SUBSTRING(WPImpDef, 3, LEN(WPImpDef)), CHARINDEX('\', SUBSTRING(WPImpDef, 3, LEN(WPImpDef))) + 1, LEN(WPImpDef)) 
						= 
						SUBSTRING(SUBSTRING(WPRPrinterName, 3, LEN(WPRPrinterName)), CHARINDEX('\', SUBSTRING(WPRPrinterName, 3, LEN(WPRPrinterName))) + 1, LEN(WPRPrinterName)) 
						and 
						WPImpReseau = 'O'
					)
					or 
					(
						SUBSTRING(SUBSTRING(WPImpDef, 3, LEN(WPImpDef)), CHARINDEX('\', SUBSTRING(WPImpDef, 3, LEN(WPImpDef))) + 1, LEN(WPImpDef)) 
						= 
						SUBSTRING(SUBSTRING(WPRPrinterName2, 3, LEN(WPRPrinterName2)), CHARINDEX('\', SUBSTRING(WPRPrinterName2, 3, LEN(WPRPrinterName2))) + 1, LEN(WPRPrinterName2)) 
						and 
						WPImpReseau2 = 'O'
					)
					or 
					(
						SUBSTRING(SUBSTRING(WPImpDef, 3, LEN(WPImpDef)), CHARINDEX('\', SUBSTRING(WPImpDef, 3, LEN(WPImpDef))) + 1, LEN(WPImpDef)) 
						= 
						SUBSTRING(SUBSTRING(WPRPrinterName3, 3, LEN(WPRPrinterName3)), CHARINDEX('\', SUBSTRING(WPRPrinterName3, 3, LEN(WPRPrinterName3))) + 1, LEN(WPRPrinterName3)) 
						and 
						WPImpReseau3 = 'O'
					)
					or 
					(
						SUBSTRING(SUBSTRING(WPImpDef, 3, LEN(WPImpDef)), CHARINDEX('\', SUBSTRING(WPImpDef, 3, LEN(WPImpDef))) + 1, LEN(WPImpDef)) 
						= 
						SUBSTRING(SUBSTRING(WPPPrinterName, 3, LEN(WPPPrinterName)), CHARINDEX('\', SUBSTRING(WPPPrinterName, 3, LEN(WPPPrinterName))) + 1, LEN(WPPPrinterName)) 
						and 
						WPImpPartage = 'O'
					)
				)
			)
)

