		INSERT INTO [dbo].[printservers]([prs_print_server_id], [prs_server_id])
			SELECT [imp_id], [srv_id]
			FROM [dbo].[srv_imp] WITH (NOLOCK)

		/**********************************************
	 	 * Alimentation de la table [networkprinters] *
	 	 **********************************************/

		INSERT INTO [dbo].[networkprinters]([net_printer_id], [net_workstation_id], [net_position], [net_default])
			SELECT [printers].[prn_id], [np].[poid],
			CASE [np].[WPPPrinterName] WHEN 1 THEN 0 ELSE
				CASE [np].[WPRPrinterName] WHEN 1 THEN 1 ELSE
					CASE [np].[WPRPrinterName2] WHEN 1 THEN 2 ELSE
						CASE [np].[WPRPrinterName3] WHEN 1 THEN 3
						END
					END
				END
			END,
			ISNULL([p].[net_default],0)
			FROM [dbo].[fct_enum_networkprinters]() AS [np]
			INNER JOIN [dbo].[printers] ON (
					[printers].[prn_name] = [np].[printername]
			  AND [printers].[prn_server_id] = [np].[srvid])
			LEFT JOIN (SELECT 1 net_default,poid,WPImpdef FROM [dbo].[fct_enum_posteprinters]()) p ON p.WPImpdef = '\\' + np.srvname + '\' + np.printername and np.poid = p.poid
			WHERE [np].[WPImpDef] = 0

		/******************************************
	 	 * Alimentation de la table [usbprinters] *
	 	 ******************************************/

	 	INSERT INTO [dbo].[usbprinters] ([usb_mat_productcode], [usb_duplex], [usb_workstation_id],[usb_default])
			SELECT LTRIM(RTRIM([pv2].[pvevaleur])),
				CASE NULLIF(LTRIM(RTRIM([pv3].[pvevaleur])), '') WHEN 'O' THEN 1 ELSE 0 END,
				[pv1].[pvepoid],ISNULL([usb_default],0)
			FROM [dbo].[postevarenv] AS [pv1] WITH (NOLOCK)
			LEFT JOIN [dbo].[postevarenv] AS [pv2] WITH (NOLOCK) ON (
					[pv2].[pvepoid] = [pv1].[pvepoid]
			  AND [pv2].[pveveid] = (SELECT [veid] FROM [dbo].[varenv] WITH (NOLOCK) WHERE [venom] = 'WPUPrinterTER'))
			LEFT JOIN [dbo].[postevarenv] AS [pv3] WITH (NOLOCK) ON (
					[pv3].[pvepoid] = [pv1].[pvepoid]
			  AND [pv3].[pveveid] = (SELECT [veid] FROM [dbo].[varenv] WITH (NOLOCK) WHERE [venom] = 'WPURectoVerso'))
			LEFT JOIN (SELECT 1 usb_default,poid,WPImpdef,WPImpUsb FROM fct_enum_posteprinters()) p ON p.WPImpdef like 'USB%' and p.WPImpUsb = 'O' and pv1.pvepoid = p.poid
			WHERE [pv1].[pveveid] = (SELECT [veid] FROM [dbo].[varenv] WITH (NOLOCK) WHERE [venom] = 'WPImpUsb')
			  AND [pv1].[pvevaleur]	= 'O'
			  AND NULLIF(LTRIM(RTRIM([pv2].[pvevaleur])), '') IS NOT NULL

		/************************************
	 	 * Alimentation de la table [views] *
	 	 ************************************/

		SET IDENTITY_INSERT [dbo].[views] ON
		INSERT INTO [dbo].[views] ([view_id], [view_name], [view_resource])
			SELECT [sasresid], [saslistname], [sasresourcename]
			FROM [dbo].[sasresource] WITH (NOLOCK)
		SET IDENTITY_INSERT [dbo].[views] OFF

		/********************************************
	 	 * Alimentation de la table [views_servers] *
	 	 ********************************************/

		INSERT INTO [dbo].[views_servers] ([viewsrv_server_id], [viewsrv_view_id])
			SELECT [pxeid], [sasid]
			FROM [dbo].[sassrv] WITH (NOLOCK)

		/***************************************************
	 	 * Alimentation de la table [workstations_options] *
	 	 ***************************************************/

		INSERT INTO [dbo].[workstations_options] ([wksopt_option_id], [wksopt_value], [wksopt_workstation_id])
			SELECT [pveveid], LTRIM(RTRIM([pvevaleur])), [pvepoid]
			FROM [dbo].[postevarenv] WITH (NOLOCK)
			INNER JOIN [dbo].[VarEnv] WITH (NOLOCK) ON PVEVEId = VEId
			INNER JOIN [dbo].[POSTE] WITH (NOLOCK) ON PVEPoId = PoId
			WHERE [pveveid] IN (SELECT [opt_id] FROM [dbo].[options] WITH (NOLOCK))
			  AND NULLIF(LTRIM(RTRIM([pvevaleur])), '') IS NOT NULL
			  AND 
			  (
				VENom not in ('WPCodeBanque', 'WPCodeBanqueComptable', 'WPCodeBureau', 'WPCodeBureauComptable', 'WPCodeCaisse', 'WPCodeCaisseComptable')
				OR
				(
					PoKit = 'AUTOMATE' AND VENom in ('WPCodeBanqueComptable', 'WPCodeBureau', 'WPCodeCaisse')
					OR
					PoKit = 'COMV' AND VENom in ('WPCodeCaisse', 'WPCodeBureau')
					OR
					PoKit = 'SECV' AND VENom in ('WPCodeBanqueComptable', 'WPCodeBureauComptable', 'WPCodeCaisseComptable')
				)
			  )

		/****************************
		 * COMMIT de la transaction *
	 	 ****************************/

		COMMIT TRANSACTION

	END TRY
	BEGIN CATCH

		DECLARE @ErrorMessage NVARCHAR(MAX)
		SELECT @ErrorMessage = ERROR_MESSAGE()

		/******************************
		 * ROLLBACK de la transaction *
	 	 ******************************/

		IF @@TRANCOUNT > 0 ROLLBACK TRANSACTION

		/**********************
		 * Levée d'une erreur *
	 	 **********************/

		RAISERROR(@ErrorMessage, 18, 1) WITH NOWAIT

	END CATCH

	SET NOCOUNT OFF

END


GO
