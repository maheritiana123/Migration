	END
	IF (@ads_name IS NOT NULL)
	BEGIN
	SET @WHERE = [dbo].[fct_add_condition](@WHERE,'(SELECT ads_name FROM [dbo].[adsites] WITH (NOLOCK) WHERE ads_id = (SELECT adp_adsite_id FROM [dbo].[adspaths] WITH (NOLOCK) WHERE adp_id = (SELECT adpims_adspath_id FROM [dbo].[adspaths_imssites] WITH (NOLOCK) WHERE adpims_id = wks_adspath_imssite_id))) = ''' + @ads_name + ''' ','AND');
