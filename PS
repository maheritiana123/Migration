CREATE PROCEDURE [dbo].[usp_update_workstation]
	@name AS NVARCHAR(16),
	@hypervision AS BIT = NULL,
	@bios_state AS INT = NULL,
	@setup_state AS INT = NULL,
	@wks_compromised AS BIT = NULL,
	@options AS XML = NULL,
	@server_kit AS NVARCHAR(MAX) = NULL,
	@wks_bootconfiguration_bios AS NVARCHAR(MAX) = NULL,
	@wks_bootconfiguration_os AS NVARCHAR(MAX) = NULL,
	@wks_accounting_bank AS NVARCHAR(MAX) = NULL,
	@wks_accounting_branch AS NVARCHAR(MAX) = NULL,
	@wks_accounting_office AS NVARCHAR(MAX) = NULL,
	@wks_accounting_pva AS NVARCHAR(MAX) = NULL,
	@wks_accounting_federation AS NVARCHAR(MAX) = NULL,
	@wks_bank AS NVARCHAR(MAX) = NULL,
	@wks_branch AS NVARCHAR(MAX) = NULL,
	@wks_office AS NVARCHAR(MAX) = NULL,
	@wks_federation AS NVARCHAR(MAX) = NULL,
	@wks_section AS NVARCHAR(MAX) = NULL,
	@wks_pva AS NVARCHAR(MAX) = NULL,
	
	@os as NVARCHAR(MAX) = NULL,
	@distribution as NVARCHAR(MAX) = NULL,
	@wks_step_data as NVARCHAR(MAX) = NULL,
	@imssite as NVARCHAR(MAX) = NULL,
	@applicant_name as NVARCHAR(MAX) = NULL,
	@kit_equipement as nvarchar(24)=NULL
AS
BEGIN
	
	DECLARE @calculate_wks_bank AS VARCHAR(5);
	DECLARE @calculate_wks_branch AS VARCHAR(5);
	DECLARE @calculate_wks_office AS VARCHAR(2);
	DECLARE @calculate_wks_federation AS VARCHAR(2);
	DECLARE @calculate_wks_section AS VARCHAR(7);
	DECLARE @calculate_wks_pva AS VARCHAR(3);



	SET NOCOUNT ON
	DECLARE @rowcount AS INT
	SET @rowcount = 0;
	
	DECLARE @wks_id AS INT
	SELECT @wks_id = wks_id FROM [dbo].[workstations] WITH (NOLOCK)
	LEFT JOIN dbo.names ON name_workstation_id = wks_id
	WHERE @name IS NOT NULL
	AND LEN(LTRIM(RTRIM(@name))) <> 0
	AND [name_name] = LTRIM(RTRIM(@name))
	
	IF (@wks_id IS NOT NULL)
	BEGIN
		BEGIN TRANSACTION
		DECLARE @wks_adspath_imssite_id AS INT;
		DECLARE @old_compromised AS BIT;
		SET @old_compromised = (SELECT wks_compromised FROM [dbo].[workstations_view] WITH (NOLOCK) WHERE wks_id = @wks_id)
		SELECT @wks_adspath_imssite_id = wks_adspath_imssite_id FROM workstations_view WHERE wks_id = @wks_id
		
		DECLARE @state_changed AS BIT;
		DECLARE @old_setup_status AS INT;
		SELECT @state_changed = 
			CASE WHEN (@setup_state <> wks_setup_status OR @bios_state <> wks_bios_status)
			THEN 1 ELSE 0 END,
			@old_setup_status = wks_setup_status
		FROM [dbo].[workstations]
		WHERE wks_id = @wks_id
		
		DECLARE @insert_event AS BIT
		SET @insert_event = 1
		IF
		NOT(
			EXISTS(
			SELECT * FROM [dbo].[workstations_view] WITH (NOLOCK) 
			WHERE 
			wks_id = @wks_id AND (
			wks_hypervision <> @hypervision
			OR
			wks_bios_status <> @bios_state
			OR
			wks_setup_status <> @setup_state
			OR
			wks_applicant_name <> @applicant_name
			OR
			wks_kit_server_id <> (select srv_id FROM [dbo].[servers] WITH (NOLOCK) WHERE srv_fullname = @server_kit)
			OR
			wks_bootconfiguration_bios <> @wks_bootconfiguration_bios
			OR
			wks_bootconfiguration_os <> @wks_bootconfiguration_os
			OR
			wks_accounting_bank <> @wks_accounting_bank
			OR
			wks_accounting_branch <> @wks_accounting_branch
			OR
			wks_accounting_office <> @wks_accounting_office
			OR
			wks_accounting_pva <> @wks_accounting_pva
			OR
			wks_accounting_federation <> @wks_accounting_federation
			OR
			wks_bank <> @wks_bank
			OR
			wks_branch <> @wks_branch
			OR
			wks_office <> @wks_office
			OR
			wks_federation <> @wks_federation
			OR
			wks_section <> @wks_section
			OR
			wks_pva <> @wks_pva
			OR
			wks_kit_operating_system <> @os
			OR
			wks_kit_distribution <> @distribution
			OR
			ims_name <> @imssite
			OR
			wks_kit_equipment<> @kit_equipement
			)
			)
			OR
			EXISTS(
			SELECT * FROM @options.nodes('/*/*') AS opts(opt)
			LEFT JOIN [dbo].[workstations_options_view] WITH (NOLOCK) ON opts.opt.value('local-name(.)','VARCHAR(MAX)') = opt_name
			WHERE
			wksopt_workstation_id = @wks_id AND wksopt_value <> opts.opt.value('.','VARCHAR(MAX)')
			)
		)
		BEGIN
			SET @insert_event = 0
		END
		
		IF (@insert_event = 1)
		BEGIN
			DECLARE @evc_name AS NVARCHAR(MAX)
			DECLARE @evt_message as NVARCHAR(MAX)
			SET @evc_name = 'MODIFICATION'
			SET @evt_message = N'The workstation has been modified.'
			IF (@state_changed = 1)
			BEGIN
				SET @evc_name = 'REKIT_STEP'
				IF (@setup_state = 1 AND @bios_state = 1)
					SET @evc_name = 'REKIT'
				IF (@setup_state = 9 AND @bios_state = 9 AND @old_setup_status = 6)
				BEGIN
					SET @evc_name = 'WORKSTATION_REPLACEMENT'
					SELECT @evt_message = N'The workstation "' + ISNULL(wks_tobereplaced_workstation_name,'') + '" has been replaced.' FROM [dbo].[workstations_view] WITH (NOLOCK) WHERE wks_id = @wks_id
				END
			END
			
			/*Si on passe dans l'Ã©tat compromis ou si on sort de l'Ã©tat compromis on ne met pas de log ici, dÃ©jÃ  une log dans le code CS pour mettre numÃ©ro SARA*/
			IF (@wks_compromised = 1)
			BEGIN
				IF (@old_compromised = 1)
				BEGIN
					EXEC [dbo].[usp_insert_event2] 
					@wks_id = @wks_id,
					@evc_name = @evc_name, 
					@evt_message = @evt_message, 
					@evt_source = 'WEBS', 
					@evt_user = 'WEBS',
					@evt_justificatif = null;
				END		
			END
			IF (@wks_compromised = 0 OR @wks_compromised IS NULL)
			BEGIN
				IF(@old_compromised = 0 OR @old_compromised IS NULL)
				BEGIN
				EXEC [dbo].[usp_insert_event2] 
					@wks_id = @wks_id,
					@evc_name = @evc_name, 
					@evt_message = @evt_message, 
					@evt_source = 'WEBS', 
					@evt_user = 'WEBS';
				END	
			END	
		END
		
		DECLARE @kit_srv_id AS INT;
		SELECT @kit_srv_id = srv_id FROM [dbo].[servers] WITH (NOLOCK) WHERE srv_fullname = @server_kit;
		
		--on met Ã  vide les variables organisationnels si ce sont dÃ©jÃ  les variables par dÃ©faut.
		SELECT 
		@calculate_wks_federation = CASE WHEN [adspaths_view].[adp_id] IS NOT NULL THEN adspaths_view.[adp_federation] ELSE [s3].srv_wkit_fede END ,
		@calculate_wks_bank = CASE WHEN [adspaths_view].[adp_id] IS NOT NULL THEN adspaths_view.[adp_bank] ELSE [s3].srv_wkit_codebanque END ,
		@calculate_wks_branch = [s3].srv_wkit_codecaisse  ,
		@calculate_wks_office = [s3].srv_wkit_codebureau ,
		@calculate_wks_pva = NULL,
		@calculate_wks_section = NULL
		FROM [dbo].[workstations] WITH (NOLOCK)
		LEFT JOIN [dbo].[adspaths_imssites] ON [adspaths_imssites].[adpims_id] = [workstations].[wks_adspath_imssite_id]
		LEFT JOIN [dbo].[adspaths_view] ON [adspaths_view].[adp_id] = [adspaths_imssites].[adpims_adspath_id]
		LEFT JOIN [dbo].[servers] [s3] ON [s3].[srv_id] = CASE WHEN [workstations].wks_adspath_imssite_id IS NULL THEN [workstations].[wks_pxe_server_id] ELSE [adspaths_view].adp_reference_server_id END
		WHERE wks_id = @wks_id;

	
		--si la valeur Ã  mettre est Ã©gale Ã  la valeur calculÃ©e, on vide. on met chaine vide pour rÃ©ellement mettre null dans workstations.
		IF (@wks_bank = @calculate_wks_bank )
		BEGIN
			select @wks_bank = '';
		END
		
		IF (@wks_branch = @calculate_wks_branch )
		BEGIN
			select @wks_branch = '';
		END
		
		IF (@wks_federation = @calculate_wks_federation )
		BEGIN
			select @wks_federation = '';
		END
		
		IF (@wks_section = @calculate_wks_section )
		BEGIN
			select @wks_section = '';
		END
		
		IF (@wks_office = @calculate_wks_office )
		BEGIN
			select @wks_office = '';
		END
		
		IF (@wks_pva = @calculate_wks_pva )
		BEGIN
			select @wks_pva = '';
		END
	
		
		UPDATE [dbo].[workstations]
		SET
		[wks_hypervision] = ISNULL(@hypervision,[wks_hypervision]),
		[wks_compromised] = ISNULL(@wks_compromised, [wks_compromised]),
		[wks_bios_status] = ISNULL(@bios_state, [wks_bios_status]),
		[wks_setup_status] = ISNULL(@setup_state, [wks_setup_status]),
		[wks_kit_server_id] = CASE WHEN (@state_changed = 1 AND (@setup_state = 9 OR @setup_state = 6) AND @bios_state = 9) OR @kit_srv_id = ISNULL(adp_kit_server_id,wks_pxe_server_id) 
								THEN NULL 
								ELSE ISNULL(@kit_srv_id, [wks_kit_server_id]) END,
		[wks_kit_operating_system] = CASE WHEN @os = '' 
								THEN NULL 
								ELSE ISNULL(@os,[wks_kit_operating_system]) END,
		[wks_kit_distribution] = CASE WHEN @distribution = '' 
								THEN NULL 
								ELSE ISNULL(@distribution,[wks_kit_distribution]) END,
		[wks_bootconfiguration_bios] = CASE WHEN @wks_bootconfiguration_bios = '' 
								THEN NULL 
								ELSE ISNULL(@wks_bootconfiguration_bios,[wks_bootconfiguration_bios]) END,
		[wks_bootconfiguration_os] = CASE WHEN @wks_bootconfiguration_os = '' 
								THEN NULL 
								ELSE ISNULL(@wks_bootconfiguration_os,[wks_bootconfiguration_os]) END,
		[wks_accounting_bank] = CASE WHEN @wks_accounting_bank = '' 
								THEN NULL 
								ELSE ISNULL(@wks_accounting_bank,[wks_accounting_bank]) END,
		[wks_accounting_branch] = CASE WHEN @wks_accounting_branch = '' 
								THEN NULL 
								ELSE ISNULL(@wks_accounting_branch,[wks_accounting_branch]) END,
		[wks_accounting_office] = CASE WHEN @wks_accounting_office = '' 
								THEN NULL 
								ELSE ISNULL(@wks_accounting_office,[wks_accounting_office]) END,
		[wks_accounting_pva] = CASE WHEN @wks_accounting_pva = '' 
								THEN NULL 
								ELSE ISNULL(@wks_accounting_pva,[wks_accounting_pva]) END,
		[wks_accounting_federation] = CASE WHEN @wks_accounting_federation = '' 
								THEN NULL 
								ELSE ISNULL(@wks_accounting_federation,[wks_accounting_federation]) END,
		[wks_bank] = CASE WHEN @wks_bank = '' 
								THEN NULL 
								ELSE ISNULL(@wks_bank,[wks_bank]) END,
		[wks_branch] = CASE WHEN @wks_branch = '' 
								THEN NULL 
								ELSE ISNULL(@wks_branch,[wks_branch]) END,
		[wks_office] = CASE WHEN @wks_office = '' 
								THEN NULL 
								ELSE ISNULL(@wks_office,[wks_office]) END,
		[wks_federation] = CASE WHEN @wks_federation = '' 
								THEN NULL 
								ELSE ISNULL(@wks_federation,[wks_federation]) END,
		[wks_section] = CASE WHEN @wks_section = '' 
								THEN NULL 
								ELSE ISNULL(@wks_section,[wks_section]) END,
		[wks_pva] = CASE WHEN @wks_pva = '' 
								THEN NULL 
								ELSE ISNULL(@wks_pva,[wks_pva]) END,
		[wks_tobereplaced_workstation_id] = CASE WHEN (@state_changed = 1 AND @setup_state = 9 AND @bios_state = 9)  
								THEN NULL 
								ELSE [wks_tobereplaced_workstation_id] END,
		[wks_step_data] = CASE WHEN (@state_changed = 1 AND @setup_state = 9 AND @bios_state = 9) OR @wks_step_data = '' 
								THEN NULL 
								ELSE ISNULL(@wks_step_data,[wks_step_data]) END,
		[wks_step_lastupdate] = CASE WHEN (@state_changed = 1 AND @setup_state = 9 AND @bios_state = 9) 
								THEN NULL 
								ELSE CASE WHEN @wks_step_data IS NULL 
									THEN [wks_step_lastupdate] 
									ELSE GETDATE() END END,
		[wks_applicant_name] = CASE WHEN @applicant_name = ''
								THEN NULL
								ELSE ISNULL(@applicant_name, [wks_applicant_name]) END,
		[wks_kit_equipment] = CASE WHEN @kit_equipement = ''
								THEN NULL
								ELSE ISNULL(@kit_equipement, [wks_kit_equipment]) END			
		FROM [dbo].[workstations]
		LEFT JOIN ([dbo].[adspaths_imssites] WITH (NOLOCK) INNER JOIN [dbo].[adspaths] WITH (NOLOCK) ON adpims_adspath_id = adp_id)
			ON wks_adspath_imssite_id = adpims_id
		WHERE wks_id = @wks_id
		SET @rowcount = @rowcount + @@ROWCOUNT;
		
		IF (EXISTS(
			SELECT * FROM [dbo].[adspaths_imssites] WITH (NOLOCK) 
			INNER JOIN [dbo].[imssites] on adpims_imssite_id = ims_id AND ims_name = @imssite
			AND adpims_adspath_id = (SELECT TOP 1 adpims_adspath_id FROM [dbo].[adspaths_imssites] WITH (NOLOCK) WHERE adpims_id = @wks_adspath_imssite_id)
			AND adpims_id <> @wks_adspath_imssite_id
			))
		BEGIN
			UPDATE [dbo].[workstations]
			SET wks_adspath_imssite_id = (SELECT TOP 1 adpims_id FROM [dbo].[adspaths_imssites] WITH (NOLOCK) WHERE 
				adpims_adspath_id = (SELECT adpims_adspath_id FROM [dbo].[adspaths_imssites] WITH (NOLOCK) WHERE adpims_id = @wks_adspath_imssite_id)
				AND adpims_imssite_id = (SELECT TOP 1 ims_id FROM [dbo].[imssites] WITH (NOLOCK) WHERE ims_name = @imssite))
			WHERE wks_id = @wks_id
			SET @rowcount = @rowcount + @@ROWCOUNT;
		END

		IF (@options IS NOT NULL)
		BEGIN
		
			DELETE FROM [dbo].[workstations_options]
			WHERE wksopt_workstation_id = @wks_id AND wksopt_option_id in (
			SELECT opt_id FROM [dbo].[options] WITH (NOLOCK)
			INNER JOIN @options.nodes('/*/*') AS opts(opt) ON opt_name = opts.opt.value('local-name(.)','VARCHAR(MAX)') AND opts.opt.value('.','VARCHAR(MAX)') = ''
			)
			SET @rowcount = @rowcount + @@ROWCOUNT;
		
			UPDATE [dbo].[workstations_options]
			SET wksopt_value = opts.opt.value('.','VARCHAR(MAX)')
			FROM [dbo].[workstations_options]
				CROSS APPLY @options.nodes('/*/*') AS opts(opt)
			INNER JOIN [dbo].[options] WITH (NOLOCK) on wksopt_option_id = opt_id and opt_name = opts.opt.value('local-name(.)','VARCHAR(MAX)') AND opts.opt.value('.','VARCHAR(MAX)') <> wksopt_value
			WHERE wksopt_workstation_id = @wks_id
			SET @rowcount = @rowcount + @@ROWCOUNT;

			INSERT INTO [dbo].[options]
			(opt_name)
			SELECT opts.opt.value('local-name(.)','VARCHAR(MAX)') FROM @options.nodes('/*/*') AS opts(opt)
			WHERE opts.opt.value('local-name(.)','VARCHAR(MAX)') NOT IN (SELECT opt_name FROM [dbo].[options] WITH (NOLOCK))

			INSERT INTO [dbo].[workstations_options]
			(wksopt_workstation_id,wksopt_option_id,wksopt_value)
			SELECT @wks_id,opt_id,opts.opt.value('.','VARCHAR(MAX)') FROM @options.nodes('/*/*') AS opts(opt)
			INNER JOIN [dbo].[options] on opt_name = opts.opt.value('local-name(.)','VARCHAR(MAX)')
			WHERE opts.opt.value('.','VARCHAR(MAX)') <> '' AND opt_id not in (SELECT wksopt_option_id FROM [dbo].[workstations_options] WITH (NOLOCK) WHERE wksopt_workstation_id = @wks_id)
			SET @rowcount = @rowcount + @@ROWCOUNT;

		END
			
		COMMIT TRANSACTION
	END
	
	EXEC [dbo].[usp_select_workstation] @name=@name, @macaddress=NULL, @mat_barcode=NULL,@uuid = NULL

END

