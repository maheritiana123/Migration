CREATE PROCEDURE [dbo].[usp_migrate_history]
	@date as DATETIME,
	@pas AS INT = 5000
AS
BEGIN

	BEGIN TRAN
	DELETE FROM dbo.eventlog
	where evt_timegenerated < @date
	COMMIT TRAN
	
	DECLARE @rowcount as int
	DECLARE @message AS NVARCHAR(MAX)
	
	INSERT INTO dbo.eventclasses
	(evc_name)
		SELECT distinct hst_type from dbo.HISTORY with (nolock)
		inner join workstations_view on name_name = HST_PONOM and wks_macaddress = HST_POADRESSEMAC
		where HST_TYPE not in (select evc_name from eventclasses with (nolock))
	union
		select EVENT_CATEGORIES.CATEGORYNAME from dbo.EVENT_CATEGORIES with (nolock)
		where EVENT_CATEGORIES.CATEGORYNAME not in (select evc_name from dbo.eventclasses with (nolock))

	DECLARE @i as int
	set @i = 1
	WHILE (1=1)
	BEGIN
	BEGIN TRAN
	BEGIN
	WITH HISTORY2 AS
	(
		SELECT *,
		ROW_NUMBER() OVER (ORDER BY hst_id) AS 'RowNumber'
		FROM HISTORY WITH (NOLOCK)
		INNER JOIN workstations_view with (nolock) ON name_name = hst_ponom and wks_macaddress = hst_poadressemac 
	) 
	INSERT INTO dbo.eventlog
	(evt_guid,evt_class_id,evt_reported,evt_message,evt_snapshot,evt_source,evt_timegenerated,evt_timewritten,evt_user,evt_workstation_macaddress,evt_workstation_name,evt_workstation_status)
	SELECT 
	wks_guid,
	(SELECT evc_id from dbo.eventclasses with (nolock) where evc_name = hst_type ) as evc_name,
	0 as evt_reported,
	N'The event has been migrated from the previous database.' as evt_message,
	(
	SELECT
	hst_ponom name_name,
	hst_poadressemac wks_macaddress,
	CASE hst_poetat WHEN 0 THEN 0 WHEN 10 THEN 1 WHEN 11 THEN 1 WHEN 12 THEN 2 WHEN 13 THEN 3 ELSE 9 END wks_bios_status,
	CASE hst_poetat WHEN 0 THEN 0 WHEN 1 THEN 1 WHEN 2 THEN 2 WHEN 3 THEN 3 WHEN 10 THEN 1 ELSE 9 END wks_setup_status,
	hst_pomateriel wks_kit_equipment,
	HST_POVersion wks_kit_distribution,
	HST_POKit wks_kit_model,
	HST_POBootDisk wks_bootconfiguration_os,
	HST_POTER wks_mat_barcode,
	HST_POHYPERVISE as wks_hypervision ,
	(SELECT srv_hostname,srv_domain FROM [dbo].[servers] WITH (NOLOCK) where srv_id = HKitId FOR XML RAW('server_kit'),ELEMENTS,TYPE) ,
	(SELECT srv_hostname,srv_domain FROM [dbo].[servers] WITH (NOLOCK) where srv_id = HPxeId FOR XML RAW('server_reference'),ELEMENTS,TYPE)
	,(SELECT venom [opt_name], hstvar_valeur [wksopt_value] FROM [dbo].[HSTPOVAR],[dbo].[varenv] WITH (NOLOCK) WHERE hstvar_veid = veid and hst_id = hstvar_hid FOR XML RAW('option') , ELEMENTS , ROOT('options') , TYPE)
	, (SELECT *
	,(SELECT *
	,(SELECT * from [dbo].[adfederations] WITH (NOLOCK) where adp_adfederation_id = adf_id FOR XML RAW('adfederation'),ELEMENTS XSINIL , TYPE)
	,(SELECT * from [dbo].[adsites] WITH (NOLOCK) where adp_adsite_id = ads_id FOR XML RAW('adsite'),ELEMENTS XSINIL , TYPE)
	,(SELECT * from [dbo].[addomains] WITH (NOLOCK) where adp_addomain_id = add_id FOR XML RAW('addomain'),ELEMENTS XSINIL , TYPE)
	,(SELECT * from [dbo].[servers] WITH (NOLOCK) where srv_id = adp_reference_server_id FOR XML RAW('srv_reference'),ELEMENTS XSINIL , TYPE)
	,(SELECT * from [dbo].[servers] WITH (NOLOCK) where srv_id = adp_antivirus_server_id FOR XML RAW('srv_antivirus'),ELEMENTS XSINIL , TYPE)
	FROM [dbo].[adspaths] WITH (NOLOCK) where adpims_adspath_id = adp_id FOR XML RAW('adspath'), ELEMENTS XSINIL , TYPE)
	,(SELECT * from [dbo].[imssites] WITH (NOLOCK) where ims_id = adpims_imssite_id FOR XML RAW('imssite'),ELEMENTS XSINIL , TYPE)
	from [dbo].[adspaths_imssites] WITH (NOLOCK) where adpims_id = wks_adspath_imssite_id FOR XML RAW('adspathimssite'), ELEMENTS , TYPE)
	FOR XML RAW('workstation'),ELEMENTS,TYPE),
	'WEB' evt_source,
	hst_date as evt_timegenerated,
	hst_date as evt_timewritten,
	hst_user evt_user,
	hst_poadressemac evt_workstation_macaddress,
	hst_ponom evt_workstation_name,
	CASE hst_poetat WHEN 0 THEN 0 WHEN 1 THEN 1 WHEN 2 THEN 2 WHEN 3 THEN 3 WHEN 10 THEN 1 ELSE 9 END wks_setup_status
	from HISTORY2 WITH (NOLOCK)
	WHERE RowNumber >= @i AND RowNumber < @i + @pas;
	
	set @rowcount = @@ROWCOUNT
	COMMIT TRAN
	if (@rowcount <> @pas)
	BEGIN
		BREAK
	END
	END
	SET @message = @i + @rowcount - 1;
	RAISERROR(@message, 1, 1) WITH NOWAIT
	SET @i = @i + @pas
	END

	set @i = 1
	WHILE (1=1)
	BEGIN
	BEGIN TRAN
	BEGIN
	WITH EVENTS2 AS
	(
		SELECT *,
		ROW_NUMBER() OVER (ORDER BY events.evtid) AS 'RowNumber'
		FROM dbo.events with (nolock)
		inner join dbo.workstations_view with (nolock) on wks_id = events.EVTPOID
		inner join dbo.EVENT_CATEGORIES with (nolock) on EVTCATEGORYID = EVENT_CATEGORIES.CATEGORYID
	) 
	insert into dbo.eventlog
	(evt_guid,evt_class_id,evt_source,evt_message,evt_user,evt_timegenerated,evt_timewritten,evt_snapshot,evt_workstation_macaddress,evt_workstation_name,evt_workstation_status)
	select 
	wks_guid as evt_guid,
	(select eventclasses.evc_id FROM dbo.eventclasses WITH (NOLOCK) WHERE evc_name = CATEGORYNAME) evt_class_id,
	EVTSOURCE as evt_source,
	ISNULL(CASE WHEN LEN(EVTTXT) > 0 THEN evttxt ELSE NULL END,N'The event has been migrated from the previous database.') as evt_message,
	CASE WHEN len(EVTUSR) > 0 THEN EVTUSR ELSE NULL END as evt_user,
	ISNULL(CASE WHEN EVTORIGINALEDATE > GETDATE() THEN EVTWRITTENDATE ELSE EVTORIGINALEDATE END,EVTWRITTENDATE) as evt_timegenerated,
	EVTWRITTENDATE as evt_timewritten,
	NULL as evt_snapshot,
	wks_macaddress as evt_workstation_macaddress,
	name_name as evt_workstation_name,
	wks_setup_status as evt_workstation_status
	from EVENTS2 
	WHERE RowNumber >= @i AND RowNumber < @i + @pas;
	
	set @rowcount = @@ROWCOUNT
	COMMIT TRAN
	if (@rowcount <> @pas)
	BEGIN
		BREAK
	END
	END
	SET @message = @i + @rowcount - 1;
	RAISERROR(@message, 1, 1) WITH NOWAIT
	SET @i = @i + @pas
	END

	DELETE FROM dbo.eventclasses
	where evc_id not in (select distinct evt_class_id from dbo.eventlog with (nolock))

END
GO
