				0 AS [poste.popxeid], 0 AS [sassrv.pxeid], 0 AS [srv_imp.imp_id], 0 AS [srv_imp.srv_id],
				0 AS [WPPPrinterName], 0 AS [WPRPrinterName], 0 AS [WPRPrinterName2], 0 AS [WPRPrinterName3]
			FROM [dbo].[srv] WITH (NOLOCK)

			UNION
			SELECT [srvname], COUNT(*) AS [adspath.srv_av_id], 0 AS [adspath.srv_pxe_id], 0 AS [poste.pokitid],
				0 AS [poste.popxeid], 0 AS [sassrv.pxeid], 0 AS [srv_imp.imp_id], 0 AS [srv_imp.srv_id],
				0 AS [WPPPrinterName], 0 AS [WPRPrinterName], 0 AS [WPRPrinterName2], 0 AS [WPRPrinterName3]
			FROM [dbo].[srv] WITH (NOLOCK)
			INNER JOIN [dbo].[adspath] WITH (NOLOCK) ON [adspath].[srv_av_id] = [srv].[srvid]
			GROUP BY [srvname]

			UNION
			SELECT [srvname], 0 AS [adspath.srv_av_id], COUNT(*) AS [adspath.srv_pxe_id], 0 AS [poste.pokitid],
				0 AS [poste.popxeid], 0 AS [sassrv.pxeid], 0 AS [srv_imp.imp_id], 0 AS [srv_imp.srv_id],
				0 AS [WPPPrinterName], 0 AS [WPRPrinterName], 0 AS [WPRPrinterName2], 0 AS [WPRPrinterName3]
			FROM [dbo].[srv] WITH (NOLOCK)
			INNER JOIN [dbo].[adspath] WITH (NOLOCK) ON [adspath].[srv_pxe_id] = [srv].[srvid]
