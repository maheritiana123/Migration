CREATE PROCEDURE [dbo].[usp_insert_networkprinter]
	@prn_name AS VARCHAR(128),
	@wks_id AS INT,
	@srv_id AS INT,
	@net_default AS BIT
	
AS
BEGIN

	DECLARE @prn_id AS INT;

	SET @prn_id = (SELECT prn_id FROM [dbo].[printers] WITH (NOLOCK) WHERE prn_name = @prn_name and prn_server_id = @srv_id);

	IF (@prn_id is null)
	BEGIN
	INSERT INTO [dbo].[printers]
	(prn_name,prn_server_id)
	VALUES
	(@prn_name,@srv_id);
	SET @prn_id = (SELECT @@IDENTITY prn_id);
	END

	IF NOT EXISTS(SELECT * FROM [dbo].[networkprinters_view] WITH (NOLOCK) WHERE net_workstation_id = @wks_id AND prn_server_id = @srv_id AND net_printer_id = @prn_id)
	BEGIN
		DECLARE @net_position as INT;
		SET @net_position = (select CASE WHEN max(net_position)>=0 then max(net_position)+1 else 0 end  from [dbo].[networkprinters_view] WITH (NOLOCK) where net_workstation_id = @wks_id)

		IF (EXISTS(SELECT * FROM [dbo].[networkprinters],usbprinters,localprinters WITH (NOLOCK) WHERE net_workstation_id = @wks_id AND loc_workstation_id = @wks_id AND usb_workstation_id = @wks_id AND net_default = '1' AND usb_default = '1' AND loc_default = '1'))
		BEGIN
			SET @net_default = '0';
		END

		IF (@net_default = '1')
		BEGIN
			UPDATE [dbo].[workstations]
			SET wks_auto_default_printer = '0'
			WHERE wks_id = @wks_id;
		END

		INSERT INTO [dbo].[networkprinters]
		(net_default,net_position,net_printer_id,net_workstation_id)
		VALUES
		(@net_default,@net_position,@prn_id,@wks_id);
	END
	
END
