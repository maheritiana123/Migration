CREATE FUNCTION [dbo].[fct_help_servers]()
RETURNS TABLE
AS
RETURN
(
		SELECT
		cs.*,
		es.srvid srvidnew,
		es.srvname srvnamenew
		FROM fct_check_servers() cs
		LEFT JOIN (
					SELECT es2.*
					FROM fct_enum_servers() es2 , (
						SELECT distinct [dbo].[fct_extract_hostname](es1.srvname) test,MAX(es1.[references]) max
						FROM fct_enum_servers() es1
						WHERE 
							es1.srvid is not null
							and
							[dbo].[fct_extract_domain](es1.srvname) <> ''
						GROUP BY [dbo].[fct_extract_hostname](es1.srvname)
					) es3
					WHERE 
						[dbo].[fct_extract_hostname](es2.srvname) = test
						and
						es3.[max] = es2.[references]
						and
						es2.srvid is not null
						and
						[dbo].[fct_extract_domain](es2.srvname) <> ''
				) es
			ON
			(
				[dbo].[fct_extract_hostname](es.srvname) = [dbo].[fct_extract_hostname](cs.srvname)
			)
)
