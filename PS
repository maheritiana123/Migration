CREATE PROCEDURE [dbo].[SELECT_POSTES]
	@criteria AS varchar(20),			-- Nom du champ utilisé comme critère de recherche
	@equal AS varchar(2),				-- Opérateur de comparaison : "" pour "like", "on" pour "="
	@value AS nvarchar(100),			-- Valeur du critère de recherche
	@server AS nvarchar(100), 			-- Serveur pour lequel s'effectue la recherche
	@orderBy AS varchar(20), 			-- Nom de la colonne sur laquelle s'effectue le tri
	@order AS varchar(4),				-- Ordre dans lequel s'effectue le tri
	@top AS integer,					-- Nombre d'enregistrements à retourner
	@resourcelist as varchar(8000),		-- filtre les retours par rapport à un type de serveur
	@postlist as varchar(8000)= '',		-- liste de noms de postes partiels ou complets
	@srvlist as varchar(8000) =''		-- liste de noms longs de serveurs

WITH RECOMPILE
AS
BEGIN
	DECLARE @order_expression VARCHAR(100);
	DECLARE @search_condition VARCHAR(8000);
	DECLARE @top_expression VARCHAR(50);

	SET @search_condition = '';

	-- --------------------------
	-- Calcul de la clause TOP --
	-- --------------------------
	SET @top_expression = '';
	IF @top >= 0 SET @top_expression = 'TOP ' + CONVERT(VARCHAR, @top);

	-- ----------------------------------------------------------------------
	-- Calcul de la clause WHERE : condition sur un des champs de la table --
	-- ----------------------------------------------------------------------

	IF @criteria <> ''
	BEGIN
		SET @search_condition = @search_condition + ' AND T1.' + @criteria;

		IF UPPER(@equal) = 'ON' SET @search_condition = @search_condition + ' = ' +  QUOTENAME(@value, '''');
		ELSE IF CHARINDEX(',', @value) > 0 SET @search_condition = @search_condition + ' IN (' +  @value + ')';
		ELSE SET @search_condition = @search_condition + ' LIKE ''%' +  REPLACE(@value, '''', '''''') + '%''';
	END

	-- ----------------------------------------------------------------------
	-- Calcul de la clause WHERE : condition supplémentaire sur le serveur --
	-- ----------------------------------------------------------------------

	IF @server <> '' SET @search_condition = @search_condition + ' AND T1.posrvname LIKE ''' + @server + '%''';

	-- ------------------------------------------------------------------------
	-- Récupération de la liste des postes passée en paramètres		 --
	-- ------------------------------------------------------------------------
	IF @postlist <> ''
	BEGIN
		DECLARE @sub_search_condition VARCHAR(8000);
		SET @sub_search_condition = '';

		-- contruction des like sur le nom
		DECLARE @criteria2 AS varchar(30);
		DECLARE poste_cursor CURSOR LOCAL FAST_FORWARD 
		FOR SELECT ItemValue FROM dbo.PXE_SPLIT(REPLACE(@postlist, ' ', ''),';') WHERE LEN(LTRIM(RTRIM(ItemValue))) <= 13 AND ItemValue <> '';
		
		OPEN poste_cursor;
		
		FETCH NEXT FROM poste_cursor INTO @criteria2;
		IF @@FETCH_STATUS = 0 SET @sub_search_condition = @sub_search_condition + 'T1.ponom LIKE ''' + @criteria2 + '%''';
		
		FETCH NEXT FROM poste_cursor INTO @criteria2;
		WHILE @@FETCH_STATUS = 0
		BEGIN
			SET @sub_search_condition = @sub_search_condition + ' OR T1.ponom LIKE ''' + @criteria2 + '%''';
			FETCH NEXT FROM poste_cursor INTO @criteria2;
		END
		CLOSE poste_cursor;

		IF @sub_search_condition <> '' SET @search_condition = @search_condition + ' AND (' + @sub_search_condition + ')';
	END

	-- ------------------------------------------------------------------------
	-- Récupération de la liste des serveurs passée en paramètres		 --
	-- ------------------------------------------------------------------------
	IF @srvlist <> '' SET @search_condition = @search_condition + ' AND T1.posrvname IN (SELECT * FROM dbo.PXE_SPLIT(''' + REPLACE(@srvlist, ' ', '') + ''','';''))';

	-- ------------------------------------------------------------------------
	-- Calcul de la clause WHERE : mise en place du filtre condition serveur --
	-- ------------------------------------------------------------------------
	IF @resourcelist <> ''
	BEGIN
		-- exploitation de filtre en tant que chaine de caractère pour cumuler plusieurs requêtes
		DECLARE @tPress TABLE(presssrv varchar(50));
		Insert into @tPress EXEC SELECT_PXESRVLIST @resourcelist;

		IF @@ROWCOUNT <> 0
		BEGIN
			SET @search_condition = @search_condition + ' AND T1.posrvname in (';

			DECLARE @criteria3 AS varchar(50);
			DECLARE press_cursor CURSOR LOCAL FAST_FORWARD 
			FOR SELECT presssrv FROM @tPress;

			OPEN press_cursor;
			FETCH NEXT FROM press_cursor INTO @criteria3;
			IF @@FETCH_STATUS = 0 SET @search_condition = @search_condition + '''' + @criteria3 + '''';

			FETCH NEXT FROM press_cursor INTO @criteria3;
			WHILE @@FETCH_STATUS = 0
			BEGIN
				SET @search_condition = @search_condition + ',''' + @criteria3 + '''';
				FETCH NEXT FROM press_cursor INTO @criteria3;
			END
			CLOSE press_cursor;
			SET @search_condition = @search_condition + ')';
		END
		ELSE
		BEGIN
			SET @search_condition = @search_condition + ' AND 1 = 0';	-- ON PURPOSE!!! condition impossible to met so that the request returns nothing
		END
	END


	-- ------------------
	-- Clause ORDER BY --
	-- ------------------
	SET @order_expression = '';
	IF @orderBy <> ''
	BEGIN
		SET @order_expression = ' ORDER BY ' + @orderBy;
		IF @order <> '' SET @order_expression = @order_expression + ' ' + @order;
	END

	-- --------------------------
	-- Execution de la requête --
	-- --------------------------
	EXEC( 'SELECT ' + @top_expression + ' T1.poid, T1.poadressemac, T1.ponom, T2.peintitule, T1.pomateriel, T1.posrvname, convert(char(10),T1.polastmaj,103) + '' '' + convert(char(10),T1.polastmaj,108) as lastmaj
	FROM posteview T1, posteetat T2 WITH (NOLOCK) WHERE T1.poetat = T2.peid' + @search_condition + @order_expression);

END -- End of procedure
GO
