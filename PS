CREATE PROCEDURE [dbo].[usp_goto]
	@name AS NVARCHAR(MAX) = NULL,
	@mat_barcode AS NVARCHAR(MAX) = NULL,
	@uuid AS NVARCHAR(MAX) = NULL,
	@macaddress AS NVARCHAR(MAX) = NULL,
	@wks_id AS INT = NULL
AS
BEGIN

	SET NOCOUNT ON
	
	IF (@name IS NOT NULL OR @mat_barcode IS NOT NULL OR @macaddress IS NOT NULL)
	BEGIN
		SELECT TOP 5000 wks_macaddress,wks_uuid, name_name, CASE WHEN ged_mat_barcode = @mat_barcode THEN ged_mat_barcode ELSE wks_mat_barcode END wks_mat_barcode
		FROM [dbo].[workstations] WITH (NOLOCK)
		LEFT JOIN [dbo].[names] WITH (NOLOCK) ON name_workstation_id = wks_id
		LEFT JOIN [dbo].[gedscanners] WITH (NOLOCK) ON ged_workstation_id = wks_id
		WHERE (
		(wks_macaddress = @macaddress)
		OR 
		(wks_uuid = @uuid)
		OR
		(name_name = @name)
		OR
		(wks_mat_barcode = @mat_barcode)
		OR
		(ged_mat_barcode = @mat_barcode)
		)
		AND (wks_id <> @wks_id OR @wks_id IS NULL)
	END
END
