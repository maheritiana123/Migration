CREATE FUNCTION [dbo].[fct_extract_domain](
	@fullname VARCHAR(MAX))
RETURNS VARCHAR(MAX)
AS
BEGIN
	RETURN LTRIM(RTRIM(SUBSTRING(@fullname, CASE CHARINDEX('.', @fullname) WHEN 0 THEN LEN(@fullname) + 1 ELSE CHARINDEX('.', @fullname) + 1 END, LEN(@fullname))))
END
