CREATE PROCEDURE [dbo].[usp_update_workstation_server_kit]
	@srv_kit_hostname AS VARCHAR(MAX),
	@wks_id AS INT,
	@evt_message [NVARCHAR](MAX),
	@evt_user [NVARCHAR](MAX)
	
AS
BEGIN

	EXEC [dbo].[usp_insert_event2]
	@wks_id = @wks_id,
	@evc_name = 'MODIFICATION_GLOBALE',
	@evt_message = @evt_message,
	@evt_source = 'WEB',
	@evt_user = @evt_user,
	@evt_justificatif = null;
	
	DECLARE @srv_kit_id AS INT;
	SELECT @srv_kit_id = srv_id FROM [dbo].[servers] WITH (NOLOCK) WHERE srv_hostname = @srv_kit_hostname;
	
	IF (@srv_kit_id IS NOT NULL)
	BEGIN
		UPDATE [dbo].[workstations]
		SET wks_kit_server_id = (
		SELECT 
		CASE WHEN wks_adspath_imssite_id IS NOT NULL 
		THEN CASE WHEN (SELECT adp_kit_server_id FROM [dbo].[adspaths] WITH (NOLOCK) WHERE adp_id in (SELECT adpims_adspath_id FROM [dbo].[adspaths_imssites] WITH (NOLOCK) WHERE adpims_id = wks_adspath_imssite_id)) = @srv_kit_id
			THEN NULL 
			ELSE @srv_kit_id END
		ELSE
			CASE WHEN (SELECT wks_kit_server_id FROM [dbo].[workstations_view] WITH (NOLOCK) WHERE wks_id = @wks_id) = @srv_kit_id 
			THEN NULL 
			ELSE @srv_kit_id END
		END
		)
		WHERE wks_id = @wks_id
	END
END
