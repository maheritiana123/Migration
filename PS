CREATE FUNCTION [dbo].[fct_add_conditions] (@WHERE [VARCHAR](MAX),@CONDITIONS [VARCHAR](MAX),@TEMPLATES [VARCHAR](MAX))
RETURNS VARCHAR(MAX)
AS
BEGIN
	IF (@TEMPLATES IS NOT NULL AND @CONDITIONS IS NOT NULL)
	BEGIN
		IF (@WHERE IS NULL)
		BEGIN
			SET @WHERE = 'WHERE';
		END
		SET @WHERE = @WHERE + '(';
		DECLARE @item AS VARCHAR(MAX);
		DECLARE items CURSOR FOR
		SELECT item FROM [dbo].[fct_split](@CONDITIONS,';')
		OPEN items;
		FETCH NEXT FROM items INTO @item;
		WHILE @@FETCH_STATUS = 0
		BEGIN
			DECLARE @template AS VARCHAR(MAX);
			DECLARE templates CURSOR FOR
			SELECT item FROM [dbo].[fct_split](@TEMPLATES,';')
			OPEN templates;
			FETCH NEXT FROM templates INTO @template;
			SET @WHERE = @WHERE + '(';
			WHILE @@FETCH_STATUS = 0
			BEGIN
			SET @WHERE = @WHERE + ' ' + REPLACE(@template,'@template',@item) + ' ';
			FETCH NEXT FROM templates INTO @template;
			IF (@@FETCH_STATUS = 0)
			BEGIN
				SET @WHERE = @WHERE + ' OR ';
			END
			END
			CLOSE templates;
			DEALLOCATE templates;
			SET @WHERE = @WHERE + ')';
		FETCH NEXT FROM items INTO @item;
		IF (@@FETCH_STATUS = 0)
		BEGIN
			SET @WHERE = @WHERE + ' AND ';
		END
		END
		CLOSE items;
		DEALLOCATE items;
		SET @WHERE = @WHERE + ')';
	END

	RETURN @WHERE;
END
GO
