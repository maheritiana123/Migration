CREATE PROCEDURE [dbo].[usp_select_next_eventlog]
	@evt_id AS INT
	
AS
BEGIN

	SET NOCOUNT ON
	
	DECLARE @guid AS NVARCHAR(MAX)
	DECLARE @evt_snapshot AS XML
	SELECT @guid = evt_guid,@evt_snapshot = evt_snapshot FROM [dbo].[eventlog] WITH (NOLOCK) WHERE evt_id = @evt_id;
	
		
	IF EXISTS(SELECT TOP 1 *,
		SUBSTRING(CONVERT(VARCHAR,evt_timegenerated, 120),0,11) evt_timegenerated_date,
		SUBSTRING(CONVERT(VARCHAR,evt_timegenerated, 120),12,LEN(evt_timegenerated)) evt_timegenerated_time,
		SUBSTRING(CONVERT(VARCHAR,evt_timewritten, 120),0,11) evt_timewritten_date,
		SUBSTRING(CONVERT(VARCHAR,evt_timewritten, 120),12,LEN(evt_timewritten)) evt_timewritten_time
		FROM [dbo].[eventlog_view] WITH (NOLOCK)
		WHERE
		evt_guid = @guid 
		AND
		evt_timewritten > (SELECT evt_timewritten FROM [dbo].[eventlog] WITH (NOLOCK) WHERE evt_id = @evt_id)
		AND ((evt_snapshot IS NULL AND @evt_snapshot IS NULL) OR (evt_snapshot IS NOT NULL AND @evt_snapshot IS NOT NULL))
		ORDER BY evt_timegenerated ASC)
	BEGIN
		SELECT TOP 1 *,
		SUBSTRING(CONVERT(VARCHAR,evt_timegenerated, 120),0,11) evt_timegenerated_date,
		SUBSTRING(CONVERT(VARCHAR,evt_timegenerated, 120),12,LEN(evt_timegenerated)) evt_timegenerated_time,
		SUBSTRING(CONVERT(VARCHAR,evt_timewritten, 120),0,11) evt_timewritten_date,
		SUBSTRING(CONVERT(VARCHAR,evt_timewritten, 120),12,LEN(evt_timewritten)) evt_timewritten_time
		FROM [dbo].[eventlog_view] WITH (NOLOCK)
		WHERE
		evt_guid = @guid 
		AND
		evt_timewritten > (SELECT evt_timewritten FROM [dbo].[eventlog] WITH (NOLOCK) WHERE evt_id = @evt_id)
		AND ((evt_snapshot IS NULL AND @evt_snapshot IS NULL) OR (evt_snapshot IS NOT NULL AND @evt_snapshot IS NOT NULL))
		ORDER BY evt_timegenerated ASC
	END
	ELSE
	BEGIN
		IF (EXISTS(SELECT wks_id FROM [dbo].[workstations] WITH (NOLOCK) WHERE wks_guid = @guid))
		BEGIN
			SELECT GETDATE() as evt_timegenerated,
			SUBSTRING(CONVERT(VARCHAR,GETDATE(), 120),0,11) evt_timegenerated_date,
			SUBSTRING(CONVERT(VARCHAR,GETDATE(), 120),12,LEN(GETDATE())) evt_timegenerated_time,
			CASE WHEN @evt_snapshot IS NOT NULL THEN [dbo].[fct_take_snapshot]((SELECT wks_id FROM [dbo].[workstations] WITH (NOLOCK) WHERE wks_guid = @guid)) ELSE NULL END evt_snapshot;
		END
	END
	
END
GO
