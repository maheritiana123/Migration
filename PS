CREATE PROCEDURE [dbo].[CLONE_POST]
	@clonemac varchar(12), @ponommodel varchar(13), @HSTUSER varchar(8), @IERREUR INT OUTPUT
WITH RECOMPILE
AS

BEGIN

DECLARE @CLONEID AS INT
DECLARE @FEDEPREFIX AS VARCHAR(5)
DECLARE @POCLONNUMBER AS VARCHAR(3)
DECLARE @EXCLUDELIST AS VARCHAR(50)
DECLARE @NUMBERVAR AS INT
DECLARE @cmd AS VARCHAR(250)
DECLARE @STEP AS INT
SET @IERREUR = 0;
SET @FEDEPREFIX = 0;
SET @STEP = 0;
SELECT @POCLONNUMBER = '';

-- id clone selon @mac = 
select @CLONEID = (select poid from poste where poadressemac = @clonemac);

BEGIN TRANSACTION CLONE_POST

-- trace histo pour certifier la modification
EXEC [dbo].[HSTINSERT] @clonemac, @HSTUSER,'MODIF','',@clonemac,'','';
SET @STEP = 1;
SET @IERREUR = @IERREUR + @@ERROR;

-- récup ad modèle + infos tech selon nom (ou  @mac ?)

select @FEDEPREFIX = (select prefix_name from poste a
inner join adspath_imssite b on b.adspath_ims_id = a.poadsimsid
inner join adspath c on c.adspath_id = b.adspath_id
inner join prefix d on d.prefix_id = c.prefix_id
where a.ponom = @ponommodel);

IF @IERREUR = 0 AND @FEDEPREFIX <> ''
BEGIN
	-- copie infos tech 
	update poste set pomodele = clone.pomodele,
	poetat = clone.poetat,
	popostbios = clone.popostbios,
	poversion = clone.poversion,
	pomateriel = clone.pomateriel,
	pokit = clone.pokit,
	pobootdisk = clone.pobootdisk,
	pokitid = clone.pokitid,
	popxeid = clone.popxeid,
	poadsimsid = clone.poadsimsid
	from
	(select pomodele, poetat, popostbios, poversion, pomateriel, pokit,pobootdisk, pokitid, popxeid, poadsimsid from poste where ponom = @ponommodel) as clone
	where poid = @CLONEID;
	SET @STEP = 2;
	SET @IERREUR = @IERREUR + @@ERROR;

	-- récup n° fédé libre
	IF @IERREUR = 0 
	BEGIN
		select @POCLONNUMBER = (SELECT TOP 1 [code] FROM [dbo].[BASE36] T1 WITH( NOLOCK ) WHERE NOT EXISTS( SELECT TOP 1 [PoNom] FROM [dbo].[POSTE] WITH( NOLOCK ) WHERE [PoNom] = (left(@ponommodel,1) + @FEDEPREFIX) + T1.[code] ) ORDER BY 1);
		SET @STEP = 3;
		SET @IERREUR = @IERREUR + @@ERROR;
		IF @POCLONNUMBER = ''
		BEGIN
			SET @IERREUR = @STEP;
		END
	END
	-- update numéro poste ( substring du nom original si config lite, burne ou autre)
	IF @IERREUR = 0
	BEGIN
		update poste set ponom= (upper(left(@ponommodel,5)) + @POCLONNUMBER) where poid = @CLONEID;
		SET @STEP = 4;
		SET @IERREUR = @IERREUR + @@ERROR;
	END

	-- liste exclusive de variables (avec numéro comptable)
	IF @IERREUR = 0
	BEGIN
		SELECT @EXCLUDELIST = '('+ convert(varchar(5),(select veid from varenv where venom = 'WPPostNumber')) + ',' + convert(varchar(5),(select veid from varenv where venom = 'WPTER')) + ',' + convert(varchar(5),(select veid from varenv where venom = 'WPNUMEROCOMPTABLE')) + ')';
		SET @IERREUR = @IERREUR + @@ERROR;
	END

	-- récup totale variables valorisées (?) ( -postnumber)

	select @cmd = ('SELECT ' + cast(@CLONEID as nvarchar(10)) +', veid, pveValeur
	FROM posteVarenv, varenv, poste
	WHERE pveVeId = veId
	AND pvevaleur <> ''''
	AND pvePoId = poId
	AND ponom = ''' + @ponommodel +
	''' AND VeId not in '+ @EXCLUDELIST +'');

	-- copie paramètres standards valorisés
	IF @IERREUR = 0
	BEGIN
		insert into postevarenv(pvepoid, pveveid, pvevaleur) exec(@cmd);
		SET @STEP = 5;
		SET @IERREUR = @IERREUR + @@ERROR;
	END
	-- insertion spécifique du nombre liée à la numérotation
	IF @IERREUR = 0
	BEGIN
		select @NUMBERVAR = (select veid from varenv where venom = 'WPPostNumber');
		insert into postevarenv(pvepoid, pveveid, pvevaleur) values(@CLONEID,@NUMBERVAR,@POCLONNUMBER);
		SET @STEP = 6;
		SET @IERREUR = @IERREUR + @@ERROR;
	END
END
-- gestion des cas d'erreur
SET @IERREUR = @IERREUR + @@ERROR
	IF (@IERREUR = 0)
	BEGIN
		COMMIT TRANSACTION CLONE_POST;
		SET @STEP = 0;
	END
	ELSE 
	BEGIN
		ROLLBACK TRANSACTION CLONE_POST;
	END 
-- sortie
SELECT @STEP as step;

END
GO
