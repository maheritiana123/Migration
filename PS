CREATE PROCEDURE [dbo].[usp_select_printservers]
	@srv_id AS VARCHAR(MAX),
	@list_views AS XML = NULL,
	@srv AS VARCHAR(MAX) = NULL
	
AS
BEGIN

	SET NOCOUNT ON

	DECLARE @declarations_variables AS VARCHAR(MAX);
	SET @declarations_variables = '
	DECLARE @list_views AS XML;
	SET @list_views = '''+CAST(@list_views AS VARCHAR(MAX))+''';';

	DECLARE @WHERE AS VARCHAR(MAX);
	
	IF (@list_views IS NOT NULL AND @list_views.value('count(/views/view)','INT') > 0)
	BEGIN
	SET @WHERE = [dbo].[fct_add_condition](@WHERE,'srv_id in (SELECT distinct viewsrv_server_id from views_servers inner join views ON view_id = viewsrv_view_id WHERE view_name in (SELECT t2.toto.value(''.'',''VARCHAR(MAX)'') FROM @list_views.nodes(''views/view'') as t2(toto)) GROUP BY viewsrv_server_id HAVING count(viewsrv_view_id) = @list_views.value(''count(views/view)'',''INT''))','AND');
	END
	IF (@srv IS NOT NULL)
	BEGIN
	SET @WHERE = [dbo].[fct_add_condition](@WHERE,'srv_hostname = ''' + @srv + '''','AND');
	END
	
	DECLARE @COUNT AS VARCHAR(MAX);
	IF (@srv_id <> '%%')
	BEGIN
		SET @WHERE = [dbo].[fct_add_condition](@WHERE,'prs_server_id = ' + @srv_id + '','AND');
		SET @COUNT = ',(SELECT count(distinct net_workstation_id) FROM [dbo].[networkprinters_view] WITH (NOLOCK) INNER JOIN [dbo].[workstations_view] ON wks_id = net_workstation_id WHERE prn_server_id = srv_id and wks_ref_server_id = '+@srv_id+') as nb_postes_printserver';
	END
	ELSE
	BEGIN
		SET @COUNT = ',(SELECT count(distinct net_workstation_id) FROM [dbo].[networkprinters_view] WITH (NOLOCK) WHERE prn_server_id = srv_id) as nb_postes_printserver';
	END
	
	EXEC (
		@declarations_variables + '
	SELECT
	DISTINCT
	srv_id,
	srv_hostname,
	srv_domain'
	+ ' ' + @COUNT + ' ' +
	'FROM [dbo].[servers] WITH (NOLOCK)
	INNER JOIN printservers ON srv_id = prs_print_server_id'
	+ ' ' + @WHERE + ' ' +
	'ORDER BY srv_hostname'
	);
END
		  
