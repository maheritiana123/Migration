CREATE PROCEDURE [dbo].[usp_rename_workstation_option]
	@varenv_old AS VARCHAR(MAX),
	@varenv_new AS VARCHAR(MAX),
	@wks_id AS INT,
	@evt_user [NVARCHAR](MAX)
	
AS
BEGIN
	DECLARE @evt_message AS NVARCHAR(MAX)
	SET @evt_message = N'The ''' + ISNULL(@varenv_old,'') + ''' environment variable has been renamed to ''' + ISNULL(@varenv_new,'') + '''.'

	EXEC [dbo].[usp_insert_event2]
	@wks_id = @wks_id,
	@evc_name = 'MODIFICATION_GLOBALE',
	@evt_message = @evt_message,
	@evt_source = 'WEB',
	@evt_user = @evt_user,
	@evt_justificatif = null;

	IF (NOT EXISTS(SELECT * FROM [dbo].[options] WITH (NOLOCK) WHERE opt_name = @varenv_new))
	BEGIN
	INSERT INTO [dbo].[options]
	(opt_name)
	VALUES(@varenv_new);
	END

	UPDATE [dbo].[workstations_options]
	SET wksopt_option_id = (SELECT opt_id FROM [dbo].[options] WHERE opt_name = @varenv_new)
	WHERE wksopt_workstation_id = @wks_id and wksopt_option_id = (SELECT opt_id FROM [dbo].[options] WITH (NOLOCK) WHERE opt_name = @varenv_old) and NOT EXISTS(SELECT * FROM [dbo].[workstations_options] WITH (NOLOCK) WHERE wksopt_workstation_id = @wks_id AND wksopt_option_id = (SELECT opt_id FROM [dbo].[options] WITH (NOLOCK) WHERE opt_name = @varenv_new));

	DELETE FROM [dbo].[workstations_options]
	WHERE wksopt_workstation_id = @wks_id and wksopt_option_id = (SELECT opt_id FROM [dbo].[options] WITH (NOLOCK) WHERE opt_name = @varenv_old);
	
END
