CREATE FUNCTION [dbo].[fct_check_localprinters]()
RETURNS TABLE
AS
RETURN
(
		SELECT 
			LTRIM(RTRIM([pv2].[pvevaleur])) as loc_driver,
			CASE NULLIF(LTRIM(RTRIM([pv3].[pvevaleur])), '') WHEN 'O' THEN 1 ELSE 0 END as loc_duplex,
			[pv1].[pvepoid] as loc_workstation_id,
			ISNULL(loc_default,0) as loc_default
		FROM [dbo].[postevarenv] AS [pv1] WITH (NOLOCK)
		LEFT JOIN [dbo].[postevarenv] AS [pv2] WITH (NOLOCK) ON (
				[pv2].[pvepoid] = [pv1].[pvepoid]
		  AND [pv2].[pveveid] = (SELECT [veid] FROM [dbo].[varenv] WITH (NOLOCK) WHERE [venom] = 'WPLPrinterTER'))
		LEFT JOIN [dbo].[postevarenv] AS [pv3] WITH (NOLOCK) ON (
				[pv3].[pvepoid] = [pv1].[pvepoid]
		  AND [pv3].[pveveid] = (SELECT [veid] FROM [dbo].[varenv] WITH (NOLOCK) WHERE [venom] = 'WPLRectoVerso'))
		LEFT JOIN (SELECT 1 loc_default,poid,WPImpdef,WPImpLocal FROM fct_enum_posteprinters()) p ON p.WPImpdef like 'LOCAL%' and p.WPImpLocal = 'O' and pv1.pvepoid = p.poid
		WHERE [pv1].[pveveid] = (SELECT [veid] FROM [dbo].[varenv] WITH (NOLOCK) WHERE [venom] = 'WPImpLocal')
		  AND [pv1].[pvevaleur]	= 'O'
		  AND NULLIF(LTRIM(RTRIM([pv2].[pvevaleur])), '') IS NOT NULL
			AND NOT (
				((len(LTRIM(RTRIM([pv2].[pvevaleur])))>(0)))
			)
)
