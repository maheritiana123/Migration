CREATE PROCEDURE [dbo].[INSERT_POSTE]
	@MACAddress nvarchar(12),     -- Adresse MAC du poste client.
	@ServerFullName nvarchar(100)     -- Nom complet du serveur PXE
AS
BEGIN
	SET NOCOUNT ON
	DECLARE @status SMALLINT
	DECLARE @lastUpdated INT
	DECLARE @postname varchar(13)
	DECLARE @poid INT
	DECLARE @SRVID AS INT
	DECLARE @pokit varchar(100)
	DECLARE @pomateriel varchar(100)
	DECLARE @podomaine varchar(100)
	DECLARE @poadspath varchar(100)
	DECLARE @posrvkit  varchar(100)
	DECLARE @poversion varchar(3)
	DECLARE @pomodele  varchar(3)
	DECLARE @PoBootDisk varchar(100)
		
	BEGIN TRANSACTION

	SELECT @lastUpdated = DATEDIFF(SS, POLASTMAJ, GETDATE()),
	       @status = POETAT,
	       @postname=PONOM,
	       @poid=POID,
	       @pokit=lower(POKIT),
	       @pomateriel=POMATERIEL,
	       @podomaine=PODOMAINE,
	       @poadspath=POADSPATH,
	       @posrvkit= posrvkit,
	       @poversion=lower(POVERSION),
	       @pomodele=POMODELE,
	       @PoBootDisk = POBOOTDISK
	       
	  FROM POSTEVIEW
	 WHERE POADRESSEMAC = @MACAddress
	 
	 -- vérification oiginale

	IF (@@rowcount = 0)
	BEGIN
		-- rien pose du verrou le tps de la transaction
		UPDATE VERROUPOSTE
		   SET VePoCompteur = VePoCompteur + 1

		-- réverification pour être sûr qu'il n'y a tjrs rien entre le select et la pose du verrou
		-- select complet des infos si il y a eu un enregistrement autre pour correspondre avec le renvoi final.
		
		SELECT @lastUpdated = DATEDIFF(SS, POLASTMAJ, GETDATE()),
		       @status = POETAT,
		       @postname=PONOM,
		       @poid=POID,
		       @pokit=lower(POKIT),
		       @pomateriel=POMATERIEL,
		       @podomaine=PODOMAINE,
		       @poadspath=POADSPATH,
		       @posrvkit= posrvkit,
		       @poversion=lower(POVERSION),
		       @pomodele=POMODELE,
		       @PoBootDisk = POBOOTDISK
		       
		  FROM POSTEVIEW
		 WHERE POADRESSEMAC = @MACAddress

		IF (@@rowcount = 0)
		BEGIN
		
			-- appel de la gestion du serveur
			EXEC [dbo].[UPDATE_SRV] @ServerFullName, @SRVID OUT
			
			INSERT INTO POSTE (POADRESSEMAC, POETAT, POPOSTBIOS, POKITID, POPXEID)
			VALUES (@MACAddress, 0, 4, @SRVID, @SRVID)
					
			SELECT @lastUpdated = 0
			SELECT @status = -1
			
			-- si -1 proposition du menu est passage à l'état 0 (voir dll de boot)
			
			SELECT @postname = NULL
			SELECT @poid = (SELECT POID FROM POSTEVIEW WHERE POADRESSEMAC = @MACAddress)
			SELECT @pokit = NULL
			SELECT @pomateriel = NULL
			SELECT @podomaine = NULL
			SELECT @poadspath = NULL
			SELECT @posrvkit = NULL
			SELECT @poversion = NULL
			SELECT @pomodele = 'WKS'
			SELECT @PoBootDisk = NULL
		END
	END
	
	COMMIT

	SELECT @lastUpdated AS lastUpdated,
	       @status AS status,
	       @postname AS postname,
	       @poid as poid,
	       @pokit as pokit,
	       @pomateriel as pomateriel,
	       @podomaine as podomaine,
	       @poadspath as poadspath,
	       (case when CHARINDEX('.',@posrvkit,1) > 0 then ltrim(rtrim(substring(@posrvkit,1,((CHARINDEX('.',@posrvkit,1))-1)))) else @posrvkit end) as posrvkit,
	       @poversion as poversion,
	       @pomodele as pomodele,
	       @PoBootDisk as pobootdisk
END
