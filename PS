CREATE VIEW [dbo].[eventlogself_view]
AS

SELECT       evt_id, evtlog.evc_name, evtlog.evt_user, evtlog.evt_workstation_name AS workstation, evtlog.evt_data AS dataWritten, evtlog.evt_message AS msg, evtlog.evt_timegenerated AS timegenerated, evtlog.evt_timewritten AS timewritten, 
                         CASE WHEN wksView.wks_kit_model = 'SIEGE' THEN CONCAT(wks_bank, '/', wks_branch) ELSE CASE WHEN wksView.wks_kit_model = 'AGENCE' THEN CONCAT([adf_name], '/', [ims_name]) ELSE NULL 
                         END END AS localisation
FROM            dbo.eventlog_view AS evtlog INNER JOIN
                         dbo.workstations_view AS wksView ON evtlog.wks_id = wksView.wks_id
WHERE        (evtlog.evc_name IN ('ADD_ADMIN', 'DELETE_ADMIN', 'LOCK_USB', 'UNLOCK_USB', 'ISOLATE', 'INTEGRATE', 'ADDDRAS', 'REMOVEDRAS'))

