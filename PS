CREATE PROCEDURE [dbo].[usp_select_workstation2]
	@wks_id AS INT
AS
BEGIN

	SET NOCOUNT ON

	DECLARE @srv_ref_id AS INT
	DECLARE @srv_kit_id AS INT
	DECLARE @adpims_id AS INT

	SELECT @srv_ref_id = wks_ref_server_id, @srv_kit_id = wks_kit_server_id , @adpims_id = wks_adspath_imssite_id 
	FROM workstations_view WITH (NOLOCK)
	WHERE wks_id = @wks_id

	SELECT * FROM [dbo].[servers] WITH (NOLOCK) 
	WHERE srv_id = @srv_ref_id
	
	SELECT * FROM [dbo].[workstations_view] WITH (NOLOCK) 
	WHERE wks_id = @wks_id
	
	SELECT * FROM [dbo].[networkprinters] WITH (NOLOCK) 
	INNER JOIN [dbo].[printers] WITH (NOLOCK) on prn_id = net_printer_id 
	INNER JOIN [dbo].[servers] WITH (NOLOCK) on prn_server_id = srv_id 
	WHERE net_workstation_id = @wks_id
	
	SELECT * FROM [dbo].[usbprinters] WITH (NOLOCK) 
	WHERE usb_workstation_id = @wks_id
	
	SELECT * FROM [dbo].[localprinters] WITH (NOLOCK) 
	WHERE loc_workstation_id = @wks_id
	
	SELECT * FROM [dbo].[ilsprinters] WITH (NOLOCK) 
	WHERE ils_workstation_id = @wks_id
	
	SELECT * FROM [dbo].[gedscanners] WITH (NOLOCK) 
	WHERE ged_workstation_id = @wks_id
	
	SELECT * FROM [dbo].[workstations_options] WITH (NOLOCK) 
	INNER JOIN [dbo].[options] WITH (NOLOCK) on opt_id = wksopt_option_id 
	WHERE wksopt_workstation_id = @wks_id

	SELECT * FROM [dbo].[servers] WITH (NOLOCK)
	WHERE srv_id = @srv_kit_id
	
	SELECT * FROM [dbo].[adspaths_imssites] WITH (NOLOCK)
	INNER JOIN [dbo].[adspaths] WITH (NOLOCK) ON adp_id = adpims_adspath_id
	INNER JOIN [dbo].[adfederations] WITH (NOLOCK) on adp_adfederation_id = adf_id
	INNER JOIN [dbo].[adsites] WITH (NOLOCK) on adp_adsite_id = ads_id
	INNER JOIN [dbo].[addomains] WITH (NOLOCK) on adp_addomain_id = add_id
	INNER JOIN [dbo].[imssites] WITH (NOLOCK) on adpims_imssite_id = ims_id
	INNER JOIN [dbo].[servers] WITH (NOLOCK) on srv_id = adp_kit_server_id
	WHERE adpims_id = @adpims_id
	
	SELECT cert_id, cert_workstation_id, cert_SN, cert_type, cert_urlrevocation, CONVERT(VARCHAR,cert_datetime, 120) cert_datetime FROM [dbo].[certificates] WITH (NOLOCK)
	INNER JOIN [dbo].[workstations] on wks_id = cert_workstation_id
	where wks_id= @wks_id order by cert_type, cert_SN;
	
	SELECT assoc_id, assoc_local_workstation_id, assoc_remote_workstation_id, assoc_remote_pxesite, assoc_remote_name
	FROM [dbo].[associated_devices] 
	WHERE assoc_local_workstation_id = @wks_id;

	SELECT * FROM [dbo].[securedprinters] WITH (NOLOCK) 
	WHERE secured_workstation_id = @wks_id;
	
END
