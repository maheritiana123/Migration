CREATE PROCEDURE [dbo].[usp_insert_adspath]
	@adp_addomain_name [NVARCHAR](MAX),
	@adp_adfederation_name [NVARCHAR](MAX),
	@adp_adsite_name [NVARCHAR](MAX),
	@adp_antivirus_server_id [INT],
	@adp_bank [NVARCHAR](MAX),
	@adp_federation [NVARCHAR](MAX),
	@adp_kit_server_id [INT] = NULL,
	@adp_reference_server_id [INT],
	@adp_scope [NVARCHAR](MAX),
	@adp_slice [NVARCHAR](MAX),
	@adp_mtosenv [NVARCHAR](MAX)
AS
BEGIN

	SET NOCOUNT ON

	DECLARE @add_id [INT]
	DECLARE @adf_id [INT]
	DECLARE @ads_id [INT]

	-- Création du domaine AD s'il n'existe pas déjà.
	SELECT @add_id = [add_id] FROM [dbo].[addomains] WITH (NOLOCK) WHERE [add_name] = @adp_addomain_name
	IF @add_id IS NULL BEGIN INSERT INTO [dbo].[addomains] (add_name) VALUES (@adp_addomain_name); SELECT @add_id = @@IDENTITY; END

	-- Création de la fédération AD si elle n'existe pas déjà.
	SELECT @adf_id = [adf_id] FROM [dbo].[adfederations] WITH (NOLOCK) WHERE [adf_name] = @adp_adfederation_name
	IF @adf_id IS NULL BEGIN INSERT INTO [dbo].[adfederations] (adf_name) VALUES (@adp_adfederation_name); SELECT @adf_id = @@IDENTITY; END

	-- Création du site AD s'il n'existe pas déjà.
	SELECT @ads_id = [ads_id] FROM [dbo].[adsites] WITH (NOLOCK) WHERE [ads_name] = @adp_adsite_name
	IF @ads_id IS NULL BEGIN INSERT INTO [dbo].[adsites] (ads_name) VALUES (@adp_adsite_name); SELECT @ads_id = @@IDENTITY; END

	-- Création du nouveau chemin AD.
	INSERT INTO [dbo].[adspaths] ([adp_addomain_id], [adp_adfederation_id], [adp_adsite_id], [adp_antivirus_server_id],
		[adp_bank], [adp_federation], [adp_kit_server_id_private], [adp_reference_server_id], [adp_scope], [adp_slice], [adp_mtosenv])
	VALUES (@add_id, @adf_id, @ads_id, @adp_antivirus_server_id, @adp_bank, @adp_federation, @adp_kit_server_id,
		@adp_reference_server_id, @adp_scope, @adp_slice, @adp_mtosenv)

	SELECT @@identity AS [adp_id]

END
