CREATE FUNCTION [dbo].[fct_check_workstations]()
RETURNS TABLE
AS
RETURN
(
		SELECT
				[poste].[poid],
				NULLIF(LTRIM(RTRIM([pv1].[pvevaleur])), '') as wks_accounting_bank,
				NULLIF(LTRIM(RTRIM([pv2].[pvevaleur])), '') as wks_accounting_branch,
				NULLIF(LTRIM(RTRIM([pv3].[pvevaleur])), '') as wks_accounting_number,
				NULLIF(LTRIM(RTRIM([pv4].[pvevaleur])), '') as wks_accounting_office,
				[poste].[poadsimsid] as wks_adspath_imssite_id,
				CASE [pp].[WPImpDef] WHEN '' THEN 1 ELSE 0 END as wks_auto_default_printer,
				CASE [poste].[poetat] WHEN 0 THEN 0 WHEN 10 THEN 1 WHEN 11 THEN 1 WHEN 12 THEN 2 WHEN 13 THEN 3 ELSE 9 END as wks_bios_status,
				NULLIF(LTRIM(RTRIM([poste].[pobootdisk])), '') as wks_boot_menu,
				[poste].[poheartbeat] as wks_heartbeat,
				[poste].[pohypervise] as wks_hypervision,
				NULLIF(LTRIM(RTRIM([poste].[poversion])), '') as wks_kit_distribution,
				NULLIF(LTRIM(RTRIM([poste].[pomateriel])), '') as wks_kit_equipment,
				NULLIF(LTRIM(RTRIM([poste].[pokit])), '') as wks_kit_model,
				NULLIF(LTRIM(RTRIM([pv5].[pvevaleur])), '') as wks_kit_operating_system,
				[poste].[pokitid] as wks_kit_server_id, 
				[poste].[poadressemac] as wks_macaddress,
				NULLIF(NULLIF(LTRIM(RTRIM([poste].[poter])), ''), 'TER') as wks_mat,
				CASE NULLIF(LTRIM(RTRIM([pv6].[pvevaleur])), '') WHEN 2 THEN 2 ELSE NULL END as wks_pcom_mode,
				[poste].[popxeid] as wks_pxe_server_id,
				CASE NULLIF(LTRIM(RTRIM([pv7].[pvevaleur])), '') WHEN 2 THEN 2 WHEN 3 THEN 3 ELSE NULL END as wks_rblk_mode,
				CASE NULLIF(LTRIM(RTRIM([pv8].[pvevaleur])), '') WHEN 'N' THEN 0 WHEN 'O' THEN 1 ELSE NULL END as wks_remote,
				CASE [poste].[poetat] WHEN 0 THEN 0 WHEN 1 THEN 1 WHEN 2 THEN 2 WHEN 3 THEN 3 WHEN 10 THEN 1 ELSE 9 END as wks_setup_status,
				CASE NULLIF(LTRIM(RTRIM([pv9].[pvevaleur])), '') WHEN 'N' THEN 0 WHEN 'O' THEN 1 ELSE NULL END as wks_sndpcanner
			FROM [dbo].[poste] WITH (NOLOCK)
			LEFT JOIN [dbo].[postevarenv] AS [pv1] WITH (NOLOCK) ON (
					[pv1].[pvepoid] = [poste].[poid]
			  AND [pv1].[pveveid] = (SELECT [veid] FROM [dbo].[varenv] WITH (NOLOCK) WHERE [venom] = 'WPCodeBanqueComptable'))
			LEFT JOIN [dbo].[postevarenv] AS [pv2] WITH (NOLOCK) ON (
					[pv2].[pvepoid] = [poste].[poid]
			  AND [pv2].[pveveid] = (SELECT [veid] FROM [dbo].[varenv] WITH (NOLOCK) WHERE [venom] = 'WPCodeCaisseComptable'))
			LEFT JOIN [dbo].[postevarenv] AS [pv3] WITH (NOLOCK) ON (
					[pv3].[pvepoid] = [poste].[poid]
			  AND [pv3].[pveveid] = (SELECT [veid] FROM [dbo].[varenv] WITH (NOLOCK) WHERE [venom] = 'WPNumeroComptable'))
			LEFT JOIN [dbo].[postevarenv] AS [pv4] WITH (NOLOCK) ON (
					[pv4].[pvepoid] = [poste].[poid]
			  AND [pv4].[pveveid] = (SELECT [veid] FROM [dbo].[varenv] WITH (NOLOCK) WHERE [venom] = 'WPCodeBureauComptable'))
			LEFT JOIN [dbo].[postevarenv] AS [pv5] WITH (NOLOCK) ON (
					[pv5].[pvepoid] = [poste].[poid]
			  AND [pv5].[pveveid] = (SELECT [veid] FROM [dbo].[varenv] WITH (NOLOCK) WHERE [venom] = 'WPOS'))
			LEFT JOIN [dbo].[postevarenv] AS [pv6] WITH (NOLOCK) ON (
					[pv6].[pvepoid] = [poste].[poid]
			  AND [pv6].[pveveid] = (SELECT [veid] FROM [dbo].[varenv] WITH (NOLOCK) WHERE [venom] = 'PFTLSNAFarmPCOM'))
			LEFT JOIN [dbo].[postevarenv] AS [pv7] WITH (NOLOCK) ON (
					[pv7].[pvepoid] = [poste].[poid]
			  AND [pv7].[pveveid] = (SELECT [veid] FROM [dbo].[varenv] WITH (NOLOCK) WHERE [venom] = 'PFTLSNAFarm'))
			LEFT JOIN [dbo].[postevarenv] AS [pv8] WITH (NOLOCK) ON (
					[pv8].[pvepoid] = [poste].[poid]
			  AND [pv8].[pveveid] = (SELECT [veid] FROM [dbo].[varenv] WITH (NOLOCK) WHERE [venom] = 'WPPED'))
			LEFT JOIN [dbo].[postevarenv] AS [pv9] WITH (NOLOCK) ON (
					[pv9].[pvepoid] = [poste].[poid]
			  AND [pv9].[pveveid] = (SELECT [veid] FROM [dbo].[varenv] WITH (NOLOCK) WHERE [venom] = 'WPScanSNDP'))
			LEFT JOIN [dbo].[fct_enum_posteprinters]() AS [pp]  ON (
				[pp].[poid] = [poste].[poid] )
			WHERE not (
				((len(NULLIF(LTRIM(RTRIM([pv1].[pvevaleur])), ''))=len(ltrim(rtrim(NULLIF(LTRIM(RTRIM([pv1].[pvevaleur])), '')))) AND len(NULLIF(LTRIM(RTRIM([pv1].[pvevaleur])), ''))=col_length('[dbo].[workstations]','wks_accounting_bank')))
				and
				((len(NULLIF(LTRIM(RTRIM([pv2].[pvevaleur])), ''))=len(ltrim(rtrim(NULLIF(LTRIM(RTRIM([pv2].[pvevaleur])), '')))) AND len(NULLIF(LTRIM(RTRIM([pv2].[pvevaleur])), ''))=col_length('[dbo].[workstations]','wks_accounting_branch')))
				and
