CREATE PROCEDURE [dbo].[SEARCH_ADSPATH]
	@adpathid as int = null,
	@Fede as varchar(15) = '',
	@Site as varchar(30) = '',
	@Domain as varchar(128) = '',
	@SrvPXE as varchar(100) = '',
	@SrvAV as varchar(100) = '',
	@SrvSMS as varchar(100) = '',
	@SrvSNA as varchar(100) = ''
AS
BEGIN
	-- SET NOCOUNT ON added to prevent extra result sets from
	-- interfering with SELECT statements.
	SET NOCOUNT ON;

	SELECT  distinct Adspath_id, 
	Ad_Federation_Id, Ad_Federation_Name, 
	Ad_Site_Id, Ad_Site_Name, 
	Ad_Domain_Id, Ad_Domain_Name_full,
	PREFIX.prefix_id, prefix_name,
	PERIMETER.Perimeter_Id, Perimeter_Name,
	s1.SrvId AS SrvIdPXE, s1.SrvName AS SrvPXE, 
	s2.SrvId  AS SrvIdAV, s2.SrvName AS SrvAV, 
	s3.SrvId AS SrvIdSMS, s3.SrvName AS SrvSMS, 
	s4.SrvId AS SrvIdSNA, s4.SrvName AS SrvSNA, 
	federation_Id, Federation_Name,
	Bank_Id, Bank_Name,
	Sms_Site_Id, Sms_Site_Name
	FROM ADSPATH WITH (NOLOCK)
	INNER JOIN AD_FEDERATION ON Adspath_Federation_Id = Ad_Federation_Id 
	INNER JOIN AD_SITE_LOCATION ON Adspath_Site_Id = Ad_Site_Id 
	INNER JOIN AD_DOMAIN ON Adspath_Domain_Id = Ad_Domain_Id 
	INNER JOIN SRV s1 ON Srv_Pxe_Id = s1.SrvId
	INNER JOIN SRV s2 ON Srv_Av_Id = s2.SrvId
	INNER JOIN SRV s3 ON Srv_Sms_Id = s3.SrvId
	INNER JOIN SRV s4 ON Srv_Sna_Id = s4.SrvId
	INNER JOIN PREFIX ON ADSPATH.Prefix_Id = PREFIX.Prefix_id
	INNER JOIN PERIMETER ON ADSPATH.Perimeter_Id = PERIMETER.Perimeter_Id
	INNER JOIN FEDERATION ON Code_Fede_Id = federation_id
	INNER JOIN BANK ON Code_Bank_Id = Bank_id
	INNER JOIN SMSSITECODE ON Code_Sms_Id = Sms_Site_Id
	WHERE (@Fede = '' OR ad_federation_name=@Fede)
	AND (@Site = '' OR ad_site_name=@Site)
	AND (@Domain = '' OR ad_domain_name_full=@Domain)
	AND (@SrvPXE = '' OR s1.SrvName LIKE (@SrvPXE + '%'))
	AND (@SrvAV = '' OR s2.SrvName LIKE (@SrvAV + '%'))
	AND (@SrvSMS = '' OR s3.SrvName LIKE (@SrvSMS + '%'))
	AND (@SrvSNA = '' OR s4.SrvName LIKE (@SrvSNA + '%'))
	AND (Adspath_Id = ISNULL(@adpathid, Adspath_Id))
	ORDER BY Ad_Federation_Name, Ad_Site_Name, Ad_Domain_Name_full
END
