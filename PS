CREATE PROCEDURE [dbo].[usp_update_perimeters_resources]
	 @Identities VARCHAR(MAX)	-- ids séparés par des virgules
	,@Resources VARCHAR(MAX)	-- json
	,@Perimeters VARCHAR(MAX)	-- json
AS
BEGIN

	DECLARE @ids TABLE ([Id] BIGINT);
	INSERT INTO @ids ([Id]) SELECT value FROM string_split(@Identities, ',') AS i;

	SET NOCOUNT ON

	DECLARE @tranCount INT = @@TRANCOUNT, @error INT, @errorMessage NVARCHAR(4000), @errorSeverity INT, @errorState INT

	IF @tranCount > 0
		SAVE TRAN usp_update_perimeters_resources;
	ELSE
		BEGIN TRAN;
	
	IF (@Perimeters IS NOT NULL)
	BEGIN
		DELETE FROM [dbo].[Perimeters]
		WHERE [IdentityId] IN (SELECT [Id] FROM @ids)

		SELECT
			@error = @@ERROR,
			@errorMessage = ERROR_MESSAGE(),
			@errorSeverity = ERROR_SEVERITY(),
			@errorState = ERROR_STATE()

		IF @error <> 0 BEGIN
			IF @tranCount > 0
				ROLLBACK TRAN usp_update_perimeters_resources;
			ELSE
				ROLLBACK;
			RAISERROR (@errorMessage, @errorSeverity, @errorState);
			RETURN
		END

		INSERT INTO [dbo].[Perimeters]
			([IdentityId]
			,[BankCodeStart]
			,[BranchCodeStart]
			,[BankCodeEnd]
			,[BranchCodeEnd])
		SELECT [Id], BankCodeStart, BranchCodeStart, BankCodeEnd, BranchCodeEnd
		FROM @ids, OPENJSON(@Perimeters)
			WITH (
			BankCodeStart INT '$.BankCodeStart',
			BranchCodeStart INT '$.BranchCodeStart',
			BankCodeEnd INT '$.BankCodeEnd',
			BranchCodeEnd INT '$.BranchCodeEnd'
		);

		SELECT
			@error = @@ERROR,
			@errorMessage = ERROR_MESSAGE(),
			@errorSeverity = ERROR_SEVERITY(),
			@errorState = ERROR_STATE()

		IF @error <> 0 BEGIN
			IF @tranCount > 0
				ROLLBACK TRAN usp_update_perimeters_resources;
			ELSE
				ROLLBACK;
			RAISERROR (@errorMessage, @errorSeverity, @errorState);
			RETURN
		END
	END

	IF(@Resources IS NOT NULL)
	BEGIN
		DELETE FROM [dbo].[Resources]
		WHERE [IdentityId] IN (SELECT [Id] FROM @ids)

		SELECT
			@error = @@ERROR,
			@errorMessage = ERROR_MESSAGE(),
			@errorSeverity = ERROR_SEVERITY(),
			@errorState = ERROR_STATE()

		IF @error <> 0 BEGIN
			IF @tranCount > 0
				ROLLBACK TRAN usp_update_perimeters_resources;
			ELSE
				ROLLBACK;
			RAISERROR (@errorMessage, @errorSeverity, @errorState);
			RETURN
		END

		INSERT INTO [dbo].[Resources]
			([IdentityId]
			,[Name])
		SELECT [Id], Nme
		FROM @ids, OPENJSON(@Resources)
			WITH (
			Nme VARCHAR(MAX) '$'
		  );

		SELECT
			@error = @@ERROR,
			@errorMessage = ERROR_MESSAGE(),
			@errorSeverity = ERROR_SEVERITY(),
			@errorState = ERROR_STATE()

		IF @error <> 0 BEGIN
			IF @tranCount > 0
				ROLLBACK TRAN usp_update_perimeters_resources;
			ELSE
				ROLLBACK;
			RAISERROR (@errorMessage, @errorSeverity, @errorState);
			RETURN
		END
	END

	IF @tranCount = 0
		COMMIT TRAN
END
GO
