CREATE PROCEDURE [dbo].[DELETE_IMP]
	@impname VARCHAR(MAX)
AS

BEGIN
	declare @iErreur as int
	set @iErreur = 0;
	BEGIN TRANSACTION DELETE_IMP

	UPDATE postevarenv
	SET pvevaleur = 'N'
	FROM postevarenv INNER JOIN varenv ON pveveid = veid
	WHERE 
	(EXISTS(SELECT * FROM postevarenv pve1 WITH (NOLOCK) INNER JOIN varenv ON pveveid = veid WHERE venom = 'WPRPrinterName' AND postevarenv.pvepoid = pve1.pvepoid AND pve1.pvevaleur like @impname)
	AND venom = 'WPImpReseau')
	OR (EXISTS(SELECT * FROM postevarenv pve1 WITH (NOLOCK) INNER JOIN varenv ON pveveid = veid  WHERE venom = 'WPRPrinterName2' AND postevarenv.pvepoid = pve1.pvepoid AND pve1.pvevaleur like @impname)
	AND venom = 'WPImpReseau2')
	OR (EXISTS(SELECT * FROM postevarenv pve1 WITH (NOLOCK) INNER JOIN varenv ON pveveid = veid  WHERE venom = 'WPRPrinterName3' AND postevarenv.pvepoid = pve1.pvepoid AND pve1.pvevaleur like @impname)
	AND venom = 'WPImpReseau3')
	OR (EXISTS(SELECT * FROM postevarenv pve1 WITH (NOLOCK) INNER JOIN varenv ON pveveid = veid WHERE venom = 'WPPPrinterName' AND postevarenv.pvepoid = pve1.pvepoid AND pve1.pvevaleur like @impname)
	AND venom = 'WPImpPartage')

	UPDATE postevarenv
	SET pvevaleur = ''
	WHERE pvevaleur = @impname
	AND pveveid in (SELECT veid FROM varenv WITH (NOLOCK) WHERE venom in ('WPRPrinterName','WPRPrinterName2','WPRPrinterName3','WPPPrinterName','WPImpDef'))

	SET @iErreur = @iErreur + @@ERROR
	IF (@iErreur = 0) COMMIT TRANSACTION DELETE_IMP
	ELSE ROLLBACK TRANSACTION DELETE_IMP
	SELECT @iErreur as result;
END
GO
