CREATE PROCEDURE [dbo].[usp_select_security_events]
	@date nvarchar(8) -- date au format ISO 112 "yyyyMMdd", date à partir de laquelle les événements sont sélectionnés (date incluse)
AS
BEGIN
	SET NOCOUNT ON;
	
	DECLARE @date_tmp AS DATETIME
	SET @date_tmp = CONVERT(datetime,@date,112)
	
	-- Récupération de la date de fin du mois
	DECLARE @date_end AS DATETIME
	SET @date_end = DATEADD(MONTH, 1, CONVERT(datetime,@date_tmp,112));	
	
	SELECT
	name_name
	,wks_kit_model
	,adf_name
	,ads_name
	,add_name
	,evc_name,evt_source,evt_user,evt_message,CONVERT(varchar,eventlog.evt_timegenerated,120) as evt_timegenerated,CONVERT(varchar,CONVERT(datetime,evt_timewritten),120) as evt_timewritten
	FROM dbo.eventlog with (nolock)
	inner join dbo.eventclasses with (nolock) on evc_id = evt_class_id 
	LEFT JOIN dbo.workstations_view with (nolock) on evt_guid = wks_guid
	WHERE evt_timewritten >= @date_tmp and evt_timewritten < @date_end
	and evc_name in('ADD_ADMIN','DELETE_ADMIN','UPDATE_WPADMIN','UPDATE_WPPERSOID','LOCK_USB','UNLOCK_USB')
	
END

