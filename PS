CREATE FUNCTION [dbo].[fct_check_names]()
RETURNS TABLE
AS
RETURN
(
		SELECT *
		FROM [dbo].[poste] p WITH (NOLOCK)
		WHERE NULLIF(LTRIM(RTRIM([ponom])), '') IS NOT NULL
		and  NOT (
			(len(ltrim(rtrim([ponom])))>(0))
			and  
			(
				select count(name)
				from (
				select ponom name 
				FROM [dbo].[poste] n
				where n.ponom = p.ponom
				) t
				GROUP by name
			) = 1
		)
)
