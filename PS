CREATE PROCEDURE [dbo].[AD_UPDATE_SRV]
@OldSrvId as int,
@OldSrvName as varchar(100),
@NewSrvName as varchar(100)
AS
BEGIN
	SET NOCOUNT ON;

	IF @OldSrvId IS NULL
	BEGIN
		SELECT @OldSrvId = SrvId FROM SRV WHERE SrvName=@OldSrvName
	END

	UPDATE [PXE1_PXE].[dbo].[SRV] SET SrvName = @NewSrvName WHERE SrvId = @OldSrvId
	SELECT @@IDENTITY AS NewSrvId

END
