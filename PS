CREATE FUNCTION [dbo].[fct_split](
   @source as NVARCHAR(MAX), @separator CHAR(1) = ';'
 )
 RETURNS @ARRAY TABLE (item NVARCHAR(MAX))
AS
BEGIN
DECLARE @current NVARCHAR(MAX)
DECLARE @item NVARCHAR(MAX)
DECLARE @index AS INT
SET @current = @source
WHILE LEN(@current) > 0
BEGIN
	SET @index = CHARINDEX(@separator, @current,1)
    IF @index > 0 
    BEGIN
        SET @item = SUBSTRING (@current, 1, @index - 1)
        SET @current = SUBSTRING (@current, @index + 1, LEN(@current) - @index)
        INSERT @ARRAY (item) VALUES (@item)
    END
    ELSE
    BEGIN                
        INSERT @ARRAY (item) VALUES (@current)    
        BREAK;
    END 
END
RETURN
END
GO
