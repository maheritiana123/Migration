CREATE PROCEDURE [dbo].[SELECT_ADV_POSTES]
	@valueAppli AS nvarchar(100),		-- Valeur du critère de recherche
	@valueState AS nvarchar(2),			-- Valeur du critère de recherche
	@valueMat AS nvarchar(100),		-- Valeur du critère de recherche
	@valueSrv AS nvarchar(100),		-- Valeur du critère de recherche
	@valueVersion AS nvarchar(3),		-- Valeur du critère de recherche
	@orderBy AS varchar(20), 		-- Nom de la colonne sur laquelle s'effectue le tri
	@order AS varchar(4),			-- Ordre dans lequel s'effectue le tri
	@top AS integer,				-- Nombre d'enregistrements à retourner
	@DateD  nvarchar(16),      	-- date de début ou unique
	@DateF nvarchar(16)		-- date de fin
WITH RECOMPILE
AS
BEGIN

	DECLARE @order_expression VARCHAR(100)
	DECLARE @search_condition VARCHAR(500)
	DECLARE @top_expression VARCHAR(50)
	DECLARE @date_expression VARCHAR(500)

	SET @order_expression = ''
	SET @search_condition = ''
	SET @date_expression = ''
	
	-- --------------------------
	-- Calcul de la clause TOP --
	-- --------------------------

	SET @top_expression = 'TOP ' + CONVERT(VARCHAR, @top)

	-- ----------------------------------------------------------------------
	-- Calcul de la clause WHERE : condition sur un des champs de la table --
	-- ----------------------------------------------------------------------

	IF @valueAppli <> '' SET @search_condition = ' and poKit=' + QUOTENAME(@valueAppli, '''')

	IF @valueState <> '' SET @search_condition = @search_condition + ' and poEtat=' + @valueState

	IF @valueMat <> '' SET @search_condition = @search_condition + ' and poMateriel=' + QUOTENAME(@valueMat, '''')

	IF @valueSrv <> '' SET @search_condition = @search_condition + ' and poSrvName=' + QUOTENAME(@valueSrv, '''')

	IF @valueVersion <> '' SET @search_condition = @search_condition + ' and poVersion=' + QUOTENAME(@valueVersion, '''')

	-- -------------------------------
	-- Calcul de la clause ORDER BY --
	-- -------------------------------

	IF @orderBy <> ''
	BEGIN
		SET @order_expression = ' ORDER BY ' + @orderBy
		IF @order <> '' SET @order_expression = @order_expression + ' ' + @order
	END
	
	-- --------------------------
	-- Calcul de la clause DATE --
	-- --------------------------
	
	if len(@DateD) <> 0 and len(@DateF) <> 0 set @date_expression = ' and polastmaj > convert(datetime,'''+ @DateD + ''',103) and polastmaj < convert(datetime,'''+ @DateF + ''',103)'

	-- --------------------------
	-- Execution de la requête --
	-- --------------------------

	exec( 'SELECT ' + @top_expression + ' T1.poid, T1.poadressemac, T1.ponom, T2.peintitule, T1.pomateriel, T1.posrvname, convert(char(10),T1.polastmaj,103) + '' '' + convert(char(10),T1.polastmaj,108) as lastmaj
		 FROM posteview T1, posteetat T2 WITH (NOLOCK) WHERE T1.poetat = T2.peid' + @search_condition + @date_expression + @order_expression)
END
GO
