CREATE PROCEDURE [dbo].[HSTINSERT](
	@POADRESSEMAC      NVARCHAR(12),    -- adresse MAC du poste
	@HSTUSER AS NVARCHAR(8),
	@HSTYPE AS NVARCHAR(8),
	@HSTRKNOM AS NVARCHAR(20),
	@HSTRKADRESSEMAC AS NVARCHAR(12),
	@HSTRKTER AS NVARCHAR(10),
	@HSTRKIP AS NVARCHAR(20)
) AS
    DECLARE @HSTID As INT
BEGIN
	IF EXISTS (SELECT POID from POSTE WHERE POADRESSEMAC = @POADRESSEMAC)
	 BEGIN
	  	INSERT INTO HISTORY (HST_PONOM,HST_POADRESSEMAC,HST_POEtat,HST_POVersion,HST_PODomaine,HST_POMateriel,HST_POKit,
		HST_POBootDisk,HST_POTER,HST_POAdspath,HST_USER,HST_TYPE,HST_RKNOM,HST_RKADRESSEMAC,HST_RKTER,HST_RKIP,HKITID,HPXEID,HST_POHYPERVISE,HST_POHEARTBEAT)
