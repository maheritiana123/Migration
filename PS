CREATE PROCEDURE [dbo].[usp_insert_event2]
	@evc_name [NVARCHAR](32),
	@evt_data [NVARCHAR](MAX) = NULL,
	@evt_message [NVARCHAR](MAX),
	@evt_source [NVARCHAR](64),
	@evt_timegenerated [DATETIME] = NULL,
	@evt_user [NVARCHAR](MAX),
	@evt_justificatif [NVARCHAR](64)='OLDWEBS',
	@wks_id [INT]
AS
BEGIN

	DECLARE @evc_id [INT]
	DECLARE @now [DATETIME]

	-- Horodatage de l'évènement
	SELECT @now = GETDATE()

	-- Création de la catégorie d'évènements si elle n'existe pas encore
	SELECT @evc_id = [evc_id] FROM [dbo].[eventclasses] WITH (NOLOCK) WHERE [evc_name] = @evc_name
	IF @evc_id IS NULL
	BEGIN
		INSERT INTO [dbo].[eventclasses] ([evc_name],[evc_log_id]) 
		SELECT @evc_name,(SELECT TOP 1 [setting_log_id] FROM settings WITH (NOLOCK))
		SELECT @evc_id = @@IDENTITY
	END

	-- Insertion de l'évènement à condition que le poste de travail existe
	INSERT INTO [dbo].[eventlog] 
	([evt_guid], [evt_class_id], [evt_data], [evt_message],[evt_snapshot], [evt_source], [evt_timegenerated], [evt_timewritten], [evt_user], [evt_workstation_macaddress],[evt_workstation_uuid], [evt_workstation_name], [evt_workstation_mat_barcode], [evt_workstation_status], [evt_workstation_justificatif])
		SELECT 
		[wks_guid], 
		@evc_id, 
		@evt_data, 
		@evt_message, 
		CASE WHEN (SELECT evc_take_snapshot FROM [dbo].[eventclasses] WITH (NOLOCK) WHERE evc_id = @evc_id) = 1 THEN [dbo].[fct_take_snapshot](@wks_id) ELSE NULL END,
		@evt_source,
		ISNULL(@evt_timegenerated, @now), 
		@now, 
		@evt_user, 
		[workstations].[wks_macaddress], 
		[workstations].[wks_uuid], 
		[names].[name_name],
		[workstations].[wks_mat_barcode],
		[workstations].[wks_setup_status],
		@evt_justificatif
		FROM [dbo].[workstations] WITH (NOLOCK)
		LEFT JOIN [dbo].[names] on [names].[name_workstation_id] = [workstations].[wks_id]
		WHERE [wks_id] = @wks_id
		
	UPDATE [dbo].[workstations]
	SET wks_lastupdate = @now
	WHERE wks_id = @wks_id
END
