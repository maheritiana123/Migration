CREATE VIEW [dbo].[POSTEVIEW]
		AS
		select PoId,PoNom,PoAdresseMAC,'WKS' as PoModele , PoEtat, PoPostBios, srvkit.srvname as PoSrvKit,
		Poversion, (case when Ad_Domain_Name IS NULL then domaine.pvevaleur else Ad_Domain_Name end) as Podomaine,PoMateriel, Pokit, PoBootDisk,
		(case when PoAdsImsId IS NULL then srvpxe.srvname else adims.srvname end) as PoSrvName,
		(case when ter.pvevaleur is NULL then '' else ter.pvevaleur end) as Poter,
		(case when PoAdsImsId IS NULL then (case when caisse.pvevaleur IS NULL then '' else ('OU#ORDINATEURS;OU#' + caisse.pvevaleur + ';OU#' + fede.pvevaleur + '-AGENCES;DC#'+ domaine.pvevaleur + ';DC#CM-CIC;DC#FR') end)
		else ('OU#ORDINATEURS;OU#' + Ad_Site_Name + ';OU#' + Ad_Federation_Name + ';DC#' + Ad_Domain_Name + ';DC#CM-CIC;DC#FR') end) as poadspath,
		PoLastMaj, pokitid, (case when PoAdsImsId IS NULL then popxeid else Srv_Pxe_Id end) as popxeid, Adspath_Id as adid, PoAdsImsId as poadimsid, PoStateDate, dbo.POSTE.PoHypervise, dbo.POSTE.PoHeartbeat from dbo.[poste] WITH( NOLOCK )
		left outer join
		(select srvname, Adspath_Ims_Id, adname.Adspath_Id, Srv_Pxe_Id, Ad_Federation_Name, Ad_Site_Name, Ad_Domain_Name from adspath_imssite as ads
		inner join 
		(select srvname, ad.Adspath_Id, Srv_Pxe_Id, Ad_Federation_Name, Ad_Site_Name, Ad_Domain_Name
		from adspath ad
		inner join AD_FEDERATION on Ad_Federation_Id = Adspath_Federation_Id
		inner join AD_SITE_LOCATION on Ad_Site_Id = Adspath_Site_Id
		inner join AD_DOMAIN on Ad_Domain_Id = Adspath_Domain_Id
		inner join SRV on srvid = Srv_Pxe_Id) as adname
		on ads.Adspath_Id = adname.Adspath_Id) as adims
		on PoAdsImsId = adims.Adspath_Ims_Id
		left outer join
			(select pvevaleur, pvepoid from postevarenv 
			inner join varenv on veid = pveveid
			where venom = 'WPTER') as ter
			on poid = ter.pvepoid
		left outer join
			(select pvevaleur, pvepoid from postevarenv 
			inner join varenv on veid = pveveid
			where venom = 'WPDOMAINE') as domaine
			on poid = domaine.pvepoid
		left outer join
			(select pvevaleur, pvepoid from postevarenv 
			inner join varenv on veid = pveveid
			where venom = 'WPCODECAISSE') as caisse
			on poid = caisse.pvepoid
		left outer join
			(select pvevaleur, pvepoid from postevarenv 
			inner join varenv on veid = pveveid
			where venom = 'WPCODEFEDE') as fede
			on poid = fede.pvepoid
		inner join
			(select srvname, srvid from srv) as srvkit on pokitid = srvkit.srvid
		inner join
			(select srvname, srvid from srv) as srvpxe on popxeid = srvpxe.srvid
		
