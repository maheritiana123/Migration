		  AND NOT (
			(((len(ltrim(rtrim([pv1].[pvevaleur])))>(0))) or pv1.pvevaleur is not null)
			and
			(pv2.pvevaleur is NULL OR ((len(NULLIF(LTRIM(RTRIM([pv2].[pvevaleur])), ''))=len(ltrim(rtrim(NULLIF(LTRIM(RTRIM([pv2].[pvevaleur])), '')))) AND len(NULLIF(LTRIM(RTRIM([pv2].[pvevaleur])), ''))=col_length('[dbo].[gedscanners]','ged_mat'))))
			and
			pv1.pvepoid IS NOT NULL
