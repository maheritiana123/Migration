CREATE PROCEDURE [dbo].[usp_select_impactedworkstations]
	@oldsrv_id AS INT,
	@type AS VARCHAR(16),
	@first_wks_id AS INT
AS
BEGIN

	SET NOCOUNT ON

		IF @type = 'ref' 
		BEGIN
			SELECT TOP 5000 * FROM [dbo].[workstations_view] WITH (NOLOCK)
			WHERE wks_ref_server_id = @oldsrv_id
			and wks_id > @first_wks_id
			ORDER BY wks_id
		END

		IF @type = 'kit' 
		BEGIN
			SELECT TOP 5000 * FROM [dbo].[workstations_view] WITH (NOLOCK)
			WHERE wks_kit_server_id = @oldsrv_id
			and wks_id > @first_wks_id
			ORDER BY wks_id
		END

