CREATE PROCEDURE [dbo].[usp_select_workstations]
	@top AS INT,
	@wks_id AS BIGINT = NULL,
	@name as VARCHAR(MAX) = NULL,
	@wks_mat_barcode AS VARCHAR(MAX) = NULL,
	@wks_kit_model AS VARCHAR(24) = NULL,
	@wpcodecaissecomptable AS VARCHAR(5) = NULL,
	@wpcodebureaucomptable AS VARCHAR(2) = NULL,
	@wpcodepvacomptable AS VARCHAR(3) = NULL,
	@wpcodecaisse AS VARCHAR(5) = NULL,
	@wpcodebureau AS VARCHAR(2) = NULL,
	@wpcodepva AS VARCHAR(3) = NULL,
	@rekit as BIT=0,
	@srvkitfullname  as nvarchar(81)=null,
	@wpcodebanque as varchar(5)=null,
	@wpcodebanquecomptable AS VARCHAR(5) = NULL,
	@wpcodesection as varchar(7) = null
AS
BEGIN

	SET NOCOUNT ON

	DECLARE @request AS VARCHAR(MAX)

	DECLARE @WHERE AS VARCHAR(MAX);

	IF (@wks_id IS NOT NULL)
	BEGIN
	SET @WHERE = [dbo].[fct_add_condition](@WHERE,'[workstations_view].[wks_id] > ' + CAST(REPLACE(@wks_id, '''', ' ') as VARCHAR(MAX)),'AND');
	END
	IF (@name IS NOT NULL)
	BEGIN
	SET @WHERE = [dbo].[fct_add_condition](@WHERE,'[workstations_view].[name_name] like ''' + REPLACE(@name, '''', ' ') + '''','AND');
	END
