CREATE PROCEDURE [dbo].[BSTRAPOPTS_GETPOSTE]
	@MACAddress nvarchar(12),     -- Adresse MAC du poste client.
	@ServerFullName nvarchar(100),     -- Nom complet du serveur PXE
	@ServerName nvarchar(100)     -- Nom court du serveur PXE

AS
BEGIN
	SET NOCOUNT ON

	IF EXISTS (SELECT POADRESSEMAC FROM POSTEVIEW WHERE POADRESSEMAC = @MACAddress)
	BEGIN

	  SELECT DATEDIFF(SS, POLASTMAJ, GETDATE()) AS lastUpdated,
	       POETAT AS status,
	       PONOM AS postname,
	       POID as poid,
	       lower(POKIT) as pokit,
	       POMATERIEL as pomateriel,
	       PODOMAINE as podomaine,
	       POADSPATH as poadspath,
	       ltrim(rtrim(substring(POSRVKIT,1,((CHARINDEX('.',POSRVKIT,1))-1)))) as posrvkit,
	       lower(POVERSION) as poversion,
	       POMODELE as pomodele,
	       POBOOTDISK as pobootdisk
		   FROM POSTEVIEW
	       WHERE POADRESSEMAC = @MACAddress
	END
END
