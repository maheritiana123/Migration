CREATE PROCEDURE [dbo].[usp_pagination]
	@page AS INT,
	@nb_par_page as INT,
	@col_order as VARCHAR(MAX),
	@order as VARCHAR(MAX),
	@requete_appelante as VARCHAR(MAX)
	
AS
BEGIN
SET NOCOUNT ON
	
	DECLARE @top as INT
	DECLARE @last as INT
	DECLARE @count as INT
	DECLARE @requete as VARCHAR(MAX)
	DECLARE @CLAUSE_ORDER1 as VARCHAR(MAX)
	DECLARE @CLAUSE_ORDER2 as VARCHAR(MAX)

	SELECT @CLAUSE_ORDER1 = 'ORDER BY ' + @col_order + ' ' +@order;
	SELECT @CLAUSE_ORDER2 = 'ORDER BY ' + @col_order + ' ' + CASE WHEN UPPER(@order) = 'ASC' THEN 'DESC' ELSE 'ASC' END

	DECLARE @t as nvarchar(max)
	SET @t = N'SELECT @count = count(*) FROM ('+@requete_appelante+N')t'

	EXECUTE sp_executesql @t,N'@count INT OUTPUT',@count=@count OUTPUT
	SET @last = @nb_par_page * @page
	SET @top = @nb_par_page

	IF (@last > @count and @last-@nb_par_page<@count)
	BEGIN
	SET @top = @count%@nb_par_page
	END
	ELSE
	IF (@last-@nb_par_page>=@count)
	SET @top = 0

	SET @requete = 'SELECT * FROM (SELECT TOP '+CAST(@top AS VARCHAR(MAX))+' * FROM (SELECT TOP '+CAST(@last AS VARCHAR(MAX))+' * FROM ('+@requete_appelante+')t3 '+@CLAUSE_ORDER1+')t2 '+@CLAUSE_ORDER2+')t1 '+@CLAUSE_ORDER1+'';

--	PRINT @requete
	EXEC (@requete)
	SELECT 'Total' = @count 

END
		  
		  











