CREATE PROCEDURE [dbo].[usp_insert_identity]
	 @Type SMALLINT
	,@Value NVARCHAR(256)
	,@ExpirationDate DATETIME
	,@Description NVARCHAR(MAX)
	,@Ressources VARCHAR(MAX)
	,@Perimeters VARCHAR(MAX)
AS
BEGIN

	SET NOCOUNT ON

	DECLARE @tranCount INT = @@TRANCOUNT

	IF @tranCount > 0
		SAVE TRAN usp_insert_identity;
	ELSE
		BEGIN TRAN;

	DECLARE @id BIGINT, @error INT, @errorMessage NVARCHAR(4000), @errorSeverity INT, @errorState INT

	INSERT INTO [dbo].[Identities]
        ( [Type]
        , [Value]
        , [ExpirationDate]
        , [Description])
    VALUES
		( @Type
        , @Value
        , @ExpirationDate
        , @Description)

	SELECT
		@id = SCOPE_IDENTITY(),
		@error = @@ERROR,
		@errorMessage = ERROR_MESSAGE(),
		@errorSeverity = ERROR_SEVERITY(),
		@errorState = ERROR_STATE()

	IF @error <> 0 BEGIN
		IF @tranCount > 0
			ROLLBACK TRAN usp_insert_identity;
		ELSE
			ROLLBACK;
		SELECT -1 AS [IdentityId];
		RAISERROR (@errorMessage, @errorSeverity, @errorState);
		RETURN
	END
	
	IF (@Perimeters IS NOT NULL)
	BEGIN
	INSERT INTO [dbo].[Perimeters]
        ( [IdentityId]
        , [BankCodeStart]
        , [BranchCodeStart]
        , [BankCodeEnd]
        , [BranchCodeEnd])
	SELECT @id, BankCodeStart, BranchCodeStart, BankCodeEnd, BranchCodeEnd
	FROM OPENJSON(@perimeters)
		WITH (
		BankCodeStart INT '$.BankCodeStart',
		BranchCodeStart INT '$.BranchCodeStart',
		BankCodeEnd INT '$.BankCodeEnd',
		BranchCodeEnd INT '$.BranchCodeEnd'
		);
	END

	INSERT INTO [dbo].[Resources]
		( [IdentityId]
		, [Name])
	SELECT @id, Nme
	FROM OPENJSON(@ressources)
		WITH (
		Nme VARCHAR(64) '$'
		);

	SELECT
		@error = @@ERROR,
		@errorMessage = ERROR_MESSAGE(),
		@errorSeverity = ERROR_SEVERITY(),
		@errorState = ERROR_STATE()

	IF @error <> 0 BEGIN
		IF @tranCount > 0
			ROLLBACK TRAN usp_insert_identity;
		ELSE
			ROLLBACK;
		SELECT -1 AS [IdentityId];
		RAISERROR (@errorMessage, @errorSeverity, @errorState);
		RETURN
	END

	SELECT @id AS [IdentityId]

	IF @tranCount = 0
		COMMIT TRAN
END
GO
