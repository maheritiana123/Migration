CREATE PROCEDURE [dbo].[ACTUVAR] @OLDVALUE AS NVARCHAR(200), @NEWVALUE AS NVARCHAR(200), @POID AS INT , @PONAME AS NVARCHAR(20) AS
BEGIN
	DECLARE @RETURNVALUE INT
	SELECT @RETURNVALUE= 1
	-- si id poste absent, recherche d'après le nom
	IF @POID = 0
	BEGIN
		SELECT @POID = poid from POSTEVIEW where ponom = @PONAME
	END 
	
	UPDATE POSTEVARENV SET PVEVALEUR = REPLACE(PVEVALEUR,@OLDVALUE,@NEWVALUE) WHERE (PVEVALEUR LIKE '%'+ @OLDVALUE + '%') AND PVEPOID=@POID
	IF @@ERROR <> 0
	BEGIN
		SELECT @RETURNVALUE= 0
	END	
	-- valeur de retour de la procédure stockée
	select @RETURNVALUE as result
END
GO
