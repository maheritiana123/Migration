GO

CREATE FUNCTION [dbo].[fct_enum_networkprinters]()
RETURNS TABLE
AS
RETURN
(
		SELECT p.*,[srv].[srvid] FROM (
			SELECT 
			[pp].[poid],
			SUBSTRING(SUBSTRING([pp].[WPImpDef], 3, LEN([pp].[WPImpDef])), 1, CHARINDEX('\', SUBSTRING([pp].[WPImpDef], 3, LEN([pp].[WPImpDef]))) - 1) AS [srvname],
			SUBSTRING(SUBSTRING([pp].[WPImpDef], 3, LEN([pp].[WPImpDef])), CHARINDEX('\', SUBSTRING([pp].[WPImpDef], 3, LEN([pp].[WPImpDef]))) + 1, LEN([pp].[WPImpDef])) AS [printername],
			1 WPImpDef,
			0 WPPPrinterName,
			0 WPRPrinterName,
			0 WPRPrinterName2,
			0 WPRPrinterName3
			FROM fct_enum_posteprinters() [pp]
			WHERE WPImpDef like '\\%\%'
			UNION
			SELECT 
			[pp].[poid],
			SUBSTRING(SUBSTRING([pp].[WPPPrinterName], 3, LEN([pp].[WPPPrinterName])), 1, CHARINDEX('\', SUBSTRING([pp].[WPPPrinterName], 3, LEN([pp].[WPPPrinterName]))) - 1) AS [srvname],
			SUBSTRING(SUBSTRING([pp].[WPPPrinterName], 3, LEN([pp].[WPPPrinterName])), CHARINDEX('\', SUBSTRING([pp].[WPPPrinterName], 3, LEN([pp].[WPPPrinterName]))) + 1, LEN([pp].[WPPPrinterName])) AS [printername],
			0 WPImpDef,
			1 WPPPrinterName,
			0 WPRPrinterName,
			0 WPRPrinterName2,
			0 WPRPrinterName3
			FROM fct_enum_posteprinters() [pp]
			WHERE WPImpPartage = 'O'
			UNION
			SELECT 
			[pp].[poid],
			SUBSTRING(SUBSTRING([pp].[WPRPrinterName], 3, LEN([pp].[WPRPrinterName])), 1, CHARINDEX('\', SUBSTRING([pp].[WPRPrinterName], 3, LEN([pp].[WPRPrinterName]))) - 1) AS [srvname],
			SUBSTRING(SUBSTRING([pp].[WPRPrinterName], 3, LEN([pp].[WPRPrinterName])), CHARINDEX('\', SUBSTRING([pp].[WPRPrinterName], 3, LEN([pp].[WPRPrinterName]))) + 1, LEN([pp].[WPRPrinterName])) AS [printername],
			0 WPImpDef,
			0 WPPPrinterName,
			1 WPRPrinterName,
			0 WPRPrinterName2,
			0 WPRPrinterName3
			FROM fct_enum_posteprinters() [pp]
			WHERE WPImpReseau = 'O'
			UNION
			SELECT 
			[pp].[poid],
			SUBSTRING(SUBSTRING([pp].[WPRPrinterName2], 3, LEN([pp].[WPRPrinterName2])), 1, CHARINDEX('\', SUBSTRING([pp].[WPRPrinterName2], 3, LEN([pp].[WPRPrinterName2]))) - 1) AS [srvname],
			SUBSTRING(SUBSTRING([pp].[WPRPrinterName2], 3, LEN([pp].[WPRPrinterName2])), CHARINDEX('\', SUBSTRING([pp].[WPRPrinterName2], 3, LEN([pp].[WPRPrinterName2]))) + 1, LEN([pp].[WPRPrinterName2])) AS [printername],
			0 WPImpDef,
			0 WPPPrinterName,
			0 WPRPrinterName,
			1 WPRPrinterName2,
			0 WPRPrinterName3
			FROM fct_enum_posteprinters() [pp]
			WHERE WPImpReseau2 = 'O'
			UNION
			SELECT 
			[pp].[poid],
			SUBSTRING(SUBSTRING([pp].[WPRPrinterName3], 3, LEN([pp].[WPRPrinterName3])), 1, CHARINDEX('\', SUBSTRING([pp].[WPRPrinterName3], 3, LEN([pp].[WPRPrinterName3]))) - 1) AS [srvname],
			SUBSTRING(SUBSTRING([pp].[WPRPrinterName3], 3, LEN([pp].[WPRPrinterName3])), CHARINDEX('\', SUBSTRING([pp].[WPRPrinterName3], 3, LEN([pp].[WPRPrinterName3]))) + 1, LEN([pp].[WPRPrinterName3])) AS [printername],
			0 WPImpDef,
			0 WPPPrinterName,
			0 WPRPrinterName,
			0 WPRPrinterName2,
			1 WPRPrinterName3
			FROM fct_enum_posteprinters() [pp]
			WHERE WPImpReseau3 = 'O'
		) p
		LEFT JOIN [dbo].[srv] ON [srv].[srvname] = [p].[srvname]			 
)
GO
