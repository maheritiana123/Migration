CREATE FUNCTION [dbo].[fct_check_ilsprinters]()
RETURNS TABLE
AS
RETURN
(
			SELECT NULLIF(LTRIM(RTRIM([pv2].[pvevaleur])), '') as ils_cardreader, NULLIF(LTRIM(RTRIM([pv3].[pvevaleur])), '') as ils_driver,
				CASE NULLIF(LTRIM(RTRIM([pv4].[pvevaleur])), '') WHEN 'O' THEN 1 ELSE 0 END as ils_duplex,
				NULLIF(LTRIM(RTRIM([pv5].[pvevaleur])), '') as ils_ipaddress, [pv1].[pvepoid] as ils_workstation_id
			FROM [dbo].[postevarenv] AS [pv1] WITH (NOLOCK)
			LEFT JOIN [dbo].[postevarenv] AS [pv2] WITH (NOLOCK) ON (
					[pv2].[pvepoid] = [pv1].[pvepoid]
			  AND [pv2].[pveveid] = (SELECT [veid] FROM [dbo].[varenv] WITH (NOLOCK) WHERE [venom] = 'WPLecteurILS'))
			LEFT JOIN [dbo].[postevarenv] AS [pv3] WITH (NOLOCK) ON (
					[pv3].[pvepoid] = [pv1].[pvepoid]
			  AND [pv3].[pveveid] = (SELECT [veid] FROM [dbo].[varenv] WITH (NOLOCK) WHERE [venom] = 'WPIPrinterTER'))
			LEFT JOIN [dbo].[postevarenv] AS [pv4] WITH (NOLOCK) ON (
					[pv4].[pvepoid] = [pv1].[pvepoid]
			  AND [pv4].[pveveid] = (SELECT [veid] FROM [dbo].[varenv] WITH (NOLOCK) WHERE [venom] = 'WPIPrinterVerso'))
			LEFT JOIN [dbo].[postevarenv] AS [pv5] WITH (NOLOCK) ON (
					[pv5].[pvepoid] = [pv1].[pvepoid]
			  AND [pv5].[pveveid] = (SELECT [veid] FROM [dbo].[varenv] WITH (NOLOCK) WHERE [venom] = 'WPIIP'))
			WHERE [pv1].[pveveid] = (SELECT [veid] FROM [dbo].[varenv] WITH (NOLOCK) WHERE [venom] = 'WPImpILS')
			  AND [pv1].[pvevaleur]	= 'O'
				and not (
					[pv2].[pvevaleur] is not NULL
					AND
					((len(ltrim(rtrim(NULLIF(LTRIM(RTRIM([pv2].[pvevaleur])), ''))))>(0)))
					AND
					((len(ltrim(rtrim(NULLIF(LTRIM(RTRIM([pv3].[pvevaleur])), ''))))>(0)))
					AND
