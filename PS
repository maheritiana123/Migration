CREATE PROCEDURE [dbo].[usp_select_servers_count]
@srv_fullname AS VARCHAR(MAX) = NULL,
	@pxe AS VARCHAR(MAX) = NULL,
	@kit AS VARCHAR(MAX) = NULL,
	@reference AS VARCHAR(MAX) = NULL,
	@av AS VARCHAR(MAX) = NULL,
	@imp AS VARCHAR(MAX) = NULL,
	@printservers_anomaly AS VARCHAR(MAX) = NULL,
	@refservers_anomaly AS VARCHAR(MAX) = NULL,
	@adf_name AS VARCHAR(MAX) = NULL,
	@add_name AS VARCHAR(MAX) = NULL,
	@ads_name AS VARCHAR(MAX) = NULL,
	@page AS INT,
	@nb_par_page AS INT,
	@col_order AS VARCHAR(MAX),
	@order AS VARCHAR(MAX)
	
AS
BEGIN
	SET NOCOUNT ON
	DECLARE @WHERE AS VARCHAR(MAX);
	
	IF (@srv_fullname IS NOT NULL)
	BEGIN
	SET @WHERE = [dbo].[fct_add_condition](@WHERE,'srv_fullname like ''%' + @srv_fullname + '%'' ','AND');
	END
	IF (@pxe IS NOT NULL)
	BEGIN
	SET @WHERE = [dbo].[fct_add_condition](@WHERE,'nb_postes_pxe > 0','AND');
	END
	IF (@kit IS NOT NULL)
	BEGIN
	SET @WHERE = [dbo].[fct_add_condition](@WHERE,'nb_postes_kit > 0 or nb_adspaths_kit > 0','AND');
	END
	IF (@reference IS NOT NULL)
	BEGIN
	SET @WHERE = [dbo].[fct_add_condition](@WHERE,'nb_postes_ref > 0 or nb_adspaths_ref > 0','AND');
	END
	IF (@av IS NOT NULL)
	BEGIN
	SET @WHERE = [dbo].[fct_add_condition](@WHERE,'nb_postes_av > 0 or nb_adspaths_av > 0','AND');
	END
	IF (@imp IS NOT NULL)
	BEGIN
	SET @WHERE = [dbo].[fct_add_condition](@WHERE,'EXISTS(SELECT * from [dbo].[printservers] WITH (NOLOCK) where prs_print_server_id = srv_id) or nb_postes_printserver > 0','AND');
	END
	IF (@printservers_anomaly IS NOT NULL)
	BEGIN
	SET @WHERE = [dbo].[fct_add_condition](@WHERE,'EXISTS(SELECT * FROM [dbo].[networkprinters_view] WITH (NOLOCK) INNER JOIN [dbo].[workstations_view] ON net_workstation_id = wks_id and srv_id = wks_ref_server_id WHERE prn_server_id not in (SELECT prs_print_server_id FROM [dbo].[printservers] WITH (NOLOCK) WHERE prs_server_id = srv_id))','AND');
	END
	IF (@refservers_anomaly IS NOT NULL)
	BEGIN
	SET @WHERE = [dbo].[fct_add_condition](@WHERE,'EXISTS(SELECT * FROM [dbo].[networkprinters_view] WITH (NOLOCK) INNER JOIN [dbo].[workstations_view] ON net_workstation_id = wks_id and srv_id = prn_server_id WHERE wks_ref_server_id not in (SELECT prs_server_id FROM [dbo].[printservers] WITH (NOLOCK) WHERE prs_print_server_id = srv_id))','AND');
	END
	
	IF (@adf_name IS NOT NULL)
	BEGIN
	SET @WHERE = [dbo].[fct_add_condition](@WHERE,'EXISTS(SELECT adp_id FROM [dbo].[adspaths_view] WITH (NOLOCK) WHERE (adp_reference_server_id = srv_id or adp_antivirus_server_id = srv_id or adp_kit_server_id = srv_id) and adf_name = '''+ @adf_name +''')','AND');
	END
	IF (@ads_name IS NOT NULL)
	BEGIN
	SET @WHERE = [dbo].[fct_add_condition](@WHERE,'EXISTS(SELECT adp_id FROM [dbo].[adspaths_view] WITH (NOLOCK) WHERE (adp_reference_server_id = srv_id or adp_antivirus_server_id = srv_id or adp_kit_server_id = srv_id) and ads_name = '''+ @ads_name +''')','AND');
	END
	IF (@add_name IS NOT NULL)
	BEGIN
	SET @WHERE = [dbo].[fct_add_condition](@WHERE,'EXISTS(SELECT adp_id FROM [dbo].[adspaths_view] WITH (NOLOCK) WHERE (adp_reference_server_id = srv_id or adp_antivirus_server_id = srv_id or adp_kit_server_id = srv_id) and add_name = '''+ @add_name +''')','AND');
	END
	      
	DECLARE @requete AS VARCHAR(MAX);
	SET @requete =
	'SELECT * FROM (
		SELECT
	srv_id,
	srv_hostname,
	srv_domain,
	srv_fullname
	,(select COUNT(wks_id) FROM [dbo].[workstations] WITH (NOLOCK) where srv_id = wks_pxe_server_id) nb_postes_pxe
	,(select COUNT(wks_id) FROM [dbo].[workstations] WITH (NOLOCK)
	INNER JOIN adspaths_imssites on wks_adspath_imssite_id = adpims_id
	INNER JOIN adspaths on adpims_adspath_id = adp_id 
	WHERE adp_kit_server_id = srv_id AND wks_kit_server_id IS NULL)
	+(select COUNT(wks_id) FROM [dbo].[workstations] WITH (NOLOCK)
	WHERE wks_kit_server_id = srv_id)
	+(SELECT COUNT(wks_id) FROM [dbo].[workstations] WITH (NOLOCK)
	WHERE wks_adspath_imssite_id is NULL and (wks_kit_server_id = srv_id OR (wks_kit_server_id IS null and wks_pxe_server_id = srv_id))) nb_postes_kit
	,(select COUNT(adp_id) from [dbo].[adspaths] WITH (NOLOCK) where srv_id = adp_reference_server_id) nb_adspaths_ref
	,(select COUNT(adp_id) from [dbo].[adspaths] WITH (NOLOCK) where srv_id = adp_kit_server_id) nb_adspaths_kit
	,(select COUNT(adp_id) from [dbo].[adspaths] WITH (NOLOCK) where srv_id = adp_antivirus_server_id) nb_adspaths_av
	,(select COUNT(wks_id) FROM [dbo].[workstations] WITH (NOLOCK)
	INNER JOIN adspaths_imssites on wks_adspath_imssite_id = adpims_id
	INNER JOIN adspaths on adpims_adspath_id = adp_id
	WHERE adp_reference_server_id = srv_id)
	+(SELECT COUNT(wks_id) FROM [dbo].[workstations] WITH (NOLOCK)
	WHERE wks_adspath_imssite_id IS NULL AND wks_pxe_server_id = srv_id) nb_postes_ref
	,(select COUNT(wks_id) FROM [dbo].[workstations] WITH (NOLOCK)
	INNER JOIN adspaths_imssites on wks_adspath_imssite_id = adpims_id
	INNER JOIN adspaths on adpims_adspath_id = adp_id
	WHERE srv_id = adp_antivirus_server_id) nb_postes_av
	,(select COUNT(distinct net_workstation_id) from [dbo].[networkprinters] WITH (NOLOCK)
	INNER JOIN printers on net_printer_id = prn_id 
	WHERE srv_id = prn_server_id) nb_postes_printserver
	FROM [dbo].[servers] WITH (NOLOCK)
	) s'
	+ ' ' + ISNULL(@WHERE,'') + ' ';

