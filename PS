CREATE VIEW [dbo].[adspaths_view]
AS
	SELECT 
	[adp_id],
	[adp_adfederation_id],
	[adf_name],
	[adp_adsite_id],
	[ads_name],
	[adp_addomain_id],
	[add_name],
	[adp_reference_server_id],
	[srv_ref].[srv_hostname] AS [srv_hostname_ref],
	[srv_ref].[srv_domain] AS [srv_domain_ref],
	[srv_ref].[srv_fullname] AS [srv_fullname_ref],
	[adp_antivirus_server_id],
	[srv_av].[srv_hostname] AS [srv_hostname_av],
	[srv_av].[srv_domain] AS [srv_domain_av],
	[srv_av].[srv_fullname] AS [srv_fullname_av],
	[adp_kit_server_id],
	[srv_kit].[srv_hostname] AS [srv_hostname_kit],
	[srv_kit].[srv_domain] AS [srv_domain_kit],
	[srv_kit].[srv_fullname] AS [srv_fullname_kit],
	[adp_bank],
	[adp_federation],
	[adp_scope],
	[adp_slice],
	[adp_smssitecode],
	[adp_mtosenv]
	,(SELECT COUNT(distinct wks_id) FROM workstations WITH (NOLOCK) 
		INNER JOIN [dbo].[adspaths_imssites] on [wks_adspath_imssite_id] = [adpims_id] 
		WHERE wks_adspath_imssite_id = adpims_id) AS [nb_postes]
	FROM [dbo].[adspaths] WITH (NOLOCK)
	INNER JOIN [dbo].[adfederations] ON [adp_adfederation_id] = [adf_id]
	INNER JOIN [dbo].[adsites] ON [adp_adsite_id] = [ads_id]
	INNER JOIN [dbo].[addomains] ON [adp_addomain_id] = [add_id]
	INNER JOIN [dbo].[servers] [srv_ref] ON [adp_reference_server_id] = [srv_ref].[srv_id]
	INNER JOIN [dbo].[servers] [srv_kit] ON [adp_kit_server_id] = [srv_kit].[srv_id]
	INNER JOIN [dbo].[servers] [srv_av] ON [adp_antivirus_server_id] = [srv_av].[srv_id]

