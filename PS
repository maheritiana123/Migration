CREATE PROCEDURE [dbo].[batch_get_circular_references]
AS
BEGIN
    SET NOCOUNT ON
    
    SELECT DISTINCT
        fk1.TableName AS Table1,
        fk2.TableName AS Table2
    FROM 
        (SELECT OBJECT_NAME(parent_object_id) TableName, 
                OBJECT_NAME(referenced_object_id) ReferencedTable
         FROM sys.foreign_keys) fk1
    JOIN 
        (SELECT OBJECT_NAME(parent_object_id) TableName, 
                OBJECT_NAME(referenced_object_id) ReferencedTable
         FROM sys.foreign_keys) fk2
    ON fk1.TableName = fk2.ReferencedTable
    AND fk1.ReferencedTable = fk2.TableName
    WHERE fk1.TableName < fk2.TableName  -- Évite les doublons (A?B et B?A)
END
