CREATE PROCEDURE [dbo].[usp_select_workstation_printers]
	 @name AS VARCHAR(16)
	,@macaddress AS VARCHAR(max),
	@uuid AS VARCHAR(50)

AS
BEGIN

	SET NOCOUNT ON

	-- GET wks_id
	DECLARE @wks_id AS INT

	IF @macaddress IS NOT NULL
	BEGIN
		SELECT @wks_id = wks_id FROM dbo.workstations WITH (NOLOCK) WHERE wks_macaddress = @macaddress
	END
	ELSE
	BEGIN
		IF @uuid IS NOT NULL
		BEGIN
			SELECT @wks_id = wks_id FROM dbo.workstations WITH (NOLOCK) WHERE wks_uuid = @uuid
		END
	END

	IF @wks_id IS NULL
	BEGIN
		SELECT @wks_id = [name_workstation_id]
		FROM dbo.names WITH (NOLOCK)
		WHERE name_name = @name
	END
	
	-- USBPRINTER
	SELECT usb_mat_productcode,usb_duplex FROM [dbo].[usbprinters] WITH (NOLOCK)
	WHERE usb_workstation_id = @wks_id
		
	-- LOCALPRINTER
	SELECT loc_mat_productcode,loc_duplex FROM [dbo].[localprinters] WITH (NOLOCK)
	WHERE loc_workstation_id = @wks_id
		
	-- ILSPRINTER
	SELECT ils_mat_productcode,ils_duplex,ils_ipaddress FROM [dbo].[ilsprinters] WITH (NOLOCK)
	WHERE ils_workstation_id = @wks_id
		
	-- NETWORKPRINTERS
	SELECT '\\' + (SELECT srv_fullname FROM [dbo].[servers] WITH (NOLOCK) WHERE srv_id = prn_server_id) + '\' + prn_name AS prn_name
	FROM [dbo].[networkprinters_view] WITH (NOLOCK)
	WHERE net_workstation_id = @wks_id
	ORDER BY net_position ASC
	
	-- SECUREDPRINTER
	SELECT secured_mapped,secured_default FROM [dbo].[securedprinters] WITH (NOLOCK)
	WHERE secured_workstation_id = @wks_id
	
	-- IMPRIMANTE PAR DEFAUT
	SELECT
	CASE
	WHEN EXISTS(SELECT * FROM [dbo].[usbprinters] WITH (NOLOCK) WHERE usb_workstation_id = @wks_id AND usb_default = 1) THEN 'usbprinter'
	WHEN EXISTS(SELECT * FROM [dbo].[localprinters] WITH (NOLOCK) WHERE loc_workstation_id = @wks_id AND loc_default = 1) THEN 'localprinter'
	WHEN EXISTS(SELECT * FROM [dbo].[networkprinters_view] WITH (NOLOCK) WHERE net_workstation_id = @wks_id AND net_default = 1) THEN (SELECT TOP 1 '\\' + srv_fullname + '\' + prn_name FROM [dbo].[networkprinters_view] WITH (NOLOCK) INNER JOIN [dbo].[servers] WITH (NOLOCK) ON prn_server_id = srv_id WHERE net_default = 1 AND net_workstation_id = @wks_id)
	WHEN (SELECT wks_auto_default_printer FROM [dbo].[workstations] WITH (NOLOCK) WHERE wks_id = @wks_id) = '1' THEN 
		CASE 
	WHEN EXISTS(SELECT * FROM [dbo].[usbprinters] WITH (NOLOCK) WHERE usb_workstation_id = @wks_id) THEN 'usbprinter'
	WHEN EXISTS(SELECT * FROM [dbo].[localprinters] WITH (NOLOCK) WHERE loc_workstation_id = @wks_id) THEN 'localprinter'
	WHEN EXISTS(SELECT * FROM [dbo].[networkprinters_view] WITH (NOLOCK) WHERE net_workstation_id = @wks_id) THEN (SELECT TOP 1 '\\' + srv_fullname + '\' + prn_name FROM [dbo].[networkprinters_view] WITH (NOLOCK) INNER JOIN [dbo].[servers] WITH (NOLOCK) ON prn_server_id = srv_id WHERE net_workstation_id = @wks_id ORDER BY net_position ASC)
		END
	ELSE 'none' END AS [default]

END
GO
