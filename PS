CREATE PROCEDURE [dbo].[usp_delete_associated_device]
	@assoc_id AS INT = NULL,
	@assoc_remote_id AS INT = NULL,
	@assoc_local_id AS INT = NULL,
	@assoc_remote_pxesite AS NVARCHAR(MAX)= NULL,
	@insert_event AS BIT
AS
BEGIN

	SET NOCOUNT ON
	DECLARE @assoc_remote_name AS nvarchar(16) = NULL;
	
	--on sélectionne toutes les variables dont on a besoin pour la suite.
	IF @assoc_id IS NOT NULL
	BEGIN
	
		SELECT @assoc_local_id = assoc_local_workstation_id, @assoc_remote_id = assoc_remote_workstation_id, @assoc_remote_pxesite =assoc_remote_pxesite,
		@assoc_remote_name = assoc_remote_name
		FROM [dbo].[associated_devices]
		WHERE assoc_id = @assoc_id;		
	END
	ELSE
	BEGIN
		IF (@assoc_remote_id IS NOT NULL AND @assoc_local_id IS NOT NULL AND @assoc_remote_pxesite IS NOT NULL) 
		BEGIN
			SELECT @assoc_id = assoc_id, @assoc_local_id = assoc_local_workstation_id, @assoc_remote_id = assoc_remote_workstation_id, @assoc_remote_pxesite =assoc_remote_pxesite,
			@assoc_remote_name = assoc_remote_name
			FROM [dbo].[associated_devices]
			WHERE assoc_remote_workstation_id = @assoc_remote_id
			AND assoc_local_workstation_id = @assoc_local_id
			AND assoc_remote_pxesite = @assoc_remote_pxesite;			
		END
	END
	
	--on insere l'evenement si on a trouvé une ligne et que l'appelant demande une insertion d'event
	IF @insert_event IS NOT NULL AND @insert_event = 1 AND @assoc_remote_name IS NOT NULL  
	BEGIN
		DECLARE @message as NVARCHAR(MAX);
		select @message = 'Association with workstation ' + @assoc_remote_name + ' deleted';
		
		DECLARE @user as NVARCHAR(MAX);
		select @user = 'PXE_'+@assoc_remote_pxesite;

		EXEC [dbo].[usp_insert_event2]
			@evc_name = N'DELETE_WORKSTATION_ASSOCIATION',
			@evt_data = NULL,
			@evt_message = @message,
			@evt_source = N'WEB',
			@evt_timegenerated = NULL,
			@evt_user = @user ,
			@wks_id = @assoc_local_id,
			@evt_justificatif = null;
	END
	
	--on supprime la ligne
	IF @assoc_remote_id IS NOT NULL
	BEGIN 
		DELETE FROM [dbo].[associated_devices]
		WHERE assoc_id = @assoc_id;
	END
	
END
