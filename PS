	INNER JOIN [dbo].[addomains] WITH (NOLOCK) ON [addomains].[add_id] = [adspaths].[adp_addomain_id]
	INNER JOIN [dbo].[adfederations] WITH (NOLOCK) ON [adfederations].[adf_id] = [adspaths].[adp_adfederation_id]
