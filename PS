	from adspath ad
	inner join (select srvname, srvid from srv) as pxesrv on ad.Srv_Pxe_Id = pxesrv.srvid
	inner join (select srvname, srvid from srv) as avsrv on ad.Srv_Av_Id = avsrv.srvid
	inner join (select srvname, srvid from srv) as smssrv on ad.Srv_Sms_Id = smssrv.srvid
	inner join (select srvname, srvid from srv) as snasrv on ad.Srv_Sna_Id = snasrv.srvid
	inner join bank a on ad.Code_Bank_Id = a.Bank_Id
	inner join prefix c on ad.Prefix_Id = c.Prefix_Id
	inner join federation d on d.Federation_Id = ad.Code_Fede_Id
	inner join perimeter e on ad.Perimeter_Id = e.Perimeter_Id
	left outer join SMSSITECODE f on f.Sms_Site_Id = ad.Code_Sms_Id
	inner join AD_DOMAIN g on ad.Adspath_Domain_Id = g.Ad_Domain_Id
	inner join AD_SITE_LOCATION h on ad.Adspath_Site_Id = h.Ad_Site_Id
