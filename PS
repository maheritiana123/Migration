CREATE FUNCTION [dbo].[fct_enum_servers]()
RETURNS TABLE
AS
RETURN
(
	SELECT [srv].[srvid], [s2].[srvname], [s2].[adspath.srv_av_id], [s2].[adspath.srv_pxe_id], [s2].[poste.pokitid],
		[s2].[poste.popxeid], [s2].[sassrv.pxeid], [s2].[srv_imp.imp_id], [s2].[srv_imp.srv_id], [s2].[WPImpDef],
		[s2].[WPPPrinterName], [s2].[WPRPrinterName], [s2].[WPRPrinterName2], [s2].[WPRPrinterName3],
		[s2].[adspath.srv_av_id] + [s2].[adspath.srv_pxe_id] + [s2].[poste.pokitid] + [s2].[poste.popxeid] +
		[s2].[sassrv.pxeid] + [s2].[srv_imp.imp_id] + [s2].[srv_imp.srv_id] + [s2].[WPImpDef] + [s2].[WPPPrinterName] +
		[s2].[WPRPrinterName] + [s2].[WPRPrinterName2] + [s2].[WPRPrinterName3] AS [references]
	FROM (
		SELECT [srvname], SUM([adspath.srv_av_id]) AS [adspath.srv_av_id], SUM([adspath.srv_pxe_id]) AS [adspath.srv_pxe_id],
			SUM ([poste.pokitid]) AS [poste.pokitid], SUM([poste.popxeid]) AS [poste.popxeid], SUM([sassrv.pxeid]) AS [sassrv.pxeid],
			SUM([srv_imp.imp_id]) AS [srv_imp.imp_id], SUM([srv_imp.srv_id]) AS [srv_imp.srv_id],SUM(WPImpDef) AS [WPImpDef], SUM([WPPPrinterName]) AS [WPPPrinterName],
			SUM([WPRPrinterName]) AS [WPRPrinterName], SUM([WPRPrinterName2]) AS [WPRPrinterName2], SUM([WPRPrinterName3]) AS [WPRPrinterName3]
		FROM (
			SELECT [srvname], 0 AS [adspath.srv_av_id], 0 AS [adspath.srv_pxe_id], 0 AS [poste.pokitid],
				0 AS [poste.popxeid], 0 AS [sassrv.pxeid], 0 AS [srv_imp.imp_id], 0 AS [srv_imp.srv_id], 0 AS [WPImpDef],
				0 AS [WPPPrinterName], 0 AS [WPRPrinterName], 0 AS [WPRPrinterName2], 0 AS [WPRPrinterName3]
			FROM [dbo].[srv] WITH (NOLOCK)

			UNION
			SELECT [srvname], COUNT(*) AS [adspath.srv_av_id], 0 AS [adspath.srv_pxe_id], 0 AS [poste.pokitid],
				0 AS [poste.popxeid], 0 AS [sassrv.pxeid], 0 AS [srv_imp.imp_id], 0 AS [srv_imp.srv_id], 0 AS [WPImpDef],
				0 AS [WPPPrinterName], 0 AS [WPRPrinterName], 0 AS [WPRPrinterName2], 0 AS [WPRPrinterName3]
			FROM [dbo].[srv] WITH (NOLOCK)
			INNER JOIN [dbo].[adspath] WITH (NOLOCK) ON [adspath].[srv_av_id] = [srv].[srvid]
			GROUP BY [srvname]

			UNION
			SELECT [srvname], 0 AS [adspath.srv_av_id], COUNT(*) AS [adspath.srv_pxe_id], 0 AS [poste.pokitid],
				0 AS [poste.popxeid], 0 AS [sassrv.pxeid], 0 AS [srv_imp.imp_id], 0 AS [srv_imp.srv_id], 0 AS [WPImpDef],
				0 AS [WPPPrinterName], 0 AS [WPRPrinterName], 0 AS [WPRPrinterName2], 0 AS [WPRPrinterName3]
			FROM [dbo].[srv] WITH (NOLOCK)
			INNER JOIN [dbo].[adspath] WITH (NOLOCK) ON [adspath].[srv_pxe_id] = [srv].[srvid]
			GROUP BY [srvname]

			UNION
			SELECT [srvname], 0 AS [adspath.srv_av_id], 0 AS [adspath.srv_pxe_id], COUNT(*) AS [poste.pokitid],
				0 AS [poste.popxeid], 0 AS [sassrv.pxeid], 0 AS [srv_imp.imp_id], 0 AS [srv_imp.srv_id], 0 AS [WPImpDef],
				0 AS [WPPPrinterName], 0 AS [WPRPrinterName], 0 AS [WPRPrinterName2], 0 AS [WPRPrinterName3]
			FROM [dbo].[srv] WITH (NOLOCK)
			INNER JOIN [dbo].[poste] WITH (NOLOCK) ON [poste].[pokitid] = [srv].[srvid]
			GROUP BY [srvname]

			UNION
			SELECT [srvname], 0 AS [adspath.srv_av_id], 0 AS [adspath.srv_pxe_id], 0 AS [poste.pokitid],
				COUNT(*) AS [poste.popxeid], 0 AS [sassrv.pxeid], 0 AS [srv_imp.imp_id], 0 AS [srv_imp.srv_id], 0 AS [WPImpDef],
				0 AS [WPPPrinterName], 0 AS [WPRPrinterName], 0 AS [WPRPrinterName2], 0 AS [WPRPrinterName3]
			FROM [dbo].[srv] WITH (NOLOCK)
			INNER JOIN [dbo].[poste] WITH (NOLOCK) ON [poste].[popxeid] = [srv].[srvid]
			GROUP BY [srvname]

			UNION
			SELECT [srvname], 0 AS [adspath.srv_av_id], 0 AS [adspath.srv_pxe_id], 0 AS [poste.pokitid],
				0 AS [poste.popxeid], COUNT(*) AS [sassrv.pxeid], 0 AS [srv_imp.imp_id], 0 AS [srv_imp.srv_id], 0 AS [WPImpDef],
				0 AS [WPPPrinterName], 0 AS [WPRPrinterName], 0 AS [WPRPrinterName2], 0 AS [WPRPrinterName3]
			FROM [dbo].[srv] WITH (NOLOCK)
			INNER JOIN [dbo].[sassrv] WITH (NOLOCK) ON [sassrv].[pxeid] = [srv].[srvid]
			GROUP BY [srvname]

			UNION
			SELECT [srvname], 0 AS [adspath.srv_av_id], 0 AS [adspath.srv_pxe_id], 0 AS [poste.pokitid],
				0 AS [poste.popxeid], 0 AS [sassrv.pxeid], COUNT(*) AS [srv_imp.imp_id], 0 AS [srv_imp.srv_id], 0 AS [WPImpDef],
				0 AS [WPPPrinterName], 0 AS [WPRPrinterName], 0 AS [WPRPrinterName2], 0 AS [WPRPrinterName3]
			FROM [dbo].[srv] WITH (NOLOCK)
			INNER JOIN [dbo].[srv_imp] WITH (NOLOCK) ON [srv_imp].[imp_id] = [srv].[srvid]
			GROUP BY [srvname]

			UNION
			SELECT [srvname], 0 AS [adspath.srv_av_id], 0 AS [adspath.srv_pxe_id], 0 AS [poste.pokitid],
				0 AS [poste.popxeid], 0 AS [sassrv.pxeid], 0 AS [srv_imp.imp_id], COUNT(*) AS [srv_imp.srv_id], 0 AS [WPImpDef],
				0 AS [WPPPrinterName], 0 AS [WPRPrinterName], 0 AS [WPRPrinterName2], 0 AS [WPRPrinterName3]
			FROM [dbo].[srv] WITH (NOLOCK)
			INNER JOIN [dbo].[srv_imp] WITH (NOLOCK) ON [srv_imp].[srv_id] = [srv].[srvid]
			GROUP BY [srvname]

			UNION
			SELECT [srvname], 0 AS [adspath.srv_av_id], 0 AS [adspath.srv_pxe_id], 0 AS [poste.pokitid],
				0 AS [poste.popxeid], 0 AS [sassrv.pxeid], 0 AS [srv_imp.imp_id], 0 AS [srv_imp.srv_id], SUM(WPImpDef) AS [WPImpDef],
				SUM([WPPPrinterName]) AS [WPPPrinterName], SUM([WPRPrinterName]) AS [WPRPrinterName],
				SUM ([WPRPrinterName2]) AS [WPRPrinterName2], SUM([WPRPrinterName3]) AS [WPRPrinterName3]
			FROM [dbo].[fct_enum_printers]()
			GROUP BY [srvname]
			) AS [s1]
		GROUP BY [srvname]) AS [s2]
	LEFT JOIN [dbo].[srv] WITH (NOLOCK) ON [srv].[srvname] = [s2].[srvname]
)
GO
