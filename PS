CREATE FUNCTION [dbo].[fct_enum_imssites]()
RETURNS TABLE
AS
RETURN
(
	SELECT [imssite].[imsid], [s2].[imsname], [WPPUSitePCOM1], [WPPUSitePCOM2],
		[WPPUSitePCOM3], [WPPuSiteRobolook1], [WPPuSiteRobolook2]
	FROM (
		SELECT [imsname], SUM([WPPUSitePCOM1]) AS [WPPUSitePCOM1], SUM([WPPUSitePCOM2]) AS [WPPUSitePCOM2],
			SUM([WPPUSitePCOM3]) AS [WPPUSitePCOM3], SUM([WPPuSiteRobolook1]) AS [WPPuSiteRobolook1],
			SUM([WPPuSiteRobolook2]) AS [WPPuSiteRobolook2]
		FROM (
			SELECT [imsname], 0 AS [WPPUSitePCOM1], 0 AS [WPPUSitePCOM2], 0 AS WPPUSitePCOM3, 0 AS [WPPuSiteRobolook1], 0 AS [WPPuSiteRobolook2]
			FROM [dbo].[imssite] WITH (NOLOCK)

			UNION
			SELECT [pv1].[pvevaleur] AS [imsname], COUNT(*) AS [WPPUSitePCOM1], 0 AS [WPPUSitePCOM2], 0 AS WPPUSitePCOM3, 0 AS [WPPuSiteRobolook1], 0 AS [WPPuSiteRobolook2]
			FROM [dbo].[postevarenv] AS [pv1] WITH (NOLOCK)
			INNER JOIN [dbo].[postevarenv] AS [pv2] WITH (NOLOCK) ON (
					  [pv2].[pvepoid] = [pv1].[pvepoid]
				  AND [pv2].[pveveid] = (SELECT [veid] FROM [dbo].[varenv] WITH (NOLOCK) WHERE [venom] = 'WPPCOM1')
				  AND [pv2].[pvevaleur] = 'O')
			WHERE [pv1].[pveveid] = (SELECT [veid] FROM [dbo].[varenv] WITH (NOLOCK) WHERE [venom] = 'WPPUSitePCOM1')
			GROUP BY [pv1].[pvevaleur]

			UNION
			SELECT [pv1].[pvevaleur] AS [imsname], 0 AS [WPPUSitePCOM1], COUNT(*) AS [WPPUSitePCOM2], 0 AS WPPUSitePCOM3, 0 AS [WPPuSiteRobolook1], 0 AS [WPPuSiteRobolook2]
			FROM [dbo].[postevarenv] AS [pv1] WITH (NOLOCK)
			INNER JOIN [dbo].[postevarenv] AS [pv2] WITH (NOLOCK) ON (
					  [pv2].[pvepoid] = [pv1].[pvepoid]
				  AND [pv2].[pveveid] = (SELECT [veid] FROM [dbo].[varenv] WITH (NOLOCK) WHERE [venom] = 'WPPCOM2')
				  AND [pv2].[pvevaleur] = 'O')
			WHERE [pv1].[pveveid] = (SELECT [veid] FROM [dbo].[varenv] WITH (NOLOCK) WHERE [venom] = 'WPPUSitePCOM2')
			GROUP BY [pv1].[pvevaleur]

			UNION
			SELECT [pv1].[pvevaleur] AS [imsname], 0 AS [WPPUSitePCOM1], 0 AS [WPPUSitePCOM2], COUNT(*) AS WPPUSitePCOM3, 0 AS [WPPuSiteRobolook1], 0 AS [WPPuSiteRobolook2]
			FROM [dbo].[postevarenv] AS [pv1] WITH (NOLOCK)
			INNER JOIN [dbo].[postevarenv] AS [pv2] WITH (NOLOCK) ON (
					  [pv2].[pvepoid] = [pv1].[pvepoid]
				  AND [pv2].[pveveid] = (SELECT [veid] FROM [dbo].[varenv] WITH (NOLOCK) WHERE [venom] = 'WPPCOM3')
				  AND [pv2].[pvevaleur] = 'O')
			WHERE [pv1].[pveveid] = (SELECT [veid] FROM [dbo].[varenv] WITH (NOLOCK) WHERE [venom] = 'WPPUSitePCOM3')
			GROUP BY [pv1].[pvevaleur]

			UNION
			SELECT [pv1].[pvevaleur] AS [imsname], 0 AS [WPPUSitePCOM1], 0 AS [WPPUSitePCOM2], 0 AS WPPUSitePCOM3, COUNT(*) AS [WPPuSiteRobolook1], 0 AS [WPPuSiteRobolook2]
			FROM [dbo].[postevarenv] AS [pv1] WITH (NOLOCK)
			INNER JOIN [dbo].[postevarenv] AS [pv2] WITH (NOLOCK) ON (
					  [pv2].[pvepoid] = [pv1].[pvepoid]
				  AND [pv2].[pveveid] = (SELECT [veid] FROM [dbo].[varenv] WITH (NOLOCK) WHERE [venom] = 'WPRobolook1')
				  AND [pv2].[pvevaleur] = 'O')
			WHERE [pv1].[pveveid] = (SELECT [veid] FROM [dbo].[varenv] WITH (NOLOCK) WHERE [venom] = 'WPPuSiteRobolook1')
			GROUP BY [pv1].[pvevaleur]

			UNION
			SELECT [pv1].[pvevaleur] AS [imsname], 0 AS [WPPUSitePCOM1], 0 AS [WPPUSitePCOM2], 0 AS WPPUSitePCOM3, 0 AS [WPPuSiteRobolook1], COUNT(*) AS [WPPuSiteRobolook2]
			FROM [dbo].[postevarenv] AS [pv1] WITH (NOLOCK)
			INNER JOIN [dbo].[postevarenv] AS [pv2] WITH (NOLOCK) ON (
					  [pv2].[pvepoid] = [pv1].[pvepoid]
				  AND [pv2].[pveveid] = (SELECT [veid] FROM [dbo].[varenv] WITH (NOLOCK) WHERE [venom] = 'WPRobolook2')
				  AND [pv2].[pvevaleur] = 'O')
			WHERE [pv1].[pveveid] = (SELECT [veid] FROM [dbo].[varenv] WITH (NOLOCK) WHERE [venom] = 'WPPuSiteRobolook2')
			GROUP BY [pv1].[pvevaleur]) AS [s1]
		GROUP BY [s1].[imsname]) AS [s2]
	LEFT JOIN [dbo].[imssite] WITH (NOLOCK) ON [imssite].[imsname] = [s2].[imsname]
)
GO
