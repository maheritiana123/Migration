CREATE FUNCTION [dbo].[fct_extract_hostname](
	@fullname VARCHAR(MAX))
RETURNS VARCHAR(MAX)
AS
BEGIN
	RETURN SUBSTRING(@fullname, 1, CASE CHARINDEX('.', @fullname) WHEN 0 THEN LEN(@fullname) ELSE CHARINDEX('.', @fullname) - 1 END)
END
