			IF @fnid IS NOT NULL AND @IERREUR = 0 UPDATE ADPATH SET CFEDENAMEID = @fnid WHERE ADID = @adid AND ADPXEID = @pxeid
		END
		IF (@type='CFEDE')
		BEGIN
			IF EXISTS(SELECT CFEDEID FROM AD_CFEDE WHERE CFEDE = @value)
			BEGIN
				SELECT @fid= (SELECT CFEDEID FROM AD_CFEDE WHERE CFEDE = LTRIM(RTRIM(@value)));	
			END
			ELSE
			BEGIN
				INSERT INTO AD_CFEDE(CFEDE) VALUES(@value);
				SELECT @fid = @@IDENTITY;
			END
			SET @IERREUR = @IERREUR + @@ERROR;
			
			-- update de valeur pour l'ad
			IF @fid IS NOT NULL AND @IERREUR = 0 UPDATE ADPATH SET CFEDEID = @fid WHERE ADID = @adid AND ADPXEID = @pxeid
		END
		IF (@type='PERIM')
		BEGIN
			IF EXISTS(SELECT PERIMID FROM AD_PERIM WHERE PERIM = @value)
			BEGIN
				SELECT @pmid= (SELECT PERIMID FROM AD_PERIM WHERE PERIM = LTRIM(RTRIM(@value)));	
			END
			ELSE
			BEGIN
				INSERT INTO AD_PERIM(PERIM) VALUES(@value);
				SELECT @pmid = @@IDENTITY;
			END
			SET @IERREUR = @IERREUR + @@ERROR;
			
			-- update de valeur pour l'ad
			IF @pmid IS NOT NULL AND @IERREUR = 0 UPDATE ADPATH SET PERIMID = @pmid WHERE ADID = @adid AND ADPXEID = @pxeid
		END
		IF (@type='SMSCODE')
		BEGIN
			IF EXISTS(SELECT SMSCODEID FROM AD_SMSSITECODE WHERE SMSCODE = @value)
			BEGIN
				SELECT @smscodeid= (SELECT SMSCODEID FROM AD_SMSSITECODE WHERE SMSCODE = LTRIM(RTRIM(@value)));	
			END
			ELSE
			BEGIN
				INSERT INTO AD_SMSSITECODE(SMSCODE) VALUES(@value);
				SELECT @smscodeid = @@IDENTITY;
			END
			SET @IERREUR = @IERREUR + @@ERROR;
			
			-- update de valeur pour l'ad
			IF @smscodeid IS NOT NULL AND @IERREUR = 0 UPDATE ADPATH SET SMSCODEID = @smscodeid WHERE ADID = @adid AND ADPXEID = @pxeid
		END
	SET @IERREUR = @IERREUR + @@ERROR;
	SELECT @IERREUR as result;
END
