IF EXISTS(SELECT * FROM ADSPATH WHERE Srv_Pxe_Id=@PxeId AND Adspath_Federation_Id=@FedeId AND Adspath_Site_Id=@SiteId AND Adspath_Domain_Id=@DomId AND Adspath_Id <> @AdsPathId) 
BEGIN
  -- probléme l'adspath existe déja pour le serveur PXE et ses entités
	IF @@TRANCOUNT > 0 ROLLBACK TRANSACTION;
	
	SELECT 0 AS RESULT;
END
ELSE
BEGIN
	UPDATE ADSPATH
		SET [Adspath_Federation_Id] = @FedeId,
			[Adspath_Site_Id] = @SiteId,
			[Adspath_Domain_Id] = @DomId,
			[Prefix_Id] = @PrefixId,
			[Perimeter_Id] = @PerimeterId,
			[Srv_Pxe_Id] = @PxeId,
			[Srv_Av_Id] = @AvId,
			[Srv_Sms_Id] = @SMSId,
			[Srv_Sna_Id] = @SNAId,
			[Code_Fede_Id] = @CodeFedeId,
			[Code_Bank_Id] = @CodeBankId,
			[Code_Sms_Id] = @CodeSmsId
	WHERE [Adspath_Id] = @AdsPathId
	
	COMMIT TRANSACTION;

	SELECT @AdsPathId AS RESULT;
END

END TRY
BEGIN CATCH

	IF @@TRANCOUNT > 0 ROLLBACK TRANSACTION;

	SELECT ERROR_NUMBER() AS ErrorNumber,
	ERROR_SEVERITY() AS ErrorSeverity,
	ERROR_STATE() AS ErrorState,
	ERROR_PROCEDURE() AS ErrorProcedure,
	ERROR_LINE() AS ErrorLine,
	ERROR_MESSAGE() AS ErrorMessage;

END CATCH
END
