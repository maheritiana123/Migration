CREATE PROCEDURE [dbo].[ACTUVARTECH] @VARNAME AS NVARCHAR(100), @VARVALUE AS NVARCHAR(100), @POID AS INT , @PONAME AS NVARCHAR(20) AS
BEGIN
	DECLARE @REQUEST NVARCHAR (1024)
	DECLARE @SRVID AS INT
	
	-- si id poste absent, recherche d'après le nom
	IF @POID = 0
	BEGIN
		SELECT @POID = poid from poste where ponom = @PONAME
	END 

	if @VARNAME = 'POETAT' OR @VARNAME = 'POPOSTBIOS'
	BEGIN
		IF @VARNAME = 'POETAT' 
		BEGIN
			SELECT @REQUEST='UPDATE POSTE SET POETAT=' + @VARVALUE + ', POSTATEDATE = getdate() WHERE POID='+ cast(@POID as nvarchar(8))
		END
		ELSE
		BEGIN
			SELECT @REQUEST='UPDATE POSTE SET '+ @VARNAME + '=' + @VARVALUE + ' WHERE POID='+ cast(@POID as nvarchar(8))
		END
	END
	ELSE
	BEGIN
		IF @VARNAME = 'POSRVKIT' or @VARNAME = 'POSRVNAME'
		BEGIN
			IF @VARNAME = 'POSRVKIT' AND CHARINDEX('.',@VARVALUE,1) <> 0
			BEGIN
				EXEC [dbo].[UPDATE_SRV] @VARVALUE, @SRVID OUT
				SELECT @REQUEST='UPDATE POSTE SET POKITID=' + cast(@SRVID as nvarchar(8)) + ' WHERE POID='+ cast(@POID as nvarchar(8))
			END
			
			-- possibilité actu srvname pxe cas agence changement de serveur
			IF @VARNAME = 'POSRVNAME' AND CHARINDEX('.',@VARVALUE,1) <> 0
			BEGIN
				EXEC [dbo].[UPDATE_SRV] @VARVALUE, @SRVID OUT
				SELECT @REQUEST='UPDATE POSTE SET POPXEID=' + cast(@SRVID as nvarchar(8)) + ' WHERE POID='+ cast(@POID as nvarchar(8)) + ' AND POADSIMSID IS NULL'
			END
			
		END
		ELSE
		BEGIN
			SELECT @REQUEST='UPDATE POSTE SET '+ @VARNAME + '=''' + @VARVALUE + ''' WHERE POID=' + cast(@POID as nvarchar(8))
		END
	END
	EXEC(@REQUEST)
	SELECT @@ROWCOUNT as result
	
	-- Gestion des erreurs
	if (@@ERROR <> 0)
	BEGIN
		RAISERROR('Origine: SP ACTUVARTECH - Erreur: %d', 18, 1, @@error)
	END
END
GO
