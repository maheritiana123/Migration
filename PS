CREATE FUNCTION [dbo].[fct_get_technical_variables] (@wks_id [INT])
RETURNS @variables TABLE([key] [NVARCHAR](MAX), [value] [NVARCHAR](MAX))
AS
BEGIN

	-- Variables internes
	DECLARE @ReferenceServerID [INT]

	-- Variables techniques
	DECLARE @PFTLSNAFarm [INT]
	DECLARE @PFTLSNAFarmPCOM [INT]
	DECLARE @WPCodeBanque [NVARCHAR](MAX)
	DECLARE @WPCodeBanqueComptable [NVARCHAR](MAX)
	DECLARE @WPCodeBureau [NVARCHAR](MAX)
	DECLARE @WPCodeBureauComptable [NVARCHAR](MAX)
	DECLARE @WPCodeCaisse [NVARCHAR](MAX)
	DECLARE @WPCodeCaisseComptable [NVARCHAR](MAX)
	DECLARE @WPCodeFede [NVARCHAR](MAX)
	DECLARE @WPCodeFedeComptable [NVARCHAR](MAX)
	DECLARE @WPCodePVA [NVARCHAR](MAX)
	DECLARE @WPCodePVAComptable [NVARCHAR](MAX)
	DECLARE @WPCodeSection [NVARCHAR](MAX)
	DECLARE @WPDomaine [NVARCHAR](MAX)
	DECLARE @WPHKGEDScan [NVARCHAR](MAX)
	DECLARE @WPIIP [NVARCHAR](MAX)
	DECLARE @WPImpILS [NVARCHAR](MAX)
	DECLARE @WPImpLocal [NVARCHAR](MAX)
	DECLARE @WPImpUsb [NVARCHAR](MAX)
	DECLARE @WPIPrinterTER [NVARCHAR](MAX)
	DECLARE @WPIPrinterVerso [NVARCHAR](MAX)
	DECLARE @WPLecteurILS [NVARCHAR](MAX)
	DECLARE @WPLPrinterTER [NVARCHAR](MAX)
	DECLARE @WPLRectoVerso [NVARCHAR](MAX)
	DECLARE @WPNumeroComptable [NVARCHAR](MAX)
	DECLARE @WPNumStat [NVARCHAR](MAX)
	DECLARE @WPOS [NVARCHAR](MAX)
	DECLARE @WPPCom1 [NVARCHAR](MAX)
	DECLARE @WPPCom2 [NVARCHAR](MAX)
	DECLARE @WPPCom3 [NVARCHAR](MAX)
	DECLARE @WPPED [NVARCHAR](MAX)
	DECLARE @WPPosteFede [NVARCHAR](MAX)
	DECLARE @WPPostNumber [NVARCHAR](MAX)
	DECLARE @WPPuName [NVARCHAR](MAX)
	DECLARE @WPPuSitePCom1 [NVARCHAR](MAX)
	DECLARE @WPPuSitePCom2 [NVARCHAR](MAX)
	DECLARE @WPPuSitePCom3 [NVARCHAR](MAX)
	DECLARE @WPPuSiteRobolook1 [NVARCHAR](MAX)
	DECLARE @WPPuSiteRobolook2 [NVARCHAR](MAX)
	DECLARE @WPRobolook1 [NVARCHAR](MAX)
	DECLARE @WPRobolook2 [NVARCHAR](MAX)
	DECLARE @WPScanSNDP [NVARCHAR](MAX)
	DECLARE @WPSiteIms [NVARCHAR](MAX)
	DECLARE @WPSMSSiteCode [NVARCHAR](MAX)
	DECLARE @WPSrvAgence [NVARCHAR](MAX)
	DECLARE @WPSrvAV [NVARCHAR](MAX)
	DECLARE @WPSrvPivot [NVARCHAR](MAX)
	DECLARE @WPSrvPXE [NVARCHAR](MAX)
	DECLARE @WPSrvTel [NVARCHAR](MAX)
	DECLARE @WPTER [NVARCHAR](MAX)
	DECLARE @WPTERGEDSCAN [NVARCHAR](MAX)
	DECLARE @WPUPrinterTER [NVARCHAR](MAX)
	DECLARE @WPURectoVerso [NVARCHAR](MAX)

	-- Recherche dans 'workstations'
	SELECT @PFTLSNAFarm = [workstations].[wks_rblk_mode],
	       @PFTLSNAFarmPCOM = [workstations].[wks_pcom_mode],
	       @ReferenceServerID = [workstations].[wks_pxe_server_id],
	       @WPCodeBanqueComptable = [workstations].[wks_accounting_bank],
	       @WPCodeBureauComptable = [workstations].[wks_accounting_office],
	       @WPCodeCaisseComptable = [workstations].[wks_accounting_branch],
		   @WPCodeFedeComptable = [workstations].[wks_accounting_federation],
		   @WPCodePVAComptable = [workstations].[wks_accounting_pva],
		   @WPCodeSection = [workstations].[wks_section],
	       @WPImpILS = 'N',
	       @WPImpLocal = 'N',
	       @WPImpUsb = 'N',
	       @WPNumeroComptable = [workstations].[wks_accounting_number],
	       @WPNumStat = CASE WHEN [workstations].[wks_adspath_imssite_id] IS NULL THEN
	                    	CASE WHEN SUBSTRING([names].[name_name], 1, 5) = 'WSDEP'
	                    		THEN SUBSTRING([names].[name_name], LEN([names].[name_name]) - 2, LEN([names].[name_name]))
	                    		ELSE SUBSTRING([names].[name_name], LEN([names].[name_name]) - 1, LEN([names].[name_name])) END END,
	       @WPOS = [workstations].[wks_kit_operating_system],
	       @WPPCom1 = CASE WHEN [workstations].[wks_pcom_ses1_imssite_id] IS NULL THEN 'N' ELSE 'O' END,
	       @WPPCom2 = CASE WHEN [workstations].[wks_pcom_ses2_imssite_id] IS NULL THEN 'N' ELSE 'O' END,
	       @WPPCom3 = CASE WHEN [workstations].[wks_pcom_ses3_imssite_id] IS NULL THEN 'N' ELSE 'O' END,
	       @WPPED = CASE WHEN [workstations].[wks_remote] = 1 THEN 'O' ELSE 'N' END,
	       @WPPostNumber = SUBSTRING([names].[name_name], LEN([names].[name_name]) - 2, LEN([names].[name_name])),
	       @WPPuSitePCom1 = [imssites_pcom_ses1].[ims_name],
	       @WPPuSitePCom2 = [imssites_pcom_ses2].[ims_name],
	       @WPPuSitePCom3 = [imssites_pcom_ses3].[ims_name],
	       @WPPuSiteRobolook1 = [imssites_robolook_ses1].[ims_name],
	       @WPPuSiteRobolook2 = [imssites_robolook_ses2].[ims_name],
	       @WPRobolook1 = CASE WHEN [workstations].[wks_rblk_ses1_imssite_id] IS NULL THEN 'N' ELSE 'O' END,
	       @WPRobolook2 = CASE WHEN [workstations].[wks_rblk_ses2_imssite_id] IS NULL THEN 'N' ELSE 'O' END,
	       @WPScanSNDP = CASE WHEN [workstations].[wks_sndpscanner] = 1 THEN 'O' ELSE 'N' END,
	       @WPTER = [workstations].[wks_mat_barcode]
	FROM [dbo].[workstations] WITH (NOLOCK)
	LEFT JOIN [dbo].[imssites] AS [imssites_pcom_ses1] WITH (NOLOCK) ON [imssites_pcom_ses1].[ims_id] = [workstations].[wks_pcom_ses1_imssite_id]
	LEFT JOIN [dbo].[imssites] AS [imssites_pcom_ses2] WITH (NOLOCK) ON [imssites_pcom_ses2].[ims_id] = [workstations].[wks_pcom_ses2_imssite_id]
	LEFT JOIN [dbo].[imssites] AS [imssites_pcom_ses3] WITH (NOLOCK) ON [imssites_pcom_ses3].[ims_id] = [workstations].[wks_pcom_ses3_imssite_id]
	LEFT JOIN [dbo].[imssites] AS [imssites_robolook_ses1] WITH (NOLOCK) ON [imssites_robolook_ses1].[ims_id] = [workstations].[wks_rblk_ses1_imssite_id]
	LEFT JOIN [dbo].[imssites] AS [imssites_robolook_ses2] WITH (NOLOCK) ON [imssites_robolook_ses2].[ims_id] = [workstations].[wks_rblk_ses2_imssite_id]
	LEFT JOIN [dbo].[names] WITH (NOLOCK) ON [names].[name_workstation_id] = [workstations].[wks_id]
	WHERE [wks_id] = @wks_id

	-- Recherche dans 'adspaths'
	SELECT @ReferenceServerID = [servers_reference].[srv_id],
	       @WPCodeBanque = [adspaths].[adp_bank],
	       @WPCodeFede = [adspaths].[adp_federation],
	       @WPDomaine = [addomains].[add_name],
	       @WPPosteFede = [adspaths].[adp_slice],
	       @WPSiteIms = [imssites].[ims_name],
	       @WPSMSSiteCode = [adspaths].[adp_smssitecode],
	       @WPSrvAV = [servers_antivirus].[srv_fullname],
	       @WPSrvPXE = [servers_reference].[srv_fullname]
	FROM [dbo].[workstations] WITH (NOLOCK)
	INNER JOIN [dbo].[adspaths_imssites] WITH (NOLOCK) ON [adspaths_imssites].[adpims_id] = [workstations].[wks_adspath_imssite_id]
	INNER JOIN [dbo].[adspaths] WITH (NOLOCK) ON [adspaths].[adp_id] = [adspaths_imssites].[adpims_adspath_id]
	INNER JOIN [dbo].[addomains] WITH (NOLOCK) ON [addomains].[add_id] = [adspaths].[adp_addomain_id]
	INNER JOIN [dbo].[imssites] WITH (NOLOCK) ON [imssites].[ims_id] = [adspaths_imssites].[adpims_imssite_id]
	INNER JOIN [dbo].[servers] AS [servers_antivirus] WITH (NOLOCK) ON [servers_antivirus].[srv_id] = [adspaths].[adp_antivirus_server_id]
	INNER JOIN [dbo].[servers] AS [servers_reference] WITH (NOLOCK) ON [servers_reference].[srv_id] = [adspaths].[adp_reference_server_id]
	WHERE [wks_id] = @wks_id

	-- Recherche dans 'gedscanners'
	SELECT @WPHKGEDScan = [ged_driver],
	       @WPTERGEDSCAN = [ged_mat_barcode]
	FROM [dbo].[gedscanners] WITH (NOLOCK)
	WHERE [ged_workstation_id] = @wks_id

	-- Recherche dans 'ilsprinters'
	SELECT @WPIIP = [ils_ipaddress],
	       @WPImpILS = 'O',
	       @WPIPrinterTER = [ils_mat_productcode],
	       @WPIPrinterVerso = CASE WHEN [ils_duplex] = 1 THEN 'O' ELSE 'N' END,
	       @WPLecteurILS  = [ils_cardreader]
	FROM [dbo].[ilsprinters] WITH (NOLOCK)
	WHERE [ils_workstation_id] = @wks_id

	-- Recherche dans 'localprinters'
	SELECT @WPImpLocal = 'O',
	       @WPLPrinterTER = [loc_mat_productcode],
	       @WPLRectoVerso = CASE WHEN [loc_duplex] = 1 THEN 'O' ELSE 'N' END
	FROM [dbo].[localprinters] WITH (NOLOCK)
	WHERE [loc_workstation_id] = @wks_id

	-- Recherche dans 'servers' si le poste n'est pas rangé dans un chemin AD
	SELECT @WPCodeBanque = [servers].[srv_wkit_codebanque],
	       @WPCodeBureau = [servers].[srv_wkit_codebureau],
	       @WPCodeCaisse = [servers].[srv_wkit_codecaisse],
	       @WPCodeFede = [servers].[srv_wkit_fede],
	       @WPDomaine = [servers].[srv_wkit_domain],
	       @WPSiteIMS = [servers].[srv_wkit_siteims],
	       @WPSMSSiteCode = [servers].[srv_wkit_srvsmsparentsitecode],
	       @WPSrvAV = [servers].[srv_wkit_srvav]
	FROM [dbo].[workstations] WITH (NOLOCK)
	INNER JOIN [dbo].[servers] WITH (NOLOCK) ON [servers].[srv_id] = [workstations].[wks_pxe_server_id]
	WHERE [workstations].[wks_id] = @wks_id AND [workstations].[wks_adspath_imssite_id] IS NULL

	-- Recherche dans 'servers' si le serveur de référence est de type 'AGENCE'
	SELECT @WPPostNumber = NULL,
	       @WPPuName = [servers].[srv_wkit_puname],
	       @WPSrvAgence = CASE WHEN [servers].[srv_wkit_srvnameold] IS NOT NULL AND LEN(LTRIM(RTRIM([servers].[srv_wkit_srvnameold]))) > 0
	                      	THEN [servers].[srv_wkit_srvnameold]
	                      	ELSE [servers].[srv_wkit_srvnamelong] END,
	       @WPSrvPivot = [servers].[srv_wkit_srvpivot],
	       @WPSrvPXE = @WPSrvAgence,
	       @WPSrvTel = [servers].[srv_wkit_ctisrvtel]
	FROM [dbo].[servers] WITH (NOLOCK)
	WHERE [servers].[srv_id] = @ReferenceServerID
	  AND [servers].[srv_wkit_isgence] = 'O'

	-- Recherche dans 'usbprinters'
	SELECT @WPImpUsb = 'O',
	       @WPUPrinterTER = [usb_mat_productcode],
	       @WPURectoVerso = CASE WHEN [usb_duplex] = 1 THEN 'O' ELSE 'N' END
	FROM [dbo].[usbprinters] WITH (NOLOCK)
	WHERE [usb_workstation_id] = @wks_id

	--on prend les valeurs du poste par défaut si elle sont saisies pour Fede, Banque, Caisse, Bureau, PVA (elles sont surchargées)
	SELECT 	@WPCodeBanque =  CASE WHEN [wks_bank] IS NOT NULL AND LEN([wks_bank])>0 THEN [wks_bank] ELSE @WPCodeBanque END,
			@WPCodeBureau =  CASE WHEN [wks_office] IS NOT NULL AND LEN([wks_office])>0 THEN [wks_office] ELSE @WPCodeBureau END,
			@WPCodeCaisse =  CASE WHEN [wks_branch] IS NOT NULL AND LEN([wks_branch])>0 THEN [wks_branch] ELSE @WPCodeCaisse END,
			@WPCodeFede =  CASE WHEN [wks_federation] IS NOT NULL AND LEN([wks_federation])>0 THEN [wks_federation] ELSE @WPCodeFede END,
			@WPCodePVA =  CASE WHEN [wks_pva] IS NOT NULL AND LEN([wks_pva])>0 THEN [wks_pva] ELSE @WPCodePVA END
	FROM [dbo].[workstations] WITH (NOLOCK)
	WHERE [workstations].[wks_id] = @wks_id;
	
	-- Insertion des variables dans la table retournée par la fonction
	IF @PFTLSNAFarm IS NOT NULL AND LEN(@PFTLSNAFarm) > 0 BEGIN INSERT INTO @variables ([key], [value]) VALUES ('PFTLSNAFarm', @PFTLSNAFarm) END
	IF @PFTLSNAFarmPCOM IS NOT NULL AND LEN(@PFTLSNAFarmPCOM) > 0 BEGIN INSERT INTO @variables ([key], [value]) VALUES ('PFTLSNAFarmPCOM', @PFTLSNAFarmPCOM) END
	IF @WPCodeBanque IS NOT NULL AND LEN(@WPCodeBanque) > 0 BEGIN INSERT INTO @variables ([key], [value]) VALUES ('WPCodeBanque', @WPCodeBanque) END
	IF @WPCodeBanqueComptable IS NOT NULL AND LEN(@WPCodeBanqueComptable) > 0 BEGIN INSERT INTO @variables ([key], [value]) VALUES ('WPCodeBanqueComptable', @WPCodeBanqueComptable) END
	IF @WPCodeBureau IS NOT NULL AND LEN(@WPCodeBureau) > 0 BEGIN INSERT INTO @variables ([key], [value]) VALUES ('WPCodeBureau', @WPCodeBureau) END
	IF @WPCodeBureauComptable IS NOT NULL AND LEN(@WPCodeBureauComptable) > 0 BEGIN INSERT INTO @variables ([key], [value]) VALUES ('WPCodeBureauComptable', @WPCodeBureauComptable) END
	IF @WPCodeCaisse IS NOT NULL AND LEN(@WPCodeCaisse) > 0 BEGIN INSERT INTO @variables ([key], [value]) VALUES ('WPCodeCaisse', @WPCodeCaisse) END
	IF @WPCodeCaisseComptable IS NOT NULL AND LEN(@WPCodeCaisseComptable) > 0 BEGIN INSERT INTO @variables ([key], [value]) VALUES ('WPCodeCaisseComptable', @WPCodeCaisseComptable) END
	IF @WPCodeFede IS NOT NULL AND LEN(@WPCodeFede) > 0 BEGIN INSERT INTO @variables ([key], [value]) VALUES ('WPCodeFede', @WPCodeFede) END
	IF @WPCodeFedeComptable IS NOT NULL AND LEN(@WPCodeFedeComptable) > 0 BEGIN INSERT INTO @variables ([key], [value]) VALUES ('WPCodeFedeComptable', @WPCodeFedeComptable) END
