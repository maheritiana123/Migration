CREATE PROCEDURE [dbo].[usp_getbootingdevice]
	@wks_macaddress [NVARCHAR](12),
	@server_pxe [NVARCHAR](MAX),
	@mode [NVARCHAR](MAX)
AS
BEGIN
	SET NOCOUNT ON
	
	IF (@mode = 'LookUpOrRegister' AND NOT EXISTS(SELECT [workstations].[wks_id] FROM [dbo].[workstations] WITH (NOLOCK) WHERE [workstations].[wks_macaddress] = @wks_macaddress))
	BEGIN
		DECLARE @srv_pxe_id AS INT
		SELECT @srv_pxe_id = srv_id FROM [dbo].[servers] WITH (NOLOCK) WHERE [servers].[srv_hostname] = [dbo].[fct_extract_hostname](@server_pxe);

		IF @srv_pxe_id IS NULL
		BEGIN
			INSERT INTO [dbo].[servers]
			([servers].[srv_hostname],[servers].[srv_domain])
			SELECT [dbo].[fct_extract_hostname](@server_pxe) , [dbo].[fct_extract_domain](@server_pxe);
			SET @srv_pxe_id = @@IDENTITY;
		END	
	
			DECLARE @wks_id AS INT;

			BEGIN TRY
				INSERT INTO [dbo].[workstations]
				([workstations].[wks_macaddress],[workstations].[wks_pxe_server_id])
				VALUES(@wks_macaddress,@srv_pxe_id);

				SET @wks_id = @@IDENTITY;

				DECLARE @evt_message as NVARCHAR(MAX)
				SET @evt_message = N'The workstation (mac address : ''' + ISNULL(@wks_macaddress,'') + ''') has been inserted.'

				EXEC [dbo].[usp_insert_event]
				@evc_name = 'CREATION',
				@evt_data = NULL,
				@evt_message = @evt_message,
				@evt_source = 'WDS',
				@evt_user = 'WEBS',
				@wks_id = @wks_id,
				@evt_justificatif = NULL;
			END TRY
			BEGIN CATCH
				IF ERROR_NUMBER() = 2627 -- Erreur "Violation of UNIQUE KEY constraint 'UQ_workstations_macaddress'. Cannot insert duplicate key in object 'dbo.workstations'" lors d'accès concurrents
				BEGIN
					-- L'adresse MAC est déjà insérée, on récupère l'id du poste
					SELECT @wks_id = [workstations].[wks_id] FROM [workstations] WITH (NOLOCK) WHERE [workstations].[wks_macaddress] = @wks_macaddress
				END
				ELSE
				BEGIN
					-- Les autres erreurs doivent se produire
					DECLARE @ErrorMessage NVARCHAR(4000) = ERROR_MESSAGE();
					DECLARE @ErrorSeverity INT = ERROR_SEVERITY();
					DECLARE @ErrorState INT = ERROR_STATE();
					RAISERROR(@ErrorMessage, @ErrorSeverity, @ErrorState)
				END
			END CATCH
			
			SELECT 
			[workstations].[wks_id], 
			CASE WHEN [wks_bios_status] <> 9 THEN [wks_bootconfiguration_bios] ELSE [wks_bootconfiguration_os] END as [wks_boot_menu],
			[workstations].[wks_kit_equipment], 
			NULL AS [name_name], 
			'-1' AS [state]
			FROM [workstations] WITH (NOLOCK)
			WHERE [workstations].[wks_id] = @wks_id
	END
	ELSE
	BEGIN
		SELECT
		[workstations].[wks_id], 
		CASE WHEN [wks_bios_status] <> 9 THEN [wks_bootconfiguration_bios] ELSE [wks_bootconfiguration_os] END as [wks_boot_menu],
		[workstations].[wks_kit_equipment], 
		[names].[name_name], 
		CASE 
		WHEN [workstations].[wks_setup_status] = 0 THEN 0 
		WHEN [workstations].[wks_setup_status] IN (1,2) THEN 1 
		WHEN [workstations].[wks_setup_status] = 3 THEN 3 
		WHEN [workstations].[wks_setup_status] = 9 AND [workstations].[wks_bios_status] = 9 THEN 4 
		WHEN [workstations].[wks_bios_status] = 1 THEN 1
		WHEN [workstations].[wks_bios_status] = 2 THEN 1 
		WHEN [workstations].[wks_bios_status] = 3 THEN 1 
		ELSE 4
		END AS [state]
		FROM [dbo].[workstations] WITH (NOLOCK)
		LEFT JOIN [dbo].[names] ON [names].[name_workstation_id] = [workstations].[wks_id]
		WHERE [workstations].[wks_macaddress] = @wks_macaddress
	END
			
END

