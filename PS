CREATE  PROCEDURE [dbo].[GETHISTORY_DELTA] 
@MACADDR AS CHAR(12),
@HISTOID AS INT
AS
BEGIN
	DECLARE @NEWER_VARS TABLE(VENOM NVARCHAR(100), VEVAL NVARCHAR(200));

	IF @HISTOID = 0
	BEGIN
		INSERT INTO @NEWER_VARS(VENOM, VEVAL)
		SELECT VENOM, PVEVALEUR
		FROM POSTEVARENV INNER JOIN VARENV ON PVEVEID = VEID
		INNER JOIN POSTE ON PVEPOID = POID
		WHERE POADRESSEMAC = @MACADDR;
	END
	ELSE
	BEGIN
		INSERT INTO @NEWER_VARS(VENOM, VEVAL)
		SELECT VENOM, HSTVAR_Valeur 
		FROM HSTPOVAR INNER JOIN VARENV ON HSTVAR_VEID = VEID
		WHERE HSTVAR_HID = @HISTOID
	END

	-- 1)  Select the most recent details
	SELECT @HISTOID AS HISTOID, VENOM AS NAME, VEVAL AS VALUE FROM @NEWER_VARS

	UNION	

	-- 2) And then the oldest details
	SELECT HSTVAR_HID,VENOM,HSTVAR_Valeur 
	FROM HSTPOVAR INNER JOIN VARENV ON HSTVAR_VEID = VEID
	WHERE HSTVAR_HID IN
	(
		select top 1 hst_id from history where HST_POADRESSEMAC = @MACADDR 
		AND (@HISTOID = 0 OR hst_date < (select hst_date from history where HST_POADRESSEMAC = @MACADDR and hst_id=@HISTOID))
		order by hst_date desc
	);
END

