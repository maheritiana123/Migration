CREATE FUNCTION [dbo].[fct_enum_posteprinters]()
RETURNS TABLE
AS
RETURN (

		SELECT 
		p.poid, p.ponom, 
		-- Imprimante par DÚfaut
		CASE
			WHEN WPImpDef.pvevaleur like '\\%\%' THEN WPImpDef.pvevaleur 
			WHEN WPImpDef.pvevaleur like 'USB%' THEN 'USB001' 
			WHEN WPImpDef.pvevaleur like 'LOCAL%' THEN 'LOCAL001' 
			WHEN WPImpDef.pvevaleur = '' or WPImpDef.PVEValeur IS NULL THEN '' 
			ELSE 'N' 
		END WPImpDef, 
		-- Imprimante Partage
		CASE  
			WHEN WPPPrinterName.pvevaleur like '\\%\%' THEN
				CASE WPImpPartage.pvevaleur WHEN 'O' THEN 'O' ELSE 'N' END 
			ELSE 'N' END WPImpPartage,
		CASE 
			WHEN WPPPrinterName.pvevaleur like '\\%\%' THEN
				CASE WPImpPartage.pvevaleur WHEN 'O' THEN WPPPrinterName.pvevaleur ELSE '' END 
			ELSE '' END	WPPPrinterName,
		-- Imprimante Reseau 1
		CASE  
			WHEN WPRPrinterName.pvevaleur like '\\%\%' THEN
				CASE WPImpReseau.pvevaleur WHEN 'O' THEN 'O' ELSE 'N' END
			ELSE 'N' END WPImpReseau,
		CASE 
			WHEN WPRPrinterName.pvevaleur like '\\%\%' THEN
				CASE WPImpReseau.pvevaleur WHEN 'O' THEN WPRPrinterName.pvevaleur ELSE '' END
		ELSE '' END	WPRPrinterName,
		-- Imprimante Reseau 2
		CASE  
			WHEN WPRPrinterName2.pvevaleur like '\\%\%' THEN
				CASE WPImpReseau2.pvevaleur WHEN 'O' THEN 'O' ELSE 'N' END
			ELSE 'N' END WPImpReseau2,
		CASE 
			WHEN WPRPrinterName2.pvevaleur like '\\%\%' THEN
				CASE WPImpReseau2.pvevaleur WHEN 'O' THEN WPRPrinterName2.pvevaleur ELSE '' END
		ELSE '' END	WPRPrinterName2,
		-- Imprimante Reseau 3
		CASE  
			WHEN WPRPrinterName3.pvevaleur like '\\%\%' THEN
				CASE WPImpReseau3.pvevaleur WHEN 'O' THEN 'O' ELSE 'N' END
			ELSE 'N' END WPImpReseau3,
		CASE 
			WHEN WPRPrinterName3.pvevaleur like '\\%\%' THEN
				CASE WPImpReseau3.pvevaleur WHEN 'O' THEN WPRPrinterName3.pvevaleur ELSE '' END
		ELSE '' END	WPRPrinterName3,
		-- Imprimante USB
		CASE WPImpUsb.pvevaleur WHEN 'O' THEN 'O' ELSE 'N' END WPImpUsb,
		CASE WHEN WPUPrinterTER.pvevaleur like '_%' THEN
			CASE WPImpUsb.pvevaleur WHEN 'O' THEN ISNULL(WPUPrinterTER.pvevaleur,'') ELSE '' END 
		ELSE '' END WPUPrinterTER,
		CASE WHEN WPUPrinterTER.pvevaleur like '_%' THEN
			CASE WPImpUsb.pvevaleur WHEN 'O' THEN CASE WPURectoVerso.pvevaleur WHEN 'O' THEN 'O' ELSE 'N' END ELSE '' END 
		ELSE '' END WPURectoVerso,
		-- Imprimante Locale
		CASE WPImpLocal.pvevaleur WHEN 'O' THEN 'O' ELSE 'N' END WPImpLocal,
		CASE WHEN WPLPrinterTER.pvevaleur like '_%' THEN
			CASE WPImpLocal.pvevaleur WHEN 'O' THEN ISNULL(WPLPrinterTER.pvevaleur,'') ELSE '' END 
		ELSE '' END WPLPrinterTER,
		CASE WHEN WPLPrinterTER.pvevaleur like '_%' THEN
			CASE WPImpLocal.pvevaleur WHEN 'O' THEN CASE WPLRectoVerso.pvevaleur WHEN 'O' THEN 'O' ELSE 'N' END ELSE '' END 
		ELSE '' END WPLRectoVerso,
		-- Imprimante Libre Service
		CASE WPImpILS.pvevaleur WHEN 'O' THEN 'O' ELSE 'N' END WPImpILS,
		CASE WHEN WPIPrinterTER.pvevaleur like '_%' THEN
			CASE WPImpILS.pvevaleur WHEN 'O' THEN WPIIP.pvevaleur ELSE '' END 
		ELSE '' END WPIIP,
		CASE WHEN WPIPrinterTER.pvevaleur like '_%' THEN
			CASE WPImpILS.pvevaleur WHEN 'O' THEN WPIPrinterTER.pvevaleur ELSE '' END 
		ELSE '' END WPIPrinterTER,
		CASE WHEN WPIPrinterTER.pvevaleur like '_%' THEN
			CASE WPImpILS.pvevaleur WHEN 'O' THEN CASE WPIPrinterVerso.pvevaleur WHEN 'O' THEN 'O' ELSE 'N' END ELSE '' END 
		ELSE '' END WPIPrinterVerso,
		CASE WHEN WPIPrinterTER.pvevaleur like '_%' THEN
			CASE WPImpILS.pvevaleur WHEN 'O' THEN WPLecteurILS.pvevaleur ELSE '' END 
		ELSE '' END WPLecteurILS
		FROM 
		poste p
		-- Imprimante par DÚfaut
		left outer join postevarenv WPImpDef on WPImpdef.pveveid = (select veid from varenv where venom = 'WPImpdef') and WPImpdef.pvepoid = p.poid 
		-- Imprimante Partage
		left outer join postevarenv WPImpPartage on WPImpPartage.pveveid = (select veid from varenv where venom = 'WPImpPartage') and WPImpPartage.pvepoid = p.poid
		left outer join postevarenv WPPPrinterName on WPPPrinterName.pveveid = (select veid from varenv where venom = 'WPPPrinterName') and WPPPrinterName.pvepoid = p.poid
		-- Imprimante Reseau 1
		left outer join postevarenv WPImpReseau on WPImpReseau.pveveid = (select veid from varenv where venom = 'WPImpReseau') and WPImpReseau.pvepoid = p.poid
		left outer join postevarenv WPRPrinterName on WPRPrinterName.pveveid = (select veid from varenv where venom = 'WPRPrinterName') and WPRPrinterName.pvepoid = p.poid
		-- Imprimante Reseau 2
		left outer join postevarenv WPImpReseau2 on WPImpReseau2.pveveid = (select veid from varenv where venom = 'WPImpReseau2') and WPImpReseau2.pvepoid = p.poid
		left outer join postevarenv WPRPrinterName2 on WPRPrinterName2.pveveid = (select veid from varenv where venom = 'WPRPrinterName2') and WPRPrinterName2.pvepoid = p.poid
		-- Imprimante Reseau 3
		left outer join postevarenv WPImpReseau3 on WPImpReseau3.pveveid = (select veid from varenv where venom = 'WPImpReseau3') and WPImpReseau3.pvepoid = p.poid
		left outer join postevarenv WPRPrinterName3 on WPRPrinterName3.pveveid = (select veid from varenv where venom = 'WPRPrinterName3') and WPRPrinterName3.pvepoid = p.poid
		-- Imprimante USB
		left outer join postevarenv WPImpUsb on WPImpUsb.pveveid = (select veid from varenv where venom = 'WPImpUsb') and WPImpUsb.pvepoid = p.poid
		left outer join postevarenv WPUPrinterTER on WPUPrinterTER.pveveid = (select veid from varenv where venom = 'WPUPrinterTER') and WPUPrinterTER.pvepoid = p.poid
		left outer join postevarenv WPURectoVerso on WPURectoVerso.pveveid = (select veid from varenv where venom = 'WPURectoVerso') and WPURectoVerso.pvepoid = p.poid
		-- Imprimante Locale
		left outer join postevarenv WPImpLocal on WPImpLocal.pveveid = (select veid from varenv where venom = 'WPImpLocal') and WPImpLocal.pvepoid = p.poid
		left outer join postevarenv WPLPrinterTER on WPLPrinterTER.pveveid = (select veid from varenv where venom = 'WPLPrinterTER') and WPLPrinterTER.pvepoid = p.poid
		left outer join postevarenv WPLRectoVerso on WPLRectoVerso.pveveid = (select veid from varenv where venom = 'WPLRectoVerso') and WPLRectoVerso.pvepoid = p.poid
		-- Imprimante Libre Service
		left outer join postevarenv WPImpILS on WPImpILS.pveveid = (select veid from varenv where venom = 'WPImpILS') and WPImpILS.pvepoid = p.poid
		left outer join postevarenv WPIIP on WPIIP.pveveid = (select veid from varenv where venom = 'WPIIP') and WPIIP.pvepoid = p.poid
		left outer join postevarenv WPIPrinterTER on WPIPrinterTER.pveveid = (select veid from varenv where venom = 'WPIPrinterTER') and WPIPrinterTER.pvepoid = p.poid
		left outer join postevarenv WPIPrinterVerso on WPIPrinterVerso.pveveid = (select veid from varenv where venom = 'WPIPrinterVerso') and WPIPrinterVerso.pvepoid = p.poid
		left outer join postevarenv WPLecteurILS on WPLecteurILS.pveveid = (select veid from varenv where venom = 'WPLecteurILS') and WPLecteurILS.pvepoid = p.poid

)
GO
