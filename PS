	END
	IF (@srv_imp IS NOT NULL)
	BEGIN
	SET @WHERE = [dbo].[fct_add_condition](@WHERE,'EXISTS(SELECT * FROM [dbo].[networkprinters_view] WITH (NOLOCK) WHERE wks_id = net_workstation_id AND prn_server_id in (SELECT srv_id from [dbo].[servers] WITH (NOLOCK) where srv_hostname like ''%' + @srv_imp + '%'')) ','AND');
	END
	IF (@list_views IS NOT NULL AND @list_views.value('count(/views/view)','INT') > 0)
	BEGIN
	DECLARE @list_v AS VARCHAR(MAX);
	SET @list_v = ''
	SELECT @list_v = @list_v + ',''' + t2.toto.value('.','VARCHAR(MAX)') + '''' FROM @list_views.nodes('views/view') as t2(toto)
	SET @WHERE = [dbo].[fct_add_condition](@WHERE,'wks_ref_server_id in (SELECT distinct viewsrv_server_id from views_servers inner join views ON view_id = viewsrv_view_id WHERE view_name in ('+SUBSTRING(@list_v,2,len(@list_v))+') GROUP BY viewsrv_server_id HAVING count(viewsrv_view_id) = '+CAST(@list_views.value('count(views/view)','INT') AS VARCHAR(MAX))+')','AND');
	END
	IF (@srv IS NOT NULL)
	BEGIN
	DECLARE @wks_ref_server_id AS INT
	SELECT @wks_ref_server_id = srv_id FROM [dbo].[servers] WITH (NOLOCK) WHERE srv_hostname = @srv
	SET @WHERE = [dbo].[fct_add_condition](@WHERE,'wks_ref_server_id = ' + CAST(@wks_ref_server_id AS VARCHAR) + '','AND');
	END
	IF (@user IS NOT NULL OR @evc_name IS NOT NULL OR @datetime_debut IS NOT NULL OR @datetime_fin IS NOT NULL)
	BEGIN
	SET @WHERE = [dbo].[fct_add_condition](@WHERE,'EXISTS(SELECT * FROM [dbo].[eventlog] WITH (NOLOCK) WHERE evt_guid = wks_guid ' +
			CASE WHEN @user IS NOT NULL THEN 'and evt_user like ''%' + @user + '%''' ELSE '' END +
			CASE WHEN @evc_name IS NOT NULL THEN 'and evt_class_id IN (SELECT evc_id FROM [dbo].[eventclasses] WITH (NOLOCK) WHERE evc_name like ''%' + @evc_name + '%'')' ELSE '' END +
			CASE WHEN @datetime_debut IS NOT NULL THEN 'and evt_timegenerated >= CONVERT(DATETIME , ''' + @datetime_debut + ''' , 120)' ELSE '' END +
			CASE WHEN @datetime_fin IS NOT NULL THEN 'and evt_timegenerated <= CONVERT(DATETIME , ''' + @datetime_fin + ''' , 120)' ELSE '' END +
			')'
			,'AND');
	END			
	IF (@evt_justificatif IS NOT NULL)
	BEGIN
	SET @WHERE = [dbo].[fct_add_condition](@WHERE,'EXISTS(SELECT * FROM [dbo].[eventlog] WITH (NOLOCK) WHERE evt_guid = wks_guid AND [evt_workstation_justificatif] like ''%' + @evt_justificatif + '%'')','AND');
	END
	IF (@usb_mat_productcode IS NOT NULL)
	BEGIN
	SET @WHERE = [dbo].[fct_add_condition](@WHERE,'EXISTS(SELECT usb_id FROM [dbo].[usbprinters] WITH (NOLOCK) WHERE usb_workstation_id = wks_id AND usb_mat_productcode like ''%' + @usb_mat_productcode + '%'')','AND');
	END
	IF (@usb_duplex IS NOT NULL)
	BEGIN
	SET @WHERE = [dbo].[fct_add_condition](@WHERE,'EXISTS(SELECT usb_id FROM [dbo].[usbprinters] WITH (NOLOCK) WHERE usb_workstation_id = wks_id AND usb_duplex = ''' + @usb_duplex + ''')','AND');
	END
	IF (@loc_mat_productcode IS NOT NULL)
	BEGIN
	SET @WHERE = [dbo].[fct_add_condition](@WHERE,'EXISTS(SELECT loc_id FROM [dbo].[localprinters] WITH (NOLOCK) WHERE loc_workstation_id = wks_id AND loc_mat_productcode like ''%' + @loc_mat_productcode + '%'')','AND');
	END
	IF (@loc_duplex IS NOT NULL)
	BEGIN
	SET @WHERE = [dbo].[fct_add_condition](@WHERE,'EXISTS(SELECT loc_id FROM [dbo].[localprinters] WITH (NOLOCK) WHERE loc_workstation_id = wks_id AND loc_duplex = ''' + @loc_duplex + ''')','AND');
	END
	IF (@ils_mat_productcode IS NOT NULL)
	BEGIN
	SET @WHERE = [dbo].[fct_add_condition](@WHERE,'EXISTS(SELECT ils_id FROM [dbo].[ilsprinters] WITH (NOLOCK) WHERE ils_workstation_id = wks_id AND ils_mat_productcode like ''%' + @ils_mat_productcode + '%'')','AND');
	END
	IF (@ils_duplex IS NOT NULL)
	BEGIN
	SET @WHERE = [dbo].[fct_add_condition](@WHERE,'EXISTS(SELECT ils_id FROM [dbo].[ilsprinters] WITH (NOLOCK) WHERE ils_workstation_id = wks_id AND ils_duplex = ''' + @ils_duplex + ''')','AND');
	END
	IF (@ged_driver IS NOT NULL)
	BEGIN
	SET @WHERE = [dbo].[fct_add_condition](@WHERE,'EXISTS(SELECT ged_id FROM [dbo].[gedscanners] WITH (NOLOCK) WHERE ged_workstation_id = wks_id AND ged_driver like ''%' + @ged_driver + '%'')','AND');
	END
	IF (@varenv_value IS NOT NULL)
	BEGIN
		IF (@varenv IS NOT NULL)
		BEGIN
		SET @WHERE = [dbo].[fct_add_condition](@WHERE,'EXISTS(SELECT wksopt_id FROM [dbo].[workstations_options] WITH (NOLOCK) WHERE wksopt_workstation_id = wks_id AND wksopt_option_id in (SELECT opt_id FROM [dbo].[options] WITH (NOLOCK) WHERE opt_name = ''' + @varenv + ''') AND wksopt_value = ''' + @varenv_value + ''')','AND');
		END
		ELSE
		BEGIN
		SET @WHERE = [dbo].[fct_add_condition](@WHERE,'EXISTS(SELECT wksopt_id FROM [dbo].[workstations_options] WITH (NOLOCK) WHERE wksopt_workstation_id = wks_id AND wksopt_value = ''' + @varenv_value + ''')','AND');
		END
	END
	IF (@varenv IS NOT NULL AND @varenv_value IS NULL)
	BEGIN
	SET @WHERE = [dbo].[fct_add_condition](@WHERE,'EXISTS(SELECT wksopt_id FROM [dbo].[workstations_options] WITH (NOLOCK) WHERE wksopt_workstation_id = wks_id AND wksopt_option_id in (SELECT opt_id FROM [dbo].[options] WITH (NOLOCK) WHERE opt_name = ''' + @varenv + '''))','AND');
	END
	
	

DECLARE @requete AS VARCHAR(MAX);
SET @requete =  
          'SELECT 
          wks_id,
          wks_macaddress,
		  wks_uuid,
          name_name,
          wks_setup_status,
		  wks_compromised,
          wks_kit_model,
          wks_kit_operating_system,
          wks_kit_equipment,
          wks_mat_barcode,
          wks_ref_server_id,
          wks_ref_server_srv_fullname,
          perimeter,
          CONVERT(VARCHAR,wks_lastupdate, 120) wks_lastupdate
          FROM [dbo].[workstations_view] WITH (NOLOCK)'
          + ' ' + ISNULL(@WHERE,'') + ' ';

EXEC [dbo].[USP_PAGINATION]
@page = @page,
@nb_par_page = @nb_par_page,
@col_order = @col_order,
@order = @order,
@requete_appelante = @requete;

END
