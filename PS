CREATE PROCEDURE [dbo].[SEARCH_SERVER_BY_AD]
	@Fede as varchar(15) = '',
	@Site as varchar(30) = '',
	@Domain as varchar(128) = '',
	@SrvName as varchar(100) = '',
	@TypePXE as bit = 1,
	@TypeAV as bit = 1,
	@TypeSMS as bit = 1,
	@TypeSNA as bit = 1
AS
BEGIN
	-- SET NOCOUNT ON added to prevent extra result sets from
	-- interfering with SELECT statements.
	SET NOCOUNT ON;

	SELECT DISTINCT A.SrvId, A.SrvName,
	CASE WHEN A.SrvId = Srv_Pxe_Id THEN 1 ELSE 0 END AS PXE,
	CASE WHEN A.SrvId = Srv_Av_Id THEN 1 ELSE 0 END AS AV,
	CASE WHEN A.SrvId = Srv_Sms_Id THEN 1 ELSE 0 END AS SMS,
	CASE WHEN A.SrvId = Srv_Sna_Id THEN 1 ELSE 0 END AS SNA
	FROM SRV A WITH (NOLOCK)
	LEFT OUTER JOIN ADSPATH ON ((@TypePXE = 1 AND A.SrvId = Srv_Pxe_Id) OR (@TypeAV = 1 AND A.SrvId = Srv_Av_Id) OR (@TypeSMS = 1 AND A.SrvId = Srv_Sms_Id) OR (@TypeSNA = 1 AND A.SrvId = Srv_Sna_Id))
	LEFT OUTER JOIN AD_FEDERATION ON Adspath_Federation_Id = Ad_Federation_Id 
	LEFT OUTER JOIN AD_SITE_LOCATION ON Adspath_Site_Id = Ad_Site_Id 
	LEFT OUTER JOIN AD_DOMAIN ON Adspath_Domain_Id = Ad_Domain_Id 
	WHERE (@Fede='' OR Ad_Federation_Name=@Fede)
	AND (@Site='' OR Ad_Site_Name=@Site)
	AND (@Domain='' OR Ad_Domain_Name_full=@Domain)
	AND (@SrvName = '' OR A.SrvName LIKE (@SrvName + '%'))
	ORDER BY A.SrvName
END
