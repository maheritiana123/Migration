CREATE FUNCTION [dbo].[fct_enum_defaultprinters]()
RETURNS TABLE
AS
RETURN (
	SELECT PoId,PoNom,WPImpDef as defaut, 1 reseau, 0 usb, 0 local
	FROM fct_enum_posteprinters()
	WHERE WPImpDef like '\\%\%'
	UNION
	SELECT PoId,PoNom,WPImpDef as defaut, 0 reseau, 1 usb, 0 local
	FROM fct_enum_posteprinters()
	WHERE WPImpDef = 'USB001'
	UNION
	SELECT PoId,PoNom,WPImpDef as defaut, 0 reseau, 0 usb, 1 local
	FROM fct_enum_posteprinters()
	WHERE WPImpDef = 'LOCAL001'
)
